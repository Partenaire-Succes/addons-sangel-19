<odoo>

    <record id="view_stock_excel_import_wizard_form" model="ir.ui.view">
        <field name="name">stock.excel.import.wizard.form</field>
        <field name="model">stock.excel.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Stock from Excel">

                <header>
                    <!-- Bouton confirmer (visible après chargement) -->
                    <button string="Confirmer"
                            name="action_confirm"
                            type="object"
                            class="btn-success"
                            invisible="state != 'loaded'"/>
                </header>

                <group>
                    <group>
                        <field name="file" widget="binary" filename="file_name"/>
                        <field name="file_name" invisible="1"/>
                        <field name="company_id"/>
                        <field name="location_id" invisible="import_mode == 'partner'"/>
                        <field name="warehouse_id" invisible="import_mode == 'partner'"/>

                        <field name="import_mode" invisible="1"/>
                        <field name="state" invisible="1"/>
                    </group>
                    <group>
                        <!-- Bouton 1 : charger produits -->
                        <button string="Charger Produits"
                                name="action_load_file"
                                type="object"
                                class="btn-primary"
                                invisible="state == 'done'"/>

                        <!-- Bouton 2 : charger contacts -->
                        <button string="Charger Contacts"
                                name="action_load_file_partner"
                                type="object"
                                class="btn-secondary"
                                invisible="state == 'done'"/>
                    </group>
                </group>

                <notebook>
                    <!-- Onglet produits -->
                    <page string="Produits">
                        <field name="line_ids" readonly="1">
                            <list editable="bottom">
                                <field name="product_code"/>
                                <field name="product_id" column_invisible="1"/>
                                <field name="product_name"/>
                                <field name="p_state"/>
                                <field name="quantity"/>
                                <field name="cost"/>
                                <field name="found"/>
                            </list>
                        </field>
                    </page>

                    <!-- Onglet contacts -->
                    <page string="Contacts">
                        <field name="line_ids">
                            <list>
                                <field name="customer_id"/>
                                <field name="partner_id"/>
                                <field name="customer_account"/>
                                <field name="partner_found" widget="boolean"/>
                            </list>
                        </field>
                    </page>
                </notebook>

                <footer>

                    <button name="action_confirm"
                            type="object"
                            string="Confirm"
                            class="btn-success"
                            invisible="state != 'loaded'"/>

                    <button string="Cancel" special="cancel"/>

                </footer>

            </form>
        </field>
    </record>

    <record id="action_stock_excel_import" model="ir.actions.act_window">
        <field name="name">Stock Excel Import</field>
        <field name="res_model">stock.excel.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_stock_excel_import" 
              name="Import Stock Excel" 
              parent="stock.menu_stock_adjustments" 
              action="action_stock_excel_import"
              sequence="100"/>

</odoo>