<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════════════════
         Assistant — Rapport des mouvements par produit
         On choisit un ou plusieurs articles (+ période optionnelle), et on
         sort tous leurs mouvements de stock validés (date, type d'opération,
         référence, quantité, prix, valeur) avec les sommes par article.
         Export PDF et Excel.
         ══════════════════════════════════════════════════════════════════════ -->

    <record id="view_stock_move_product_report_wizard_form" model="ir.ui.view">
        <field name="name">stock.move.product.report.wizard.form</field>
        <field name="model">stock.move.product.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Mouvements par produit">
                <sheet>
                    <div class="oe_title">
                        <h1>Mouvements par produit</h1>
                        <h3 class="text-muted">
                            Historique détaillé des mouvements de stock, article par article
                        </h3>
                    </div>
                    <group>
                        <group string="Articles">
                            <field name="product_ids"
                                   widget="many2many_tags"
                                   options="{'no_create': True}"
                                   placeholder="Sélectionnez un ou plusieurs articles…"/>
                        </group>
                        <group string="Filtres">
                            <field name="company_id"
                                   options="{'no_create': True, 'no_open': True}"
                                   readonly="1"/>
                            <label for="date_debut" string="Période"/>
                            <div>
                                <field name="date_debut" class="oe_inline"/>
                                -
                                <field name="date_fin" class="oe_inline"/>
                            </div>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_print_report"
                            string="Imprimer PDF"
                            type="object"
                            class="btn-primary"
                            icon="fa-print"/>
                    <button name="action_export_excel"
                            string="Télécharger Excel"
                            type="object"
                            class="btn-success"
                            icon="fa-file-excel-o"/>
                    <button string="Annuler"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_stock_move_product_report_wizard" model="ir.actions.act_window">
        <field name="name">Mouvements par produit</field>
        <field name="res_model">stock.move.product.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Menu : Inventaire → Analyse (stock.menu_warehouse_report) -->
    <menuitem id="menu_stock_move_product_report"
              name="Mouvements par produit"
              parent="stock.menu_warehouse_report"
              action="action_stock_move_product_report_wizard"
              sequence="60"/>

</odoo>
