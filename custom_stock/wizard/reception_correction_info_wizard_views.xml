<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════════════════
         TOUTES LES VUES DE CORRECTION / MODIFICATION DES RÉCEPTIONS
         - Wizard 1 : Modifier les informations (sans impact stock)
         - Wizard 2 : Corriger les quantités de stock (différentiel)
         - Héritage picking : les deux boutons ensemble
         ══════════════════════════════════════════════════════════════════════ -->


    <!-- ── WIZARD 1 : Modification des informations ──────────────────────── -->

    <record id="view_reception_correction_info_wizard_form" model="ir.ui.view">
        <field name="name">reception.correction.info.wizard.form</field>
        <field name="model">reception.correction.info.wizard</field>
        <field name="arch" type="xml">
            <form string="Modifier les informations de la réception">
                <sheet>
                    <div class="oe_title">
                        <h1>Modifier les informations</h1>
                        <h3 class="text-muted">Sans impact sur le stock ni la comptabilité</h3>
                    </div>

                    <div class="alert alert-warning mb-3" role="alert">
                        <i class="fa fa-pencil"/>
                        Modifiez librement les informations descriptives.
                        Les mouvements de stock restent <strong>inchangés</strong>.
                        Chaque modification est <strong>tracée dans le chatter</strong>.
                    </div>

                    <group>
                        <group string="Réception concernée">
                            <field name="picking_id" readonly="1"/>
                        </group>
                    </group>

                    <group>
                        <group string="Informations à modifier">
                            <field name="ref_sage"
                                   placeholder="Réf. Cession, BL Sage…"/>
                            <field name="partner_id"
                                   options="{'no_create': True, 'no_create_edit': True}"
                                   placeholder="Fournisseur"/>
                            <field name="scheduled_date"/>
                            <field name="note"
                                   placeholder="Remarque, référence BL…"/>
                        </group>
                    </group>
                </sheet>

                <footer>
                    <button name="action_appliquer"
                            string="Appliquer les modifications"
                            type="object"
                            class="btn-primary"
                            data-hotkey="q"
                            confirm="Confirmer les modifications ? Elles seront tracées dans le chatter."/>
                    <button string="Annuler"
                            class="btn-secondary"
                            special="cancel"
                            data-hotkey="x"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_reception_correction_info_wizard" model="ir.actions.act_window">
        <field name="name">Modifier les informations</field>
        <field name="res_model">reception.correction.info.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="stock.model_stock_picking"/>
        <field name="binding_view_types">form</field>
    </record>


    <!-- ── WIZARD 2 : Correction des quantités de stock ──────────────────── -->

    <record id="view_reception_correction_stock_wizard_form" model="ir.ui.view">
        <field name="name">reception.correction.stock.wizard.form</field>
        <field name="model">reception.correction.stock.wizard</field>
        <field name="arch" type="xml">
            <form string="Corriger les quantités de stock">
                <sheet>
                    <div class="oe_title">
                        <h1>Correction de stock</h1>
                        <h3 class="text-muted">
                            Saisissez les quantités correctes — des pickings de correction seront créés automatiquement
                        </h3>
                    </div>

                    <div class="alert alert-danger mb-3" role="alert">
                        <i class="fa fa-exclamation-circle"/>
                        <strong>Action irréversible.</strong>
                        Des mouvements de stock réels seront créés et validés pour corriger
                        les quantités. Vérifiez bien avant de valider.
                    </div>

                    <group>
                        <group string="Réception concernée">
                            <field name="picking_id" readonly="1"/>
                        </group>
                        <group string="Motif (obligatoire)">
                            <field name="motif"
                                   placeholder="Ex : Erreur saisie quantité, produit manquant BL…"
                                   required="1"/>
                        </group>
                    </group>

                    <field name="line_ids">
                        <list editable="bottom"
                              decoration-danger="delta &lt; 0"
                              decoration-success="delta &gt; 0"
                              decoration-muted="delta == 0">
                            <field name="product_id" readonly="1" string="Article"/>
                            <field name="product_uom_id" readonly="1" string="Unité"/>
                            <field name="qty_originale" readonly="1" string="Qté reçue"/>
                            <field name="qty_correcte" required="1" string="Qté correcte"/>
                            <field name="delta" readonly="1" string="Écart"
                                   decoration-danger="delta &lt; 0"
                                   decoration-success="delta &gt; 0"/>
                            <field name="price_unit" readonly="1" string="Prix"/>
                        </list>
                    </field>

                    <div class="alert alert-info mt-2" role="alert" style="font-size: 85%;">
                        <strong>Comment ça fonctionne :</strong><br/>
                        &#x2022; Ligne rouge (écart négatif) &#x2192; retour vers le fournisseur créé.<br/>
                        &#x2022; Ligne verte (écart positif) &#x2192; réception complémentaire créée.<br/>
                        &#x2022; Ligne grise (écart = 0) &#x2192; aucune action.
                    </div>
                </sheet>

                <footer>
                    <button name="action_appliquer"
                            string="Appliquer la correction"
                            type="object"
                            class="btn-danger"
                            data-hotkey="q"
                            confirm="Confirmer ? Des mouvements de stock réels seront créés et immédiatement validés."/>
                    <button string="Annuler"
                            class="btn-secondary"
                            special="cancel"
                            data-hotkey="x"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_reception_correction_stock_wizard" model="ir.actions.act_window">
        <field name="name">Corriger le stock</field>
        <field name="res_model">reception.correction.stock.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="stock.model_stock_picking"/>
        <field name="binding_view_types">form</field>
    </record>


    <!-- ── HÉRITAGE PICKING FORM — Bouton impression (toutes réceptions) ── -->

    <record id="view_picking_btn_impression" model="ir.ui.view">
        <field name="name">stock.picking.btn.impression</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <!-- Masquer le bouton natif Odoo -->
            <xpath expr="//button[@name='do_print_picking']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <!-- Insérer le bouton personnalisé à la place -->
            <xpath expr="//button[@name='do_print_picking']" position="after">
                <button name="%(action_report_bon_reception)d"
                        string="Imprimer"
                        type="action"
                        class="btn-secondary"
                        icon="fa-print"
                        invisible="picking_type_code != 'incoming'"
                        help="Imprimer le bon de r&#233;ception personnalis&#233;."/>
            </xpath>
        </field>
    </record>

    <!-- ── HÉRITAGE PICKING FORM — Boutons correction (réceptions directes) -->

    <record id="view_picking_btn_corrections" model="ir.ui.view">
        <field name="name">stock.picking.btn.corrections</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('oe_button_box')]" position="inside">

                <button name="%(action_reception_correction_info_wizard)d"
                        string="Modifier les infos"
                        type="action"
                        class="oe_stat_button"
                        icon="fa-pencil"
                        invisible="1"
                        groups="custom_pos.group_superviseur,custom_pos.group_responsable_magasin,custom_pos.group_dsi_it"
                        help="Modifier r&#233;f. Sage, fournisseur, date ou notes sans toucher au stock."/>

                <button name="%(action_reception_correction_stock_wizard)d"
                        string="Corriger le stock"
                        type="action"
                        class="oe_stat_button"
                        icon="fa-wrench"
                        invisible="1"
                        groups="custom_pos.group_superviseur,custom_pos.group_dsi_it"
                        help="Corriger les quantit&#233;s re&#231;ues par pickings diff&#233;rentiels."/>

            </xpath>
        </field>
    </record>

</odoo>
