<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_stock_return_picking_form_price_unit" model="ir.ui.view">
        <field name="name">stock.return.picking.form.price.unit</field>
        <field name="model">stock.return.picking</field>
        <field name="inherit_id" ref="stock.view_stock_return_picking_form"/>
        <field name="arch" type="xml">
            <field name="uom_id" position="after">
                <field name="price_unit" string="Prix unitaire" readonly="1" required="1"/>
            </field>

            <!-- Masquer "Tout renvoyer" et "Retour pour échanger" — seul le
                 bouton "Retour" doit rester visible dans le wizard de retour
                 natif. On laisse les actions/boutons en place (invisible="1")
                 pour ne rien casser côté code Python. -->
            <button name="action_create_returns_all" position="attributes">
                <attribute name="invisible">1</attribute>
            </button>
            <button name="action_create_exchanges" position="attributes">
                <attribute name="invisible">1</attribute>
            </button>
        </field>
    </record>
</odoo>
