<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
   <data noupdate="1">
        <record id="ir_sequence_stock_picking_inter" model="ir.sequence">
            <field name="name">Tansfert inter societe</field>
            <field name="code">stock.picking.inter</field>
            <field name="prefix">WHI/</field>
            <field name="padding">5</field>
            <field name="number_next_actual">1</field>
            <field name="number_increment">1</field>
            <field name="implementation">no_gap</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="ir_sequence_stock_picking_supply_request" model="ir.sequence">
            <field name="name">Demande de transfert inter societe</field>
            <field name="code">stock.picking.supply.request</field>
            <field name="prefix">SUPREQ/</field>
            <field name="padding">5</field>
            <field name="number_next_actual">1</field>
            <field name="number_increment">1</field>
            <field name="implementation">no_gap</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="ir_sequence_stock_scrap_breakers" model="ir.sequence">
            <field name="name">Groupe de casse</field>
            <field name="code">stock.scrap.breakers</field>
            <field name="prefix">GP/SP/</field>
            <field name="padding">5</field>
            <field name="number_next_actual">1</field>
            <field name="number_increment">1</field>
            <field name="implementation">no_gap</field>
            <field name="company_id" eval="False"/>
        </record>
   </data>
</odoo>