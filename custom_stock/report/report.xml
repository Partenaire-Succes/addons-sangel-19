<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Rapport unique d'inventaire physique -->
        <record id="action_report_physical_inventory" model="ir.actions.report">
            <field name="name">Rapport d'Inventaire Physique Journalier</field>
            <field name="model">physical.inventory</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">custom_stock.report_physical_inventory</field>
            <field name="report_file">custom_stock.report_physical_inventory</field>
            <field name="binding_model_id" ref="model_physical_inventory"/>
            <field name="binding_type">report</field>
            <field name="paperformat_id" ref="base.paperformat_euro"/>
            <field name="print_report_name">'Inventaire_%s_%s' % (object.name, object.date)</field>
        </record>

        <!-- Rapport unique d'inventaire physique Décompte -->
        <record id="action_report_physical_inventory_decompte" model="ir.actions.report">
            <field name="name">Rapport d'Inventaire Physique Décompte</field>
            <field name="model">physical.inventory</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">custom_stock.report_physical_inventory_decompte</field>
            <field name="report_file">custom_stock.report_physical_inventory_decompte</field>
            <field name="binding_model_id" ref="model_physical_inventory"/>
            <field name="binding_type">report</field>
            <field name="paperformat_id" ref="base.paperformat_euro"/>
            <field name="print_report_name">'Décompte_%s_%s' % (object.name, object.date)</field>
        </record>
        <!-- Rapport consolidé Retours & Réceptions (déclenché par le wizard) -->
        <record id="action_report_retours_receptions" model="ir.actions.report">
            <field name="name">Rapport Retours et Réceptions consolidé</field>
            <field name="model">rapport.retours.receptions.wizard</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">custom_stock.report_retours_receptions</field>
            <field name="report_file">custom_stock.report_retours_receptions</field>
            <field name="paperformat_id" ref="base.paperformat_euro"/>
            <field name="print_report_name">'Rapport_Retours_Receptions'</field>
        </record>

        <!-- Bon de Réception personnalisé — stock.picking -->
        <record id="action_report_bon_reception" model="ir.actions.report">
            <field name="name">Bon de Réception</field>
            <field name="model">stock.picking</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">custom_stock.report_bon_reception</field>
            <field name="report_file">custom_stock.report_bon_reception</field>
            <field name="binding_model_id" ref="stock.model_stock_picking"/>
            <field name="binding_type">report</field>
            <field name="paperformat_id" ref="base.paperformat_euro"/>
            <field name="print_report_name">'Bon_Reception_%s' % object.name.replace('/', '_')</field>
        </record>
    </data>
</odoo>