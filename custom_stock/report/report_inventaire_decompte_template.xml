<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="report_physical_inventory_decompte_document">
            <t t-call="web.external_layout">

                <!-- ═══════════════════════════════════════════════════════════
                     CAS 1 — INVENTAIRE JOURNALIER (code_inventory_id défini)
                     Une page par code inventaire
                ════════════════════════════════════════════════════════════ -->
                <t t-if="doc.code_inventory_id">
                    <t t-foreach="doc.code_inventory_id" t-as="code_inv">
                        <div class="page" t-att-style="'page-break-before: always;' if not code_inv_first else ''">
                            <div class="oe_structure"/>

                            <div class="row">
                                <div class="col-4"> </div>
                                <div class="col-4 text-center">
                                    <span>Code Inv. : </span><span t-esc="code_inv.name"/>
                                </div>
                            </div>

                            <div class="row mt-3">
                                <div class="col-12">
                                    <strong>Liste Comptage Inventaire au </strong>
                                    <span t-field="doc.date" t-options="{'format': 'dd/MM/yyyy'}"/>
                                    <strong><h3><span t-field="doc.company_id.name"/></h3></strong>
                                </div>
                            </div>

                            <div class="row mt-3">
                                <div class="col-12" style="border: solid 1px #000;">
                                    <div class="row">
                                        <div class="col-2"><strong>Code Article :</strong></div>
                                        <div class="col-5"><strong>Désignation</strong></div>
                                        <div class="col-5"><strong>Qté Comptée</strong></div>
                                    </div>
                                </div>
                            </div>

                            <div class="row mt-4">
                                <div class="col-12">
                                    <t t-set="filtered_lines" t-value="doc.physical_line_ids.filtered(lambda l: l.code_inventory_id.id == code_inv.id and l.location_id.usage == 'internal' and l.product_tmpl_id.current_company_status_id.code == 'C' and l.company_id in l.product_tmpl_id.allowed_company_ids)"/>
                                    <t t-if="filtered_lines">
                                        <t t-foreach="filtered_lines" t-as="line">
                                            <div class="row" style="margin-bottom: 15px;">
                                                <div class="col-2">
                                                    <span t-field="line.product_tmpl_id.code_article"/>
                                                </div>
                                                <div class="col-5">
                                                    <span t-field="line.product_tmpl_id.name"/>
                                                </div>
                                                <div class="col-5">
                                                    <strong>Qté Totale = ___________________</strong>
                                                </div>
                                                <br/><br/>
                                            </div>
                                        </t>
                                    </t>
                                    <t t-else="">
                                        <div class="alert alert-warning">
                                            <strong>Aucune ligne d'inventaire trouvée pour ce code.</strong>
                                        </div>
                                    </t>
                                </div>
                            </div>

                            <div class="oe_structure"/>
                        </div>
                    </t>
                </t>

                <!-- ═══════════════════════════════════════════════════════════
                     CAS 2 — INVENTAIRE LIBRE (code_inventory_id non défini)
                     Une seule page avec toutes les lignes
                ════════════════════════════════════════════════════════════ -->
                <t t-else="">
                    <div class="page">
                        <div class="oe_structure"/>

                        <div class="row mt-3">
                            <div class="col-12">
                                <strong>Liste Comptage Inventaire Libre au </strong>
                                <span t-field="doc.date" t-options="{'format': 'dd/MM/yyyy'}"/>
                                <strong><h3><span t-field="doc.company_id.name"/></h3></strong>
                            </div>
                        </div>

                        <div class="row mt-3">
                            <div class="col-12" style="border: solid 1px #000;">
                                <div class="row">
                                    <div class="col-2"><strong>Code Article :</strong></div>
                                    <div class="col-5"><strong>Désignation</strong></div>
                                    <div class="col-5"><strong>Qté Comptée</strong></div>
                                </div>
                            </div>
                        </div>

                        <div class="row mt-4">
                            <div class="col-12">
                                <t t-if="doc.physical_line_ids">
                                    <t t-foreach="doc.physical_line_ids.filtered(lambda l: l.location_id.usage == 'internal' and l.product_tmpl_id.current_company_status_id.code == 'C' and l.company_id in l.product_tmpl_id.allowed_company_ids)" t-as="line">
                                        <div class="row" style="margin-bottom: 15px;">
                                            <div class="col-2">
                                                <span t-field="line.product_tmpl_id.code_article"/>
                                            </div>
                                            <div class="col-5">
                                                <span t-field="line.product_tmpl_id.name"/>
                                            </div>
                                            <div class="col-5">
                                                <strong>Qté Totale = ___________________</strong>
                                            </div>
                                            <br/><br/>
                                        </div>
                                    </t>
                                </t>
                                <t t-else="">
                                    <div class="alert alert-warning">
                                        <strong>Aucune ligne d'inventaire trouvée.</strong>
                                    </div>
                                </t>
                            </div>
                        </div>

                        <div class="oe_structure"/>
                    </div>
                </t>

            </t>
        </template>

        <template id="report_physical_inventory_decompte">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <t t-call="custom_stock.report_physical_inventory_decompte_document"/>
                </t>
            </t>
        </template>
    </data>
</odoo>