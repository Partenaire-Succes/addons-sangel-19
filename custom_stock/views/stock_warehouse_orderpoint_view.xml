<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_stock_picking_form_inherits" model="ir.ui.view">
        <field name="name">stock.picking.form.inherits</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='picking_type_id']" position="after">
                <field name="ref_sage"/>
                <field name="date_sage"/>
            </xpath>

            <xpath expr="//notebook/page[@name='operations']/field[@name='move_ids']//field[@name='quantity']" position="after">
                <field name="standard_price" readonly="1" string="Cout"/>
                <field name="price_unit" readonly="state in ('done','cancel')" string="Prix unitaire"/>
            </xpath>
        </field>
    </record>

    <record id="view_stock_quant_tree_inventory_editable_inherits" model="ir.ui.view">
        <field name="name">stock.quant.tree.inventory.editable.inherits</field>
        <field name="model">stock.quant</field>
        <field name="inherit_id" ref="stock.view_stock_quant_tree_inventory_editable"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_uom_id']" position="after">
                <field name="standard_price"/>
            </xpath>
        </field>
    </record>

    <record id="sproduct_supplierinfo_list_views_inherits" model="ir.ui.view">
        <field name="name">product.supplierinfo.list.views.inherits</field>
        <field name="model">product.supplierinfo</field>
        <field name="inherit_id" ref="product.product_supplierinfo_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='price']" position="after">
                <field name="primary" widget="boolean_toggle"/>
            </xpath>
        </field>
    </record>

    <record id="stock_warehouse_orderpoint_list_views_inherits" model="ir.ui.view">
        <field name="name">stock.warehouse.orderpoint.list.views.inherits</field>
        <field name="model">stock.warehouse.orderpoint</field>
        <field name="inherit_id" ref="stock.view_warehouse_orderpoint_tree_editable"/>
        <field name="arch" type="xml">

            <xpath expr="//list" position="attributes">
                <attribute name="multi_edit">1</attribute>
            </xpath>
            <xpath expr="//list" position="inside">
                <header>
                    <button name="auto_update_supply" 
                        type="object" 
                        string="Mettre à jour les fournisseurs" 
                        class="btn-primary"
                        icon="fa-magic"
                        confirm="Cette action va modifier les fournisseurs. Voulez-vous continuer ?"/>
                </header>
            </xpath>
            <xpath expr="//field[@name='product_id']" position="attributes">
                <attribute name="string">Code Article</attribute>
                <attribute name="domain">[
                    ('actif_x3', '=', '1'),
                    ('company_status_ids', 'not any', [
                        ('company_id', '=', company_id),
                        ('status_id.code', '=', 'D')
                    ])
                ]</attribute>
            </xpath>
            <!-- <xpath expr="//field[@name='product_id']" position="after">
                <field name="prod_name" string="Article"/>
            </xpath> -->
        </field>
    </record>

</odoo>