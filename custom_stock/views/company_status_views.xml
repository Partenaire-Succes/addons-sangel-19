<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_product_status_list" model="ir.ui.view">
        <field name="name">product.status.list</field>
        <field name="model">product.status</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_product_status_form" model="ir.ui.view">
        <field name="name">product.status.form</field>
        <field name="model">product.status</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_product_status" model="ir.actions.act_window">
        <field name="name">Statuts Produits</field>
        <field name="res_model">product.status</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_product_form_inherit_status" model="ir.ui.view">
        <field name="name">product.template.form.status</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">

            <xpath expr="//page[@name='general_information']" position="after">
                <page string="Info Magasin" name="info_magasin">
                    <group>
                        <group name="status_magasin" string="Statut magasin">
                            <field name="current_company_status_id"/>
                        </group>
                    </group>
                </page>
            </xpath>

        </field>
    </record>

    <menuitem id="menu_product_status_root"
              name="Statuts Produits"
              parent="sale.menu_sale_config"
              action="action_product_status"/>

</odoo>