<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_company_form" model="ir.ui.view">
            <field name="name">res.company.view.form.inherit.stock.inter.company</field>
            <field name="model">res.company</field>
            <field name="inherit_id" ref="base.view_company_form"/>
            <field name="arch" type="xml">
                <xpath expr="//page[1]" position="after">
                    <page name="inter_company" string="Système d'affectation magasin">
                        <group>
                            <group>
                                <field name="dest_warehouse_id"
                                    domain="[('company_id', '=', id)]"/>

                                <field name="lib_company" required="1"/> 
                            </group>
                            <group>
                                <field name="code_company" required="1"/>
                            </group>
                        </group>
                    </page>
                </xpath>

                <xpath expr="//notebook" position="inside">
                    <page name="sage_x3_accounting" string="SAGE X3 Comptabilité">
                        
                        <group string="Comptes Comptables">
                            <group string="Types de pieces">
                                <field name="sage_x3_type_facli" required="1"/>
                                <field name="sage_x3_avcli" required="1"/>
                                <field name="sage_x3_type_encai" required="1"/>
                                <field name="sage_x3_type_decai" required="1"/>
                            </group>
                            <group string="Journaux">
                                <field name="sage_x3_site" required="1"/>
                                <field name="sage_x3_journal_sale" required="1"/>
                                <field name="sage_x3_journal_caisse" required="1"/>
                            </group>
                            <group string="Comptes">
                                <field name="sage_x3_account_sale_id" 
                                    options="{'no_create': True}"
                                    placeholder="701xxxxx - Compte de vente unique"
                                    required="1"/>
                                <field name="sage_x3_account_customer_default_id"
                                    options="{'no_create': True}"
                                    placeholder="41110000 - Client DIVERS"
                                    required="1"/>
                                <field name="sage_x3_account_caisse_id"
                                    options="{'no_create': True}"
                                    placeholder="57110005 - Compte caisse"
                                    required="1"/>
                                <field name="sage_x3_account_ecart_caisse_id"
                                    options="{'no_create': True}"
                                    placeholder="77820000 - Ecart caisse"
                                    required="1"/>
                            </group>

                            <group>
                                <div class="alert alert-info">
                                    <h4>📝 Instructions de configuration</h4>
                                    <ul>
                                        <li><strong>Compte de vente</strong> : Un seul compte 701xxxxx par société</li>
                                        <li><strong>Client DIVERS</strong> : Compte générique 4111xxxx pour ventes comptoir</li>
                                    </ul>
                                    <p><strong>Exemples pour SANgel Yop demi-gros :</strong></p>
                                    <ul>
                                        <li>Vente : 70116000</li>
                                        <li>Client : 41110000 </li>
                                    </ul>
                                </div>
                            </group>
                        </group>
                        
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
