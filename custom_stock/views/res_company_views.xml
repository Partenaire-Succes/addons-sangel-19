<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_company_form" model="ir.ui.view">
            <field name="name">res.company.view.form.inherit.stock.inter.company</field>
            <field name="model">res.company</field>
            <field name="inherit_id" ref="base.view_company_form"/>
            <field name="arch" type="xml">
                <xpath expr="//page[1]" position="after">
                    <page name="inter_company" string="Système d'affectation magasin">
                        <group name="config_magasin">
                            <group>
                                <field name="dest_warehouse_id"
                                    domain="[('company_id', '=', id)]"/>

                                <field name="lib_company" required="1"/> 
                            </group>
                            <group>
                                <field name="code_company" required="1"/>
                                <field name="site_company" required="0"/>
                            </group>
                        </group>

                        <group name="info_magasin">
                            <group name='info_logo' string="Ettiquete Article">
                            </group>

                            <group>
                                <div class="alert alert-info">
                                    <h4>📝 Instructions de configuration</h4>
                                    <ul>
                                        <li><strong>YOP DEMI GROS </strong> Libelle: YOP01 Code: 01</li>
                                        <li><strong>YOP DETAIL </strong> Libelle: YOP02 Code: 02</li>
                                        <li><strong>YOP SYNACASSCI </strong> Libelle: SYNACASSCI Code: 03</li>
                                        <li><strong>YOP SQUARE </strong> Libelle: SQUARE Code: 04</li>
                                        <li><strong>YOP BASSAM </strong> Libelle: BASSAM Code: 05</li>
                                        <li><strong>YOP KOUMASSI </strong> Libelle: KOUMASSI Code: 06</li>
                                    </ul>
                                </div>
                            </group>
                            
                        </group>
                    </page>
                </xpath>

                <xpath expr="//notebook" position="inside">
                    <page name="sage_x3_accounting" string="SAGE X3 Comptabilité">
                        
                        <group string="Comptes Comptables">
                            <group string="Types de pieces">
                                <field name="sage_x3_type_facli" required="1"/>
                                <field name="sage_x3_avcli" required="1"/>
                                <field name="sage_x3_type_encai" required="1"/>
                                <field name="sage_x3_type_decai" required="1"/>
                            </group>
                            <group>
                                <div class="alert alert-info">
                                    <h4>📝 Instructions de configuration des pieces</h4>
                                    <ul>
                                        <li><strong>Facture client SAGE X3 </strong> FACLI</li>
                                        <li><strong>Avoir client SAGE X3 </strong> AVCLI</li>
                                        <li><strong>Encaissement client SAGE X3 </strong> ENCAI</li>
                                        <li><strong>Decaissement client SAGE X3 </strong> DECAI</li>
                                    </ul>
                                </div>
                            </group>

                            <group string="Journaux">
                                <field name="sage_x3_site" required="1"/>
                                <field name="sage_x3_journal_sale" required="1"/>
                                <field name="sage_x3_journal_caisse" required="1"/>
                                <field name="partner_devers_id" required="1"/>
                            </group>
                            <group>
                                <div class="alert alert-info">
                                    <h4>📝 Instructions de configuration des journaux</h4>
                                    <ul>
                                        <li><strong>Site SAGE X3 </strong> SIEGE</li>
                                        <li><strong>Journal ventes SAGE X3 </strong> VTE</li>
                                    </ul>
                                    <p><strong>Journal caisse SAGE Magasin :</strong></p>
                                    <ul>
                                        <li><strong>YOP DEMI GROS </strong> CYG</li>
                                        <li><strong>YOP DETAIL </strong> CYL</li>
                                        <li><strong>YOP SYNACASSCI </strong> CSYN</li>
                                        <li><strong>YOP SQUARE </strong> CSQR</li>
                                        <li><strong>YOP BASSAM </strong> CBSM</li>
                                        <li><strong>YOP KOUMASSI </strong> CKMS</li>
                                    </ul>
                                </div>
                            </group>
                            
                            <group string="Comptes">
                                <field name="sage_x3_account_sale_id" 
                                    options="{'no_create': True}"
                                    placeholder="701xxxxx - Compte de vente unique"
                                    required="1"/>
                                <field name="sage_x3_account_customer_default_id"
                                    options="{'no_create': True}"
                                    placeholder="41110000 - Client DIVERS"
                                    required="1"/> 

                                <field name="sage_x3_account_customer_int_default_id"
                                    options="{'no_create': True}"
                                    placeholder="41120000 - Client Int DIVERS"
                                    required="1"/> 
                                    
                                <field name="sage_x3_account_caisse_id"
                                    options="{'no_create': True}"
                                    placeholder="57110005 - Compte caisse"
                                    required="1"/>
                                <field name="sage_x3_account_sale_tva_18_id"
                                    options="{'no_create': True}"
                                    placeholder="44310000 - TVA 18"
                                    required="1"/>
                                <field name="sage_x3_account_sale_tva_9_id"
                                    options="{'no_create': True}"
                                    placeholder="44310000 - TVA 9"
                                    required="1"/>
                                <field name="sage_x3_account_sale_airsi_id"
                                    options="{'no_create': True}"
                                    placeholder="44600000 - AIRSI"
                                    required="1"/>
                            </group>

                            <group>
                                <div class="alert alert-info">
                                    <h4>📝 Instructions de configuration</h4>
                                    <ul>
                                        <li><strong>Compte de vente</strong> : Un seul compte 701xxxxx par société</li>
                                        <li><strong>Client DIVERS</strong> : Compte générique 4111xxxx pour ventes comptoir</li>
                                    </ul>
                                    <p><strong>Exemples pour SANgel Yop demi-gros :</strong></p>
                                    <ul>
                                        <li>Compte de vente : 70116000</li>
                                        <li>Compte client par défaut : 41110000 </li>
                                        <li>Compte caisse : 57120000 </li>
                                    </ul>
                                </div>
                            </group>
                        </group>
                        
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
