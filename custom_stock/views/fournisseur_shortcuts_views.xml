<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════════════════
         RACCOURCIS FOURNISSEURS — Inventaire > Fournisseurs
         Commandes fournisseurs, Réceptions fournisseurs
         Accès restreint : pas de Caissières
         ══════════════════════════════════════════════════════════════════════ -->

    <!-- Action : réceptions fournisseurs (pickings incoming) -->
    <record id="action_receptions_fournisseur_stock" model="ir.actions.act_window">
        <field name="name">Réceptions fournisseurs</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('picking_type_code', '=', 'incoming')]</field>
        <field name="context">{'default_picking_type_code': 'incoming'}</field>
    </record>

    <!-- Menu parent Fournisseurs -->
    <menuitem
        id="menu_fournisseur_root"
        name="Fournisseurs"
        parent="stock.menu_stock_root"
        sequence="27"
        groups="custom_pos.group_superviseur,custom_pos.group_assistant_magasin,custom_pos.group_responsable_magasin,custom_pos.group_dsi_it"
    />

    <!-- Commandes fournisseurs -->
    <menuitem
        id="menu_fournisseur_commandes"
        name="Commandes fournisseurs"
        parent="menu_fournisseur_root"
        action="purchase.purchase_form_action"
        sequence="10"
        groups="custom_pos.group_superviseur,custom_pos.group_assistant_magasin,custom_pos.group_responsable_magasin,custom_pos.group_dsi_it"
    />

    <!-- Réceptions fournisseurs -->
    <menuitem
        id="menu_fournisseur_receptions"
        name="Réceptions fournisseurs"
        parent="menu_fournisseur_root"
        action="action_receptions_fournisseur_stock"
        sequence="20"
        groups="custom_pos.group_superviseur,custom_pos.group_assistant_magasin,custom_pos.group_responsable_magasin,custom_pos.group_dsi_it"
    />


</odoo>
