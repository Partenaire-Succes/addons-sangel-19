<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_session_form_sage_x3" model="ir.ui.view">
        <field name="name">pos.session.form.sage_x3</field>
        <field name="model">pos.session</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_session_form"/>
        <field name="arch" type="xml">

            <!-- La vue de base verrouille tout le formulaire (edit="0"), ce
                 qui écrase le readonly="False" mis sur les champs SAGE X3
                 ci-dessous. On débloque l'édition ici ; les autres champs
                 restent protégés par leur propre condition readonly. -->
            <xpath expr="//form" position="attributes">
                <attribute name="edit">1</attribute>
            </xpath>

            <!-- Onglet SAGE X3 -->
            <xpath expr="//group" position="after">
                <group name="sage_x3" string="SAGE X3">
                    <group>
                        <field name="sage_x3_piece_number" readonly="False"/>
                        <field name="sage_x3_sent" readonly="False"/>
                    </group>
                    <group>
                        <field name="sage_x3_sent_date" readonly="False"/>
                        <field name="message" readonly="False"/>
                    </group>
                </group>
            </xpath>
            
        </field>
    </record>
</odoo>