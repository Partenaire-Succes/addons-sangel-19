<?xml version="1.0" encoding="UTF-8"?>
<odoo>

<!-- =====================================================
     LIST VIEW - physical.inventory.line.archive
     ===================================================== -->
    <record id="view_physical_inventory_line_archive_list" model="ir.ui.view">
        <field name="name">physical.inventory.line.archive.list</field>
        <field name="model">physical.inventory.line.archive</field>
        <field name="arch" type="xml">
            <list string="Lignes d'inventaire archivées"
                decoration-warning="needs_verification == True"
                decoration-success="verify == True">

                <field name="archived_date" string="Date d'archivage" optional="show"/>
                <field name="company_id" string="Société" optional="show" groups="base.group_multi_company"/>
                <field name="inventory_physical_id" string="Inventaire" optional="show"/>
                <field name="product_tmpl_id" string="Produit"/>
                <field name="code_article" string="Code Article" optional="show"/>
                <field name="code_category_id" string="Catégorie" optional="show"/>
                <field name="code_inventory_id" string="Code Inventaire" optional="show"/>
                <field name="location_id" string="Emplacement" optional="show"/>
                <field name="lot_id" string="N° Lot" optional="show"/>
                <field name="quantity" string="Stock Théorique" optional="show"/>
                <field name="physical_qty" string="Qté Comptée"/>
                <field name="qty_diff" string="Différence"
                    decoration-danger="qty_diff &lt; 0"
                    decoration-success="qty_diff &gt; 0"
                    decoration-muted="qty_diff == 0"/>
                <field name="standard_price" string="Prix Standard" optional="show"/>
                <field name="valorisation" string="Valorisation" optional="show"/>
                <field name="product_uom_id" string="Unité" optional="show"/>
                <field name="needs_verification" string="À vérifier" optional="show"/>
                <field name="verify" string="Inventorié" optional="show"/>
                <field name="archived_by" string="Archivé par" optional="show"/>
                <field name="archive_reason" string="Raison" optional="show"/>

            </list>
        </field>
    </record>


    <record id="action_physical_inventory_line_archive" model="ir.actions.act_window">
            <field name="name">Code Categorie inventaire</field>
            <field name="res_model">physical.inventory.line.archive</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Créer votre premier Code Categorie inventaire
                </p>
            </field>
        </record>

        <record id="physical_inventory_archive_company_rule" model="ir.rule">
            <field name="name">Physical Inventory: multi-company</field>
            <field name="model_id" ref="model_physical_inventory_line_archive"/>
            <field name="global" eval="True"/>
            <field name="domain_force">
                ['|',
                    ('company_id', '=', False),
                    ('company_id', 'in', company_ids)
                ]
            </field>
        </record>


    <!-- =====================================================
        MENU ITEM (à adapter selon votre structure de menus)
        ===================================================== -->
