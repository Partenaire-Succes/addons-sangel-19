<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========================================================================
         VUE FORMULAIRE FACTURE : Ajout champs et bouton SAGE X3
         ======================================================================== -->
    
    <record id="view_move_form_sage_x3" model="ir.ui.view">
        <field name="name">account.move.form.sage.x3</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            
            <!-- Onglet SAGE X3 -->
            <xpath expr="//notebook" position="inside">
                <page name="sage_x3" string="SAGE X3" invisible="move_type != 'out_invoice'">
                    <group>
                        <group string="Statut SAGE X3">
                            <field name="sage_x3_sent" readonly="1"/>
                            <field name="sage_x3_piece_type" readonly="1"/>
                            <field name="sage_x3_piece_number" readonly="1"/>
                            <field name="sage_x3_sent_date" readonly="1"/>
                        </group>
                        <group string="Détails">
                            <field name="sage_x3_response" 
                                   readonly="1" 
                                   invisible="not sage_x3_response"
                                   widget="text"/>
                            <field name="sage_x3_error" 
                                   readonly="1" 
                                   invisible="not sage_x3_error"
                                   widget="text"/>
                        </group>
                    </group>
                    
                    <!-- Indicateurs -->
                    <group>
                        <div class="alert alert-success" 
                             invisible="not sage_x3_sent"
                             style="margin: 10px;">
                            <strong>✅ Facture envoyée à SAGE X3</strong>
                            <p>N° Pièce: <field name="sage_x3_piece_number" readonly="1" nolabel="1"/></p>
                        </div>
                        
                        <div class="alert alert-danger" 
                             invisible="not sage_x3_error"
                             style="margin: 10px;">
                            <strong>❌ Erreur SAGE X3</strong>
                            <p><field name="sage_x3_error" readonly="1" nolabel="1"/></p>
                        </div>
                    </group>
                </page>
            </xpath>
            
        </field>
    </record>

    <!-- ========================================================================
         VUE LISTE : Colonnes SAGE X3
         ======================================================================== -->
    
    <record id="view_invoice_tree_sage_x3" model="ir.ui.view">
        <field name="name">account.move.tree.sage.x3</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_invoice_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='status_in_payment']" position="after">
                <field name="sage_x3_sent" 
                       widget="boolean"
                       string="SAGE X3"
                       optional="show"/>
            </xpath>
        </field>
    </record>

    <!-- ========================================================================
         FILTRES
         ======================================================================== -->
    
    <record id="view_account_invoice_filter_sage_x3" model="ir.ui.view">
        <field name="name">account.invoice.filter.sage.x3</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_invoice_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='late']" position="after">
                <separator/>
                <filter name="sage_x3_sent" 
                        string="Envoyé à SAGE X3"
                        domain="[('sage_x3_sent', '=', True)]"/>
                <filter name="sage_x3_not_sent" 
                        string="Non envoyé à SAGE X3"
                        domain="[('sage_x3_sent', '=', False), ('move_type', '=', 'out_invoice'), ('state', '=', 'posted')]"/>
                <filter name="sage_x3_errors" 
                        string="Erreurs SAGE X3"
                        domain="[('sage_x3_error', '!=', False)]"/>
            </xpath>
        </field>
    </record>


    <!-- ========================================================================
         VUE PAIEMENT : Ajout champs et bouton SAGE X3
         ======================================================================== -->
    
    <record id="view_account_payment_form_sage_x3" model="ir.ui.view">
        <field name="name">account.payment.form.sage.x3</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
            
            <!-- Champs SAGE X3 -->
            <xpath expr="//group[@name='main_group']" position="after">
                <group name="sage_x3_info" string="SAGE X3" 
                       invisible="payment_type != 'inbound' or partner_type != 'customer'">
                    <field name="sage_x3_sent" readonly="1"/>
                    <field name="sage_x3_piece_number" readonly="1"/>
                    <field name="sage_x3_sent_date" readonly="1"/>
                    <field name="sage_x3_error" readonly="1" invisible="not sage_x3_error"/>
                </group>
            </xpath>
        </field>
    </record>

    <!-- ========================================================================
         LISTE PAIEMENTS : Colonne SAGE X3
         ======================================================================== -->
    
    <record id="view_account_payment_tree_sage_x3" model="ir.ui.view">
        <field name="name">account.payment.tree.sage.x3</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="after">
                <field name="sage_x3_sent" 
                       widget="boolean"
                       string="SAGE X3"
                       optional="show"/>
            </xpath>
        </field>
    </record>

