<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_stock_scrap_breakers_form" model="ir.ui.view">
            <field name="name">stock.scrap.breakers.form</field>
            <field name="model">stock.scrap.breakers</field>
            <field name="arch" type="xml">
                <form string="Groupe de rebuts">
                    <header>
                        <button name="action_validate_breaker" 
                                string="Valider les casses" 
                                type="object" 
                                class="oe_highlight"
                                invisible="state != 'draft'"/>

                        <button name="action_cancel_breaker" 
                                string="Annuler" 
                                type="object" 
                                class="oe_link"
                                invisible="state != 'draft'"/>

                        <button name="action_set_to_draft" 
                                string="Remettre à brouillon" 
                                type="object" 
                                class="oe_link"
                                invisible="state != 'cancelled'"/>

                        <field name="state" widget="statusbar" 
                               statusbar_visible="draft,done,cancelled" 
                               readonly="1"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="name" class="oe_edit_only"/>
                            <h1>
                                <field name="name" placeholder="Nom" readonly="state != 'draft'"/>
                            </h1>
                        </div>  
                        <group>
                            <group>
                                <label for="start" string="Periode"/>
                                <div>
                                    <field name="start" class="oe_inline" readonly="state != 'draft'"/>
                                    <span> à </span>
                                    <field name="end" class="oe_inline" readonly="state != 'draft'"/>
                                </div>
                            </group>
                        </group>
                        <notebook>
                            <page name="list_scrap" string="Listes de casses">
                                <field name="scrap_ids" readonly="state == 'done'">
                                    <list editable="bottom">
                                        <field name="product_id"/>
                                        <field name="scrap_qty"/>
                                        <field name="scrap_reason_tag_ids" widget="many2many_tags" required="1" options="{'no_create': True, 'no_create_edit': True}"/>
                                        <button name="action_validate"
                                                string="Valider le casse"
                                                type="object"
                                                class="oe_highlight"
                                                invisible="state != 'draft' or parent.state != 'done'"/>
                                    </list>
                                </field>
                                
                            </page>
                        </notebook>                   
                    </sheet>
                    <chatter reload_on_follower="True"/>
                </form>
            </field>
        </record>

        <!-- Vue liste Code Inventaire -->
        <record id="view_stock_scrap_breakers_tree" model="ir.ui.view">
            <field name="name">stock.scrap.breakers.tree</field>
            <field name="model">stock.scrap.breakers</field>
            <field name="arch" type="xml">
                <list string="Groupe de casses">
                    <field name="name"/>
                    <field name="start"/>
                    <field name="end"/>
                </list>
            </field>
        </record>

        <!-- Action Code Inventaire -->
        <record id="action_stock_scrap_breakers" model="ir.actions.act_window">
            <field name="name">Groupe de casses</field>
            <field name="res_model">stock.scrap.breakers</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Créer votre premier Groupe de casses
                </p>
            </field>
        </record>

        <record id="view_stock_scrap_reason_tag_form" model="ir.ui.view">
            <field name="name">stock.scrap.reason.tag</field>
            <field name="model">stock.scrap.reason.tag</field>
            <field name="arch" type="xml">
                <form string="Groupe de rebuts">
                    <sheet>
                        <div class="oe_title">
                            <label for="name" class="oe_edit_only"/>
                            <h1>
                                <field name="name" placeholder="Nom" readonly="name"/>
                            </h1>
                        </div>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_stock_scrap_reason_tag_tree" model="ir.ui.view">
            <field name="name">stock.scrap.reason.tag.tree</field>
            <field name="model">stock.scrap.reason.tag</field>
            <field name="arch" type="xml">
                <list string="Raisons de casses">
                    <field name="name"/>
                </list>
            </field>
        </record>

            <!-- Action Code Inventaire -->
        <record id="action_stock_scrap_reason_tag" model="ir.actions.act_window">
            <field name="name">Raisons de casses</field>
            <field name="res_model">stock.scrap.reason.tag</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Créer votre première raison de casse
                </p>
            </field>
        </record>

        <menuitem id="menu_stock_scrap_breakers"
                  name="Groupe de casses"
                  parent="stock.menu_stock_adjustments"
                  action="action_stock_scrap_breakers"
                  sequence="4"/>

        <menuitem id="menu_stock_scrap_reason_tag"
                  name="Raisons de casses"
                  parent="stock.menu_stock_config_settings"
                  action="action_stock_scrap_reason_tag"
                  sequence="5"/>

    </data>

</odoo>