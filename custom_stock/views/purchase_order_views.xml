<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vue formulaire avec onglet SAGE X3 -->
    <record id="view_purchase_order_form_sage" model="ir.ui.view">
        <field name="name">purchase.order.form.sage.x3</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            
            <!-- Message d'avertissement si non validé -->
            <xpath expr="//sheet" position="before">
                <div class="alert alert-success" 
                     role="alert" 
                     invisible="not sage_x3_validated or type_supplier == 'local'"
                     style="margin: 10px;">
                    <strong>✅ Commande validée par SAGE X3</strong>
                    <p>Cette commande a été acceptée par SAGE X3 et peut être confirmée.</p>
                </div>
                <div class="alert alert-warning" role="alert" 
                     invisible="state not in ['draft', 'sent'] or sage_x3_validated == True or type_supplier == 'local'">
                    <strong>⚠️ Validation SAGE X3 requise</strong><br/>
                    Cette commande doit être soumise et validée par SAGE X3 avant de pouvoir être confirmée.
                    <br/>Utilisez le bouton <strong>"Soumettre à SAGE X3"</strong>.
                </div>
                
                <div class="alert alert-danger" role="alert" 
                     invisible="sage_x3_submitted == False or sage_x3_error == False or type_supplier == 'local'">
                    <strong>❌ Erreur SAGE X3</strong><br/>
                    <field name="sage_x3_error" readonly="1" nolabel="1"/>
                </div>
            </xpath>

            <xpath expr="//button[@name='button_confirm']" position="before">
                <!-- Bouton Soumettre à SAGE X3 -->
                <button name="action_pending_to_sage_x3" 
                        string="Mettre en attente SAGE X3" 
                        type="object"
                        class="oe_highlight"
                        invisible="state not in ['draft'] or sage_x3_validated == True or type_command != 'normal' or type_supplier != 'vridi'"/>

                <button name="button_confirm_local"
                        string="Confirmer"
                        type="object"
                        class="oe_highlight"
                        invisible="not (state in ('draft', 'sent') and type_supplier == 'local')"/>
            </xpath>

            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="type_supplier" 
                       widget="selection"
                       options="{'no_create': True}"
                       readonly="state in ['cancel', 'purchase']"/>

                <field name="type_command" 
                       widget="selection"
                       invisible="type_supplier == 'local'"
                       options="{'no_create': True}"
                       readonly="state in ['cancel', 'purchase']"/>
            </xpath>
            
            <!-- Onglet SAGE X3 -->
            <xpath expr="//notebook" position="inside">
                <page string="SAGE X3" name="sage_x3">
                    <group>
                        <group string="Statut de soumission">
                            <field name="sage_x3_submitted" readonly="1"/>
                            <field name="sage_x3_validated" readonly="1"/>
                            <field name="sage_x3_submitted_date" 
                                   readonly="1"
                                   invisible="sage_x3_submitted == False"/>
                        </group>
                        <group string="Réponse SAGE X3">
                            <field name="sage_x3_response_message" 
                                   readonly="1"
                                   invisible="sage_x3_response_message == False"/>
                        </group>
                    </group>
                    
                    <group string="Livraison SAGE X3">
                        <group>
                            <field name="sage_x3_delivery_received" readonly="1"/>
                            <field name="sage_x3_delivery_date" 
                                   readonly="1"
                                   invisible="sage_x3_delivery_received == False"/>
                        </group>
                    </group>
                </page>
            </xpath>

            <xpath expr="//button[@name='action_rfq_send'][1]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//button[@name='action_rfq_send'][2]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//button[@name='action_rfq_send'][3]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//button[@name='button_confirm'][1]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//button[@name='button_confirm'][2]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            
        </field>
    </record>

    <!-- Vue formulaire avec onglet SAGE X3 -->
    <record id="view_purchase_order_tree_sage" model="ir.ui.view">
        <field name="name">purchase.order.form.sage.x3</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_kpis_tree"/>
        <field name="arch" type="xml">          
            <xpath expr="//field[@name='partner_ref']" position="before">
                <field name="create_date" readonly="1" string="Date"/>
            </xpath>
            <xpath expr="//field[@name='company_id']" position="before">
                <field name="receipt_status" 
                    widget="badge"
                    decoration-success="receipt_status == 'full'" 
                    decoration-warning="receipt_status == 'pending'" 
                    decoration-info="receipt_status == 'partial'" 
                    readonly="1"/>
            </xpath>
        </field>
    </record>
        
</odoo>