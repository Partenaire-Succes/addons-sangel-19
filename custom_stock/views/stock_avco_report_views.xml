<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Vue liste ─────────────────────────────────────────────────────── -->
    <record id="view_stock_avco_report_list" model="ir.ui.view">
        <field name="name">stock.avco.report.list.custom</field>
        <field name="model">stock.avco.report</field>
        <field name="arch" type="xml">
            <list default_order="date desc, id desc" create="false" edit="false" delete="false">
                <field name="reference"      string="Référence"/>
                <field name="product_id"     string="Produit"/>
                <field name="date"           string="Date"/>
                <field name="description"    string="Description"/>
                <field name="quantity"       string="Added Qua."/>
                <field name="added_value"    string="Valeur ajout."/>
                <field name="total_value"    string="Valeur totale"/>
                <field name="total_quantity" string="Total Quantity"/>
                <field name="avco_value"     string="AVCO Value"/>
                <field name="company_id"     column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- ── Vue recherche ─────────────────────────────────────────────────── -->
    <record id="view_stock_avco_report_search" model="ir.ui.view">
        <field name="name">stock.avco.report.search.custom</field>
        <field name="model">stock.avco.report</field>
        <field name="arch" type="xml">
            <search string="AVCO Justification">

                <field name="reference" string="Référence"/>
                <field name="product_id" string="Produit"/>
                <field name="company_id" string="Société"/>

                <separator/>

                <filter name="group_product"
                        string="Regrouper par Produit"
                        context="{'group_by': 'product_id'}"/>
                <filter name="group_company"
                        string="Regrouper par Société"
                        context="{'group_by': 'company_id'}"/>

            </search>
        </field>
    </record>

    <!-- ── Action (menu standalone) ─────────────────────────────────────── -->
    <record id="action_stock_avco_report_standalone" model="ir.actions.act_window">
        <field name="name">AVCO Justification</field>
        <field name="res_model">stock.avco.report</field>
        <field name="view_mode">list</field>
        <field name="domain">[('reference', 'ilike', '/IN/')]</field>
        <field name="search_view_id" ref="view_stock_avco_report_search"/>
        <field name="context">{'cost_method': 'average'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Aucun mouvement trouvé.</p>
        </field>
    </record>

    <!-- ── Action (bouton fiche article, filtré par produit) ─────────────── -->
    <record id="action_stock_avco_report_from_product" model="ir.actions.act_window">
        <field name="name">AVCO Justification</field>
        <field name="res_model">stock.avco.report</field>
        <field name="view_mode">list</field>
        <field name="domain">[('reference', 'ilike', '/IN/'), ('product_id.product_tmpl_id', '=', active_id)]</field>
        <field name="search_view_id" ref="view_stock_avco_report_search"/>
        <field name="context">{'cost_method': 'average'}</field>
    </record>

    <!-- ── Bouton sur la fiche article (product.template) ────────────────── -->
    <record id="product_template_avco_button" model="ir.ui.view">
        <field name="name">product.template.avco.button</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="stock.product_template_form_view_procurement_button"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="%(custom_stock.action_stock_avco_report_from_product)d"
                        type="action"
                        class="oe_stat_button"
                        icon="fa-bar-chart"
                        groups="custom_pos.group_dsi_it">
                    <div class="o_stat_info">
                        <span class="o_stat_text">AVCO</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>

    <!-- ── Menu : Inventaire → Analyse et Rapports → Stock et Inventaire ── -->
    <menuitem
        id="menu_stock_avco_report_standalone"
        name="AVCO Justification"
        parent="custom_reports.menu_reports_stock"
        action="action_stock_avco_report_standalone"
        groups="custom_pos.group_dsi_it"
        sequence="50"/>

</odoo>
