<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_loyalty_card_form_inherit" model="ir.ui.view">
            <field name="name">loyalty.card.form.inherit.code</field>
            <field name="model">loyalty.card</field>
            <field name="inherit_id" ref="loyalty.loyalty_card_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='code']" position="attributes">
                    <attribute name="readonly">0</attribute>
                </xpath>
                <xpath expr="//label[@for='points_display']" position="after">
                    <field name="points_display" nolabel="1"/>
                </xpath>

                <xpath expr="//button[@name='action_loyalty_update_balance']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>

                <xpath expr="//sheet" position="before">
                    <header>
                        <button name="update_code_from_partner"
                                type="object"
                                string="Mettre les partenaire"
                                icon="fa-sync"
                                class="btn-primary"/>
                    </header>
                </xpath>
            </field>
        </record>

        <record id="action_update_code_from_partner" model="ir.actions.server">
            <field name="name">Mettre les partenaire sur les cartes</field>
            <field name="model_id" ref="model_loyalty_card"/>
            <field name="binding_model_id" ref="model_loyalty_card"/>
            <field name="binding_view_types">list</field>
            <field name="state">code</field>
            <field name="code">
        action = records.update_code_from_partner()
            </field>
        </record>
    </data>
</odoo>


