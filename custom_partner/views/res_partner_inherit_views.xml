<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ce code permet de modifier le libellé etiquette en catgorie client-->
        <record id="res_partner_inherit_form_view" model="ir.ui.view">
            <field name="name">res.partner.inherit.form</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <xpath expr="//sheet" position="before">
                    <button string="Suppression des doublons" invisible="1"
                        name="remove_duplicate_partners" type="object" class="oe_highlight"/>
                    <button string="Sync. codes-barres (clients 10...)"
                        name="action_sync_barcode_from_customer_id" type="object"
                        class="btn-secondary"
                        invisible="1"
                        confirm="Assigner barcode = ID client pour tous les partenaires dont l'ID commence par 10 et dont le code-barres est vide. Continuer ?"/>
                    <button string="Sync. codes-barres (clients 10 - 20)"
                        name="action_fill_missing_company_barcodes" type="object"
                        class="btn-secondary"
                        invisible="0"
                        confirm="Assigner barcode = ID client pour tous les partenaires dont l'ID commence par 10 et 20 et dont le code-barres est vide. Continuer ?"/>
                </xpath>
                <xpath expr="//field[@name='category_id']" position="attributes">
                    <attribute name="string">Catégorie client</attribute>
                    <attribute name="options">{'no_create': True, 'no_create_edit': True}</attribute>
                </xpath>

                <xpath expr="//field[@name='parent_id']" position="attributes">
                    <attribute name="options">{'no_create': True, 'no_create_edit': True}</attribute>
                </xpath>

                <xpath expr="//field[@name='vat']" position="after">
                    <field name="customer_id" readonly="customer_id"/>
                    <field name="customer_account" readonly="1"/>
                    <field name="type_location" readonly="0"/>
                    <field name="code_family" readonly="1"/>
                </xpath>

                <xpath expr="//page[@name='sales_purchases']/group[1]/group[1]/field[@name='user_id']"
                       position="after">
                    <field name="primary_responsible_id" readonly="1"/>
                    <field name="secondary_responsible_id" readonly="1"/>
                </xpath>

                <xpath expr="//page[@name='sales_purchases']" position="after">
                    <page name="discount" string="Remises &amp; Taxes">
                        <group>
                            <group name="customer_discount" string="Remises">
                                <field name="discount_eligible"/>
                                <field name="discount_percentage"
                                       invisible="discount_eligible == False"
                                       widget="percentage"
                                       class="oe_inline"
                                       options="{'factor': 1.0}"
                                />
                                <label for="discount_start_date" string="Période"
                                       invisible="discount_eligible == False"/>
                                <div invisible="discount_eligible == False">
                                    <field name="discount_start_date" class="oe_inline"/>
                                    -
                                    <field name="discount_end_date" class="oe_inline"/>
                                </div>
                            </group>
                            <group name="taxes" string="Taxes">
                                <field name="is_airsi_eligible" readonly="0"/>
                            </group>
                        </group>
                    </page>
                </xpath>

                <xpath expr="//notebook" position="inside">
                    <page string="Cartes de fidélité">
                        <group>
                            <field name="no_loyalty_points"
                                   widget="boolean_toggle"
                                   string="Exclure des points de fidélité"/>
                            <field name="no_promotion"
                                   widget="boolean_toggle"
                                   string="Exclure des promotions"/>
                        </group>
                        <field name="loyalty_card_ids" readonly="1">
                            <list>
                                <field name="code"/>
                                <field name="points"/>
                                <field name="expiration_date"/>
                                <field name="program_id"/>
                            </list>
                        </field>
                    </page>
                </xpath>
            </field>
        </record>

        <record id="res_partner_inherit_tree_view" model="ir.ui.view">
            <field name="name">res.partner.inherit.tree</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='complete_name']" position="before">
                    <field name="customer_id"/>
                </xpath>
            </field>
        </record>

        <record id="view_partner_simple_form_inherit" model="ir.ui.view">
            <field name="name">res.partner.simplified.form.inherit</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_simple_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='parent_id']" position="attributes">
                    <attribute name="options">{'no_create': True, 'no_create_edit': True}</attribute>
                </xpath>
            </field>
        </record>

        <record id="view_partner_filter_inherit" model="ir.ui.view">
            <field name="name">res.partner.search.customer_id</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_res_partner_filter"/>
            <field name="arch" type="xml">
                <xpath expr="//search" position="inside">
                    <field name="customer_id" string="ID Client"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>