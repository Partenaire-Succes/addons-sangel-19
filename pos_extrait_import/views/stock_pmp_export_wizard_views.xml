<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_stock_pmp_export_wizard_form" model="ir.ui.view">
        <field name="name">stock.pmp.export.wizard.form</field>
        <field name="model">stock.pmp.export.wizard</field>
        <field name="arch" type="xml">
            <form string="Export PMP par Article">
                <group>
                    <field name="company_id"/>
                </group>
                <footer>
                    <button name="action_export_excel"
                            string="Exporter Excel"
                            type="object"
                            class="btn-primary"/>
                    <button string="Annuler" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_stock_pmp_export_wizard" model="ir.actions.act_window">
        <field name="name">Export PMP Articles</field>
        <field name="res_model">stock.pmp.export.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem
        id="menu_stock_pmp_export"
        name="Export PMP Articles"
        parent="point_of_sale.menu_point_of_sale"
        action="action_stock_pmp_export_wizard"
        sequence="101"/>

</odoo>
