<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_stock_avco_correction_wizard_form" model="ir.ui.view">
        <field name="name">stock.avco.correction.wizard.form</field>
        <field name="model">stock.avco.correction.wizard</field>
        <field name="arch" type="xml">
            <form string="Correction AVCO - Réceptions à Valeur Zéro">
                <header>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,preview,done"/>
                </header>
                <sheet>

                    <!-- ── ÉTAPE 1 : Import ───────────────────────────────── -->
                    <group invisible="state != 'draft'">
                        <field name="company_id"/>
                        <field name="import_file" widget="binary"
                               filename="import_filename"/>
                        <field name="import_filename" invisible="1"/>
                    </group>

                    <!-- ── ÉTAPE 2 : Aperçu ───────────────────────────────── -->
                    <group invisible="state != 'preview'">
                        <group string="Résumé de l'analyse">
                            <field name="count_ok"      string="✅ Lignes OK"/>
                            <field name="count_warning" string="⚠️  Avertissements"/>
                            <field name="count_error"   string="❌ Erreurs"/>
                            <field name="total_value"   string="💰 Valeur à injecter"/>
                        </group>
                    </group>

                    <field name="line_ids" invisible="state != 'preview'" readonly="1">
                        <list decoration-success="line_state == 'ok'"
                              decoration-warning="line_state == 'warning'"
                              decoration-danger="line_state == 'error'">
                            <field name="default_code"    string="Code"/>
                            <field name="product_name"    string="Article"/>
                            <field name="correct_price"   string="Prix correct"
                                   digits="[16,4]"/>
                            <field name="qty_zero_svl"    string="Qté à 0"
                                   digits="[16,3]"/>
                            <field name="value_to_inject" string="Valeur à injecter"
                                   digits="[16,2]"/>
                            <field name="current_avco"    string="AVCO actuel"
                                   digits="[16,4]"/>
                            <field name="current_qty"     string="Stock actuel"
                                   digits="[16,3]"/>
                            <field name="new_avco"        string="AVCO corrigé"
                                   digits="[16,4]"/>
                            <field name="line_state"      string="Statut"/>
                            <field name="message"         string="Message"/>
                        </list>
                    </field>

                    <!-- ── ÉTAPE 3 : Résultat ─────────────────────────────── -->
                    <field name="result_log" invisible="state != 'done'"
                           widget="html"/>

                </sheet>
                <footer>
                    <button name="action_preview"
                            string="Analyser le fichier"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>

                    <button name="action_validate"
                            string="Corriger l'AVCO"
                            type="object" class="btn-primary"
                            invisible="state != 'preview' or not can_validate"
                            confirm="Cette action va modifier l'AVCO et créer des écritures comptables. Continuer ?"/>

                    <button name="action_back_to_draft"
                            string="Retour"
                            type="object" class="btn-secondary"
                            invisible="state != 'preview'"/>

                    <button string="Fermer" class="btn-secondary" special="cancel"
                            invisible="state == 'preview'"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_stock_avco_correction_wizard" model="ir.actions.act_window">
        <field name="name">Correction AVCO</field>
        <field name="res_model">stock.avco.correction.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem
        id="menu_stock_avco_correction"
        name="Correction AVCO TEST"
        parent="point_of_sale.menu_point_of_sale"
        action="action_stock_avco_correction_wizard"
        sequence="102"/>

</odoo>
