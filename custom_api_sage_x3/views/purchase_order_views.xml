<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vue formulaire avec onglet SAGE X3 -->
    <record id="view_purchase_order_form_sage_x3" model="ir.ui.view">
        <field name="name">purchase.order.form.sage.x3</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <!-- Boutons dans le header -->
            <xpath expr="//button[@name='button_confirm']" position="before">
                <!-- Bouton Soumettre à SAGE X3 -->
                <button name="action_submit_urgent_command" 
                        string="Confirmer Commande" 
                        type="object"
                        class="oe_highlight"
                        invisible="state not in ['draft', 'sent'] or sage_x3_validated == True or type_command != 'urgent' or type_supplier != 'vridi'"/>
            </xpath>
        </field>
    </record>
    
        
</odoo>