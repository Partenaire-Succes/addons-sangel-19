<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vue formulaire avec onglet SAGE X3 -->
    <record id="view_purchase_order_form_sage_x3" model="ir.ui.view">
        <field name="name">purchase.order.form.sage.x3</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//button[@name='action_rfq_send'][1]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//button[@name='action_rfq_send'][2]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//button[@name='action_rfq_send'][3]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//button[@name='button_confirm'][1]" position="attributes">
                <attribute name="invisible">type_supplier == 'vridi' or state not in ['draft', 'sent']</attribute>
            </xpath>
            <xpath expr="//button[@name='button_confirm'][2]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            
            
            <!-- Boutons dans le header -->
            <xpath expr="//button[@name='button_confirm']" position="before">
                <!-- Bouton Soumettre à SAGE X3 -->
                <button name="action_submit_urgent_command" 
                        string="Commande urgente" 
                        type="object"
                        class="oe_highlight"
                        invisible="state not in ['draft', 'sent'] or sage_x3_validated == True or type_command != 'urgent' or type_supplier != 'vridi'"/>

                <button name="action_submit_to_sage_x3" 
                        string="Soumettre à SAGE X3" 
                        type="object" 
                        class="oe_highlight"
                        invisible="1"/>

                <button name="action_import_deliveries" 
                        string="Importer livraisons" 
                        type="object" 
                        class="oe_highlight"/>
            </xpath>
        </field>
    </record>
    
    <!-- Action serveur pour importer les livraisons -->
    <record id="action_import_sage_x3_deliveries" model="ir.actions.server">
        <field name="name">Importer livraisons SAGE X3</field>
        <field name="model_id" ref="purchase.model_purchase_order"/>
        <field name="binding_model_id" ref="purchase.model_purchase_order"/>
        <field name="state">code</field>
        <field name="code">
action = model.action_import_deliveries()
        </field>
    </record>
    
    <!-- Menu pour les actions SAGE X3 -->
    <menuitem 
        id="menu_purchase_sage_x3"
        name="SAGE X3"
        parent="purchase.menu_purchase_root"
        sequence="100"/>
    
    <menuitem 
        id="menu_import_deliveries_sage_x3"
        name="Importer livraisons"
        parent="menu_purchase_sage_x3"
        action="action_import_sage_x3_deliveries"
        sequence="10"/>
        
</odoo>