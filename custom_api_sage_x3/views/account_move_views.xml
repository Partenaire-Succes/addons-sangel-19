<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========================================================================
         VUE FORMULAIRE FACTURE : Ajout champs et bouton SAGE X3
         ======================================================================== -->
    
    <record id="view_move_form_sage_x3" model="ir.ui.view">
        <field name="name">account.move.form.sage.x3</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            
            <!-- Bouton dans le header -->
            <xpath expr="//header/button[@name='action_post']" position="after">
                <button name="action_send_all_pending_to_sage_x3"
                        type="object"
                        string="Envoyer à SAGE X3"
                        class="btn-primary"
                        invisible="move_type != 'out_invoice' or state != 'posted' or sage_x3_sent"
                        groups="account.group_account_manager"
                        help="Envoie la facture à SAGE X3"/>

                <button name="action_send_all_classic_invoices_to_sage_x3"
                        type="object"
                        string="Envoyer autre factures à SAGE X3"
                        class="btn-primary"
                        help="Envoie les factures non envoyées à SAGE X3"/>
            </xpath>
            
        </field>
    </record>

    <record id="view_account_payment_btn_form_sage_x3" model="ir.ui.view">
        <field name="name">account.payment.form.sage.x3</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
            
            <!-- Champs SAGE X3 -->
            <xpath expr="//header/button[@name='action_draft']" position="after">
                <button name="action_send_all_pending_payments_to_sage_x3"
                        type="object"
                        string="Envoyer à SAGE X3"
                        class="btn-primary"
                        invisible="payment_type != 'inbound' or partner_type != 'customer' or sage_x3_sent"
                        groups="account.group_account_manager"
                        help="Envoie le paiement à SAGE X3"/>
            </xpath>
        </field>
    </record>

</odoo>