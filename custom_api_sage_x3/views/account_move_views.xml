<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========================================================================
         VUE FORMULAIRE FACTURE : Ajout champs et bouton SAGE X3
         ======================================================================== -->
    
    <record id="view_move_form_sage_x3" model="ir.ui.view">
        <field name="name">account.move.form.sage.x3</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            
            <!-- Bouton dans le header -->
            <xpath expr="//header/button[@name='action_post']" position="after">
                <button name="action_send_all_pending_to_sage_x3"
                        type="object"
                        string="Envoyer à SAGE X3"
                        class="btn-primary"
                        invisible="move_type != 'out_invoice' or state != 'posted' or sage_x3_sent"
                        groups="account.group_account_manager"
                        help="Envoie la facture à SAGE X3"/>

                <button name="action_send_all_classic_invoices_to_sage_x3"
                        type="object"
                        string="Envoyer autre factures à SAGE X3"
                        class="btn-primary"
                        help="Envoie les factures non envoyées à SAGE X3"/>
            </xpath>
            
            <!-- Onglet SAGE X3 -->
            <xpath expr="//notebook" position="inside">
                <page name="sage_x3" string="SAGE X3" invisible="move_type != 'out_invoice'">
                    <group>
                        <group string="Statut SAGE X3">
                            <field name="sage_x3_sent" readonly="1"/>
                            <field name="sage_x3_piece_type" readonly="1"/>
                            <field name="sage_x3_piece_number" readonly="1"/>
                            <field name="sage_x3_sent_date" readonly="1"/>
                        </group>
                        <group string="Détails">
                            <field name="sage_x3_response" 
                                   readonly="1" 
                                   invisible="not sage_x3_response"
                                   widget="text"/>
                            <field name="sage_x3_error" 
                                   readonly="1" 
                                   invisible="not sage_x3_error"
                                   widget="text"/>
                        </group>
                    </group>
                    
                    <!-- Indicateurs -->
                    <group>
                        <div class="alert alert-success" 
                             invisible="not sage_x3_sent"
                             style="margin: 10px;">
                            <strong>✅ Facture envoyée à SAGE X3</strong>
                            <p>N° Pièce: <field name="sage_x3_piece_number" readonly="1" nolabel="1"/></p>
                        </div>
                        
                        <div class="alert alert-danger" 
                             invisible="not sage_x3_error"
                             style="margin: 10px;">
                            <strong>❌ Erreur SAGE X3</strong>
                            <p><field name="sage_x3_error" readonly="1" nolabel="1"/></p>
                        </div>
                    </group>
                </page>
            </xpath>
            
        </field>
    </record>

