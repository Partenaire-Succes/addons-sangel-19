<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="product_template_form_view_api" model="ir.ui.view">
            <field name="name">product.template.form.composite</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_form_view"/>
            <field name="arch" type="xml">

                <xpath expr="//div[@name='button_box']" position="inside">
                    <button name="import_products" 
                            string="Importer Produits SAGE X3" 
                            type="object" 
                            icon="fa-history" 
                            class="btn btn-primary"/>

                    <button name="action_delete_products_no_company" 
                            string="Suppresion" 
                            type="object" 
                            icon="fa-upload" 
                            class="btn btn-secondary"/>
                </xpath>

            </field>
        </record>
    </data>
</odoo>