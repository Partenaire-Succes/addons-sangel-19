<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="product_template_form_view_api" model="ir.ui.view">
            <field name="name">product.template.form.composite</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_form_view"/>
            <field name="arch" type="xml">

                <xpath expr="//div[@name='button_box']" position="inside">

                    <button name="action_delete_products_no_company" 
                            string="Suppresion" 
                            type="object" 
                            icon="fa-upload" 
                            invisible="1"
                            class="btn btn-secondary"/>

                    <button name="normalize_taxes_tva_all_companies" 
                            string="Normaliser TVA" 
                            type="object" 
                            invisible="1"
                            class="btn btn-secondary"/>

                    <button name="normalize_taxes_airsi_all_companies" 
                            string="Normaliser AIRSI" 
                            type="object" 
                            invisible="1"
                            class="btn btn-secondary"/>

                    <button name="reset_airsi_taxes_all_products"
                            string="Supprimer AIRSI"
                            type="object"
                            invisible="1"
                            class="btn btn-secondary"/>

                    <button name="fix_all_gs1_barcodes_direct"
                            string="Corriger barcodes GS1"
                            type="object"
                            icon="fa-barcode"
                            confirm="Cette action va corriger tous les code-barres GS1 (27...) sur tous les produits actifs. Continuer ?"
                            class="btn btn-warning"
                            groups="base.group_system"/>
                </xpath>

            </field>
        </record>
    </data>
</odoo>