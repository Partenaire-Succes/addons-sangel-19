<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Form View ── -->
    <record id="view_x3_config_form" model="ir.ui.view">
        <field name="name">x3.config.form</field>
        <field name="model">x3.config</field>
        <field name="arch" type="xml">
            <form string="Configuration Sage X3">
                <header>
                    <button name="action_test_connection"
                            string="🔌 Tester la connexion"
                            type="object"
                            class="btn-primary"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,ok,error"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_logs"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-list">
                            <field name="log_count" widget="statinfo" string="Logs"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <h1><field name="name" placeholder="Ex: Client ABC - Production"/></h1>
                    </div>

                    <group>
                        <group string="🖥 Serveur X3">
                            <field name="server_url" placeholder="https://192.168.1.10"/>
                            <field name="port"/>
                            <field name="dossier" placeholder="SEED"/>
                            <field name="pool"/>
                            <field name="verify_ssl"/>
                        </group>
                        <group string="🔑 Authentification">
                            <field name="username"/>
                            <field name="password" password="True"/>
                            <field name="x3_version"/>
                            <field name="db_type"/>
                        </group>
                    </group>

                    <group string="ℹ️ Informations de connexion" attrs="{'invisible': [('state', '=', 'draft')]}">
                        <field name="last_test_date" readonly="1"/>
                        <field name="last_error" readonly="1"
                               attrs="{'invisible': [('state', '!=', 'error')]}"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Tree View ── -->
    <record id="view_x3_config_tree" model="ir.ui.view">
        <field name="name">x3.config.tree</field>
        <field name="model">x3.config</field>
        <field name="arch" type="xml">
            <tree string="Configurations X3" decoration-success="state=='ok'"
                  decoration-danger="state=='error'">
                <field name="name"/>
                <field name="server_url"/>
                <field name="dossier"/>
                <field name="x3_version"/>
                <field name="state"/>
                <field name="last_test_date"/>
            </tree>
        </field>
    </record>

    <!-- ── Action ── -->
    <record id="action_x3_config" model="ir.actions.act_window">
        <field name="name">Configurations X3</field>
        <field name="res_model">x3.config</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
