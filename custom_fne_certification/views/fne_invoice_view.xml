<odoo>
    <record id="view_move_form_fne" model="ir.ui.view">
        <field name="name">account.move.form.fne</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form" />
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <div class="oe_stat_button btn btn-secondary" invisible="not fne_certified">
                    <field name="fne_sticker_balance" widget="statinfo" string="Solde Sticker"/>
                    <span class="fa fa-ticket" style="margin-right: 4px;"/>
                </div>
            </xpath>
            <xpath expr="//button[@name='preview_invoice']" position="after">
                <button name="action_open_fne_wizard" 
                        type="object"
                        string="Validation FNE" class="btn btn-primary"
                        icon="fa-edit"
                        invisible="not (state == 'posted' and not fne_certified)"/>
                <button name="action_open_fne_link" 
                        type="object" string="Voir sur FNE"
                        class="btn-success" 
                        invisible="not (state == 'posted' and fne_certified)"/>

            </xpath>
            <xpath expr="//field[@name='ref']" position="after">
                <field name="fne_certified" invisible="1"/>
                <field name="fne_reference" invisible="0"/>
                <field name="fne_token" invisible="1"/>
                <field name="fne_response_json" invisible="0"/>
            </xpath>
            <xpath expr="//notebook/page[@name='invoice_tab']/field[@name='invoice_line_ids']/list/field[@name='product_id']" position="before">
                <field name="fne_original_line_id" />
            </xpath>
        </field>
    </record>
    
</odoo>