<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Format papier paysage A4 -->
    <record id="paperformat_cfao_landscape" model="report.paperformat">
        <field name="name">CFAO Landscape A4</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Landscape</field>
        <field name="margin_top">10</field>
        <field name="margin_bottom">8</field>
        <field name="margin_left">5</field>
        <field name="margin_right">5</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">5</field>
        <field name="dpi">96</field>
    </record>

    <!-- Action rapport -->
    <record id="action_report_cfao_dashboard" model="ir.actions.report">
        <field name="name">Tableau de Bord Quotidien CFAO</field>
        <field name="model">cfao.dashboard.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">cfao_dashboard_report.cfao_dashboard_main</field>
        <field name="report_file">cfao_dashboard_report.cfao_dashboard_main</field>
        <field name="paperformat_id" ref="paperformat_cfao_landscape"/>
        <field name="print_report_name">'Tableau_Bord_CFAO_' + (object.analysis_date and object.analysis_date.strftime('%Y%m%d') or '')</field>
    </record>

</odoo>
