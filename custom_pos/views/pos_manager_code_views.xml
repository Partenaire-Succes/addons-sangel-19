<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ═══════════════ pos.manager.code ═══════════════════════════════ -->

        <record id="pos_manager_code_view_list" model="ir.ui.view">
            <field name="name">pos.manager.code.list</field>
            <field name="model">pos.manager.code</field>
            <field name="arch" type="xml">
                <list string="Badges managers" decoration-muted="not active">
                    <field name="user_id"/>
                    <field name="name"/>
                    <field name="config_id" string="Caisse de référence"/>
                    <field name="active" optional="show"/>
                </list>
            </field>
        </record>

        <record id="pos_manager_code_view_form" model="ir.ui.view">
            <field name="name">pos.manager.code.form</field>
            <field name="model">pos.manager.code</field>
            <field name="arch" type="xml">
                <form string="Badge manager POS">
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_print_badge"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-id-card"
                                    string="Imprimer le badge"/>
                        </div>
                        <div class="oe_title">
                            <label for="user_id" string="Manager"/>
                            <h1><field name="user_id" placeholder="Sélectionner un utilisateur Odoo"/></h1>
                        </div>
                        <group>
                            <group string="Configuration">
                                <field name="config_id"
                                       help="Sélectionner une caisse dont le code d'accès sera utilisé pour ce badge. Assurez-vous que toutes vos caisses ont le même code."/>
                                <field name="active"/>
                            </group>
                        </group>
                        <group string="Aperçu code-barres du badge">
                            <field name="barcode_html" widget="html" readonly="1" nolabel="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="pos_manager_code_view_search" model="ir.ui.view">
            <field name="name">pos.manager.code.search</field>
            <field name="model">pos.manager.code</field>
            <field name="arch" type="xml">
                <search string="Rechercher un badge manager">
                    <field name="user_id" string="Manager"/>
                    <field name="config_id" string="Caisse"/>
                    <filter name="active" string="Actifs" domain="[('active','=',True)]"/>
                    <filter name="archived" string="Archivés" domain="[('active','=',False)]"/>
                    <group>
                        <filter name="group_config" string="Caisse"
                                context="{'group_by':'config_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_pos_manager_code" model="ir.actions.act_window">
            <field name="name">Badges Managers POS</field>
            <field name="res_model">pos.manager.code</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'active_test': False}</field>
            <field name="search_view_id" ref="pos_manager_code_view_search"/>
        </record>

        <menuitem
            id="menu_pos_manager_code"
            name="Badges Managers"
            parent="point_of_sale.menu_point_config_product"
            action="action_pos_manager_code"
            sequence="50"
            groups="custom_pos.group_responsable_magasin"/>

        <!-- ═══════════════ pos.access.log ══════════════════════════════════ -->

        <record id="pos_access_log_view_list" model="ir.ui.view">
            <field name="name">pos.access.log.list</field>
            <field name="model">pos.access.log</field>
            <field name="arch" type="xml">
                <list string="Journal des validations" create="0" delete="0"
                      default_order="datetime desc">
                    <field name="datetime"/>
                    <field name="company_id" optional="show"/>
                    <field name="config_id" string="Caisse"/>
                    <field name="cashier_name" string="Caissière"/>
                    <field name="manager_name" string="Validé par"/>
                    <field name="action" widget="badge"
                           decoration-danger="action == 'refund'"
                           decoration-warning="action in ('discount','price_reduction','stock')"
                           decoration-info="action in ('print','details','invoice')"/>
                    <field name="order_ref"/>
                    <field name="offline" optional="show"/>
                </list>
            </field>
        </record>

        <record id="pos_access_log_view_search" model="ir.ui.view">
            <field name="name">pos.access.log.search</field>
            <field name="model">pos.access.log</field>
            <field name="arch" type="xml">
                <search string="Rechercher dans le journal">
                    <field name="cashier_name" string="Caissière"/>
                    <field name="manager_name" string="Manager"/>
                    <field name="order_ref" string="Commande"/>
                    <field name="config_id" string="Caisse"/>
                    <filter name="filter_today" string="Aujourd'hui"
                            domain="[('datetime','&gt;=', (context_today()).strftime('%Y-%m-%d'))]"/>
                    <filter name="filter_offline" string="Hors-ligne"
                            domain="[('offline','=',True)]"/>
                    <group>
                        <filter name="group_company" string="Société"
                                context="{'group_by':'company_id'}"/>
                        <filter name="group_caisse" string="Caisse"
                                context="{'group_by':'config_id'}"/>
                        <filter name="group_action" string="Action"
                                context="{'group_by':'action'}"/>
                        <filter name="group_manager" string="Manager"
                                context="{'group_by':'manager_name'}"/>
                        <filter name="group_cashier" string="Caissière"
                                context="{'group_by':'cashier_name'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_pos_access_log" model="ir.actions.act_window">
            <field name="name">Journal des validations POS</field>
            <field name="res_model">pos.access.log</field>
            <field name="view_mode">list</field>
            <field name="search_view_id" ref="pos_access_log_view_search"/>
        </record>

        <menuitem
            id="menu_pos_access_log"
            name="Journal des validations"
            parent="point_of_sale.menu_point_of_sale"
            action="action_pos_access_log"
            sequence="98"
            groups="custom_pos.group_superviseur"/>

    </data>
</odoo>
