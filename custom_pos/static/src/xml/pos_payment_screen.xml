<?xml version="1.0" encoding="UTF-8"?>

<templates xml:space="preserve">

    <t t-name="custom_pos.PaymentScreenDue"
       t-inherit="point_of_sale.PaymentScreenDue"
       t-inherit-mode="extension">

        <xpath expr="//section[hasclass('paymentlines-container')]" position="after">
            <t t-set="order" t-value="pos.getOrder()"/>
            <t t-if="order and order.getPartner()">
                <t t-set="loyaltyTotal"
                   t-value="order.getLoyaltyBalanceTotal()"/>
                <t t-if="loyaltyTotal > 0">
                    <section class="paymentlines-container bg-view rounded-3 mt-2">
                        <div class="text-center py-2 py-lg-4">
                            <div class="fw-bold">
                                Solde: Points fidélité
                            </div>
                            <div class="text-warning fw-bold fs-3">
                                <t t-esc="loyaltyTotal"/>
                            </div>
                        </div>
                    </section>

                </t>
            </t>

        </xpath>
    </t>



    <!-- FeedbackScreen : monnaie en grand, montant payé en petit -->
    <t t-name="custom_pos.FeedbackScreen"
       t-inherit="point_of_sale.FeedbackScreen"
       t-inherit-mode="extension">

        <xpath expr="//div[hasclass('amount-paid')]" position="replace">
            <t t-if="this.currentOrder.amount_return > 0">
                <div class="amount-paid fw-bolder">MONNAIE À RENDRE</div>
            </t>
            <t t-else="">
                <div class="amount-paid fw-bolder">Montant payé</div>
            </t>
        </xpath>

        <xpath expr="//div[hasclass('amount') and hasclass('lh-sm')]" position="replace">
            <t t-if="this.currentOrder.amount_return > 0">
                <div t-ref="amount" class="amount lh-sm text-dark fw-bold">
                    <PriceFormatter price="this.env.utils.formatCurrency(this.currentOrder.amount_return, false)"/>
                </div>
                <div class="text-center text-secondary mt-3 fw-semibold" style="font-size: 26px;">
                    Payé : <t t-esc="this.env.utils.formatCurrency(this.currentOrder.amount_paid, false)"/>
                </div>
            </t>
            <t t-else="">
                <div t-ref="amount" class="amount lh-sm">
                    <PriceFormatter price="this.env.utils.formatCurrency(this.currentOrder.amount_total, false)"/>
                </div>
            </t>
        </xpath>

    </t>


    <!-- Insert Preset Remise Buttons into Actionpad (Product Screen) -->
    <t t-inherit="point_of_sale.ActionpadWidget" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('d-flex gap-2')]" position="before">
            <div t-if="this.getPresetRemiseList and this.getPresetRemiseList().length > 0"
                 class="d-flex flex-row flex-wrap gap-1 w-100 mt-2 mb-2 preset-remise-buttons-container">
                <t t-foreach="this.getPresetRemiseList()" t-as="percentage" t-key="percentage">
                    <button class="button preset-remise-button btn btn-info btn-lg flex-grow-1 text-wrap lh-lg"
                            t-on-click="() => this.applyPresetRemise(percentage)"
                            t-attf-title="Apply {{ percentage }}% remise to selected product">
                        <i class="fa fa-percent me-1" role="img" />
                        <span t-esc="percentage"/>
                    </button>
                </t>
            </div>
        </xpath>
    </t>

</templates>
