<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-inherit="point_of_sale.LoginScreen" t-inherit-mode="extension">

        <xpath expr="//button[contains(@class,'select-logout')]" position="after">
            <button class="btn btn-outline-danger btn-lg ms-2 d-flex align-items-center gap-2" t-on-click="confirmLogout">
                <i class="fa fa-sign-out-alt"/>
                <span>Déconnexion</span>
            </button>
        </xpath>

    </t>

</templates>
