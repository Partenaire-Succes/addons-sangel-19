<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="point_of_sale.ReceiptHeader"
       t-inherit="point_of_sale.ReceiptHeader"
       t-inherit-mode="extension">

        <!-- Traduire "Served by:" → "Servi par :" -->
        <xpath expr="//div[hasclass('cashier')]" position="replace">
            <div t-if="order?.getCashierName() and (!order.preset_id or order.preset_id.identification === 'name')"
                 class="cashier">
                <div>Servi par : <t t-esc="order.getCashierName()" /></div>
            </div>
        </xpath>

        <!-- Nom de la caisse visible (taille gérée par receipt_custom.css via .pos-receipt-contact) -->
        <xpath expr="//div[hasclass('pos-receipt-contact')]" position="inside">
            <div t-if="order.config.name">
                <t t-esc="order.config.name"/>
            </div>
        </xpath>

    </t>
</templates>
