                    <td class="num highlight"><t t-esc="'{:,.0f}'.format(enc.get('mise_en_compte',0)).replace(',', ' ')"/></td>
                    <td class="num"></td><td class="num highlight">0</td>
                    <td class="num"></td><td class="num"></td>
                </tr>
                <tr class="row-grand-total">
                    <td colspan="2">Total général</td>
                    <td class="num"><t t-esc="'{:,.0f}'.format(tgen.get('total_enc',0)).replace(',', ' ')"/></td>
                    <td class="num">0</td><td class="num">0</td>
                    <td class="num"></td>
                    <td class="num"><t t-esc="'{:,.0f}'.format(tgen.get('total_dec',0)).replace(',', ' ')"/></td>
                    <td class="num">0</td>
                    <td class="num"></td><td class="num"></td>
                </tr>
            </tbody>
        </table>

        <table style="width:35%;">
            <tr class="row-bold">
                <td>Total des chèques à échoir</td>
                <td class="num" style="width:35%;">0</td>
            </tr>
        </table>

        <!-- ============================================================ -->
        <!-- PAGE 2                                                        -->
        <!-- ============================================================ -->
        <div class="rc-page2"/>

        <!-- En-tête page 2 -->
        <div class="rc-mini-header">
            <table>
                <tr>
                    <td style="width:60%;">
                        <strong><t t-esc="h.get('company_name', '')"/></strong> —
                        Poste(s) : <t t-esc="h.get('postes', '')"/>
                        <t t-if="h.get('lieu')"> | Lieu : <t t-esc="h.get('lieu', '')"/></t>
                         | Caissier(s) : <t t-esc="h.get('caissiers', '')"/> |
                        Chiffres du <t t-esc="h.get('date_from').strftime('%d/%m/%Y') if h.get('date_from') else ''"/>
                        au <t t-esc="h.get('date_to').strftime('%d/%m/%Y') if h.get('date_to') else ''"/>
                    </td>
                    <td style="width:40%; text-align:right;">
                        <strong>RÉCAPITULATIF DES CAISSES</strong> —
                        Édité le <t t-esc="h.get('print_date', '')"/>
                    </td>
                </tr>
            </table>
        </div>

        <!-- ============================================================ -->
        <!-- SECTION 3 : Remises fidélités                                 -->
        <!-- ============================================================ -->
        <div class="section-title">Remises fidélités</div>

        <table style="width:90%;">
            <thead>
                <tr>
                    <th class="th-group" style="width:20%; text-align:left;"></th>
                    <th class="th-group" style="width:10%;">Nombre total</th>
                    <th class="th-group" style="width:14%;">Montant total</th>
                    <th class="th-group" style="width:10%; background:#c0392b;">Nb réduction</th>
                    <th class="th-group" style="width:16%; background:#c0392b;">Montant déduit</th>
                    <th class="th-group" style="width:10%; background:#27ae60;">Nb ajout</th>
                    <th class="th-group" style="width:16%; background:#27ae60;">Montant ajout</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td class="row-bold">Porte-monnaie</td>
                    <td class="num"><t t-esc="remises.get('porte_monnaie_count', 0)"/></td>
                    <td class="num"><t t-esc="'{:,.0f}'.format(remises.get('porte_monnaie_total', 0)).replace(',', ' ')"/></td>
                    <td class="num" style="background:#fdecea;"><t t-esc="remises.get('nb_reduction', 0)"/></td>
                    <td class="num" style="background:#fdecea; font-weight:bold;"><t t-esc="'{:,.0f}'.format(remises.get('montant_deduit', 0)).replace(',', ' ')"/></td>
                    <td class="num" style="background:#eafaf1;"><t t-esc="remises.get('nb_ajout', 0)"/></td>
                    <td class="num" style="background:#eafaf1; font-weight:bold;"><t t-esc="'{:,.0f}'.format(remises.get('montant_ajout', 0)).replace(',', ' ')"/></td>
                </tr>
            </tbody>
        </table>
        <div style="font-size:7.5pt; color:#666; margin-bottom:10px; font-style:italic;">
            Réduction : montant prélevé sur la carte pour compléter un paiement.
            Ajout : monnaie rendue sur la carte quand la caissière n'a pas de monnaie à rendre.
        </div>

        <!-- ============================================================ -->
        <!-- SECTION 4 : Détail des titres de paiements                   -->
        <!-- ============================================================ -->
        <div class="section-title">Détail des titres de paiements</div>

        <table style="width:55%;">
            <thead>
                <tr>
                    <th class="th-group" style="text-align:left; width:50%;">Mode de paiement</th>
                    <th class="th-group" style="width:25%;">Nombre</th>
                    <th class="th-group" style="width:25%;">Montant TTC</th>
                </tr>
            </thead>
            <tbody>
                <t t-if="titres">
                    <t t-foreach="titres" t-as="titre">
                        <tr t-att-class="'row-alt' if titre_index % 2 == 0 else ''">
                            <td><t t-esc="titre.get('name', '')"/></td>
                            <td class="num"><t t-esc="titre.get('count', 0)"/></td>
                            <td class="num"><t t-esc="'{:,.0f}'.format(titre.get('total', 0)).replace(',', ' ')"/></td>
                        </tr>
                    </t>
                    <tr class="row-total">
                        <td>Total titres</td>
                        <td class="num"><t t-esc="sum(t.get('count',0) for t in titres)"/></td>
                        <td class="num"><t t-esc="'{:,.0f}'.format(sum(t.get('total',0) for t in titres)).replace(',', ' ')"/></td>
                    </tr>
                </t>
                <t t-else="">
                    <tr><td colspan="3" style="color:#888; font-style:italic;">Aucun titre de paiement enregistré</td></tr>
                </t>
            </tbody>
        </table>

        <!-- ============================================================ -->
        <!-- SECTION 5 : Cartes cadeaux                                   -->
        <!-- ============================================================ -->
        <div class="section-title">Cartes cadeaux</div>

        <table style="width:40%;">
            <thead>
                <tr>
                    <th class="th-group" style="text-align:left; width:50%;"></th>
                    <th class="th-group" style="width:25%;">Nombre</th>
                    <th class="th-group" style="width:25%;">Montant</th>
                </tr>
            </thead>
            <tbody>
                <tr><td>Achats</td><td class="num">0</td><td class="num">0</td></tr>
                <tr class="row-alt"><td>Consommées</td><td class="num">0</td><td class="num">0</td></tr>
            </tbody>
        </table>

        <!-- ============================================================ -->
        <!-- SECTION 6 : Répartition des encaissements                    -->
        <!-- ============================================================ -->
        <div class="section-title">Répartition des encaissements</div>

        <table style="width:70%;">
            <thead>
                <tr>
                    <th class="th-group" style="text-align:left; width:28%;">Modalité</th>
                    <th class="th-group" style="width:14%;">Nombre</th>
                    <th class="th-group" style="width:14%;">% répartition</th>
                    <th class="th-group" style="width:22%;">Montant TTC</th>
                    <th class="th-group" style="width:14%;">% répartition</th>
                </tr>
            </thead>
            <tbody>
                <t t-foreach="repartition" t-as="rep">
                    <tr t-att-class="'row-alt' if rep_index % 2 == 0 else ''">
                        <td class="row-bold"><t t-esc="rep.get('label', '')"/></td>
                        <td class="num"><t t-esc="rep.get('count', 0)"/></td>
                        <td class="num"><t t-esc="'{:.2f}'.format(rep.get('pct_count', 0))"/>%</td>
                        <td class="num"><t t-esc="'{:,.0f}'.format(rep.get('montant', 0)).replace(',', ' ')"/></td>
                        <td class="num"><t t-esc="'{:.2f}'.format(rep.get('pct_montant', 0))"/>%</td>
                    </tr>
                </t>
                <tr class="row-grand-total">
                    <td>Total</td>
                    <td class="num"><t t-esc="sum(r.get('count',0) for r in repartition)"/></td>
                    <td class="num"></td>
                    <td class="num"><t t-esc="'{:,.0f}'.format(sum(r.get('montant',0) for r in repartition)).replace(',', ' ')"/></td>
                    <td class="num"></td>
                </tr>
            </tbody>
        </table>

        <!-- ============================================================ -->
        <!-- SECTION 7 : Répartition TVA ventes locales                   -->
        <!-- ============================================================ -->
        <div class="section-title">Répartition de la TVA — ventes locales</div>

        <table>
            <thead>
                <tr>
                    <th class="th-group" style="text-align:left; width:26%;"></th>
                    <t t-foreach="tva_list" t-as="tva">
                        <th class="th-group" style="width:10%;">
                            0 / TVA <t t-esc="'{:.0f}%'.format(tva.get('tax_percent', 0))"/>
                        </th>
                    </t>
                    <th class="th-group" style="width:12%;">Total</th>
                </tr>
            </thead>
            <tbody>
                <tr class="row-bold">
                    <td>CA TTC</td>
                    <t t-foreach="tva_list" t-as="tva">
                        <td class="num"><t t-esc="'{:,.0f}'.format(tva.get('ca_ttc',0)).replace(',', ' ')"/></td>
                    </t>
                    <td class="num highlight"><t t-esc="'{:,.0f}'.format(sum(t.get('ca_ttc',0) for t in tva_list)).replace(',', ' ')"/></td>
                </tr>
                <tr class="row-alt row-bold">
                    <td>Base HT issue des doc.</td>
                    <t t-foreach="tva_list" t-as="tva">
                        <td class="num"><t t-esc="'{:,.0f}'.format(tva.get('base_ht',0)).replace(',', ' ')"/></td>
                    </t>
                    <td class="num highlight"><t t-esc="'{:,.0f}'.format(sum(t.get('base_ht',0) for t in tva_list)).replace(',', ' ')"/></td>
                </tr>
                <tr class="row-italic">
                    <td style="padding-left:14px;">Articles tenus en stock</td>
                    <t t-foreach="tva_list" t-as="tva">
                        <td class="num"><t t-esc="'{:,.0f}'.format(tva.get('articles_tenus',0)).replace(',', ' ')"/></td>
                    </t>
                    <td class="num"><t t-esc="'{:,.0f}'.format(sum(t.get('articles_tenus',0) for t in tva_list)).replace(',', ' ')"/></td>
                </tr>
                <tr class="row-alt row-italic">
                    <td style="padding-left:14px;">Articles non tenus en stock</td>
                    <t t-foreach="tva_list" t-as="tva">
                        <td class="num"><t t-esc="'{:,.0f}'.format(tva.get('articles_non_tenus',0)).replace(',', ' ')"/></td>
                    </t>
                    <td class="num"><t t-esc="'{:,.0f}'.format(sum(t.get('articles_non_tenus',0) for t in tva_list)).replace(',', ' ')"/></td>
                </tr>
                <tr class="row-bold">
                    <td>TVA issue des doc.</td>
                    <t t-foreach="tva_list" t-as="tva">
                        <td class="num"><t t-esc="'{:,.0f}'.format(tva.get('tva',0)).replace(',', ' ')"/></td>
                    </t>
                    <td class="num highlight"><t t-esc="'{:,.0f}'.format(sum(t.get('tva',0) for t in tva_list)).replace(',', ' ')"/></td>
                </tr>
                <tr class="row-alt row-italic">
                    <td style="padding-left:14px;">Articles tenus en stock</td>
                    <t t-foreach="tva_list" t-as="tva">
                        <td class="num"><t t-esc="'{:,.0f}'.format(tva.get('tva_tenus',0)).replace(',', ' ')"/></td>
                    </t>
                    <td class="num"><t t-esc="'{:,.0f}'.format(sum(t.get('tva_tenus',0) for t in tva_list)).replace(',', ' ')"/></td>
                </tr>
                <tr class="row-italic">
                    <td style="padding-left:14px;">Articles non tenus en stock</td>
                    <t t-foreach="tva_list" t-as="tva">
                        <td class="num"><t t-esc="'{:,.0f}'.format(tva.get('tva_non_tenus',0)).replace(',', ' ')"/></td>
                    </t>
                    <td class="num"><t t-esc="'{:,.0f}'.format(sum(t.get('tva_non_tenus',0) for t in tva_list)).replace(',', ' ')"/></td>
                </tr>
                <tr style="border:none;"><td colspan="99" style="border:none; padding:2px; background:transparent;"></td></tr>
                <tr class="row-alt row-bold">
                    <td>Base HT calculée</td>
                    <t t-foreach="tva_list" t-as="tva">
                        <td class="num"><t t-esc="'{:,.0f}'.format(tva.get('base_calc',0)).replace(',', ' ')"/></td>
                    </t>
                    <td class="num highlight"><t t-esc="'{:,.0f}'.format(sum(t.get('base_calc',0) for t in tva_list)).replace(',', ' ')"/></td>
                </tr>
                <tr class="row-bold">
                    <td>TVA calculée</td>
                    <t t-foreach="tva_list" t-as="tva">
                        <td class="num"><t t-esc="'{:,.0f}'.format(tva.get('tva_calc',0)).replace(',', ' ')"/></td>
                    </t>
                    <td class="num highlight"><t t-esc="'{:,.0f}'.format(sum(t.get('tva_calc',0) for t in tva_list)).replace(',', ' ')"/></td>
                </tr>
                <tr class="row-alt">
                    <td>Écart d'arrondis</td>
                    <t t-foreach="tva_list" t-as="tva">
                        <td class="num"><t t-esc="'{:,.0f}'.format(tva.get('ecart',0)).replace(',', ' ')"/></td>
                    </t>
                    <td class="num"><t t-esc="'{:,.0f}'.format(sum(t.get('ecart',0) for t in tva_list)).replace(',', ' ')"/></td>
                </tr>
                <tr>
                    <td>% Écart</td>
                    <t t-foreach="tva_list" t-as="tva">
                        <td class="num"><t t-esc="'{:.2f}'.format(tva.get('pct_ecart',0))"/></td>
                    </t>
                    <td class="num">0,00</td>
                </tr>
            </tbody>
        </table>

        <!-- Pied de page -->
        <div class="rc-footer">
            2/2 — <t t-esc="h.get('company_name', '')"/> — Récapitulatif des Caisses édité le <t t-esc="h.get('print_date', '')"/>
        </div>

    </div>
</template>

</data>
</odoo>
