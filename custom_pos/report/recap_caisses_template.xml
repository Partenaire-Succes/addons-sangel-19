<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<!-- ================================================================ -->
<!-- Wrapper : web.external_layout garantit UTF-8 dans <head>         -->
<!-- Boucle sur chaque POS retourné par get_report_data()             -->
<!-- ================================================================ -->
<template id="report_recap_caisses">
    <t t-call="web.html_container">
        <t t-foreach="docs" t-as="doc">
            <t t-call="web.external_layout">
                <div class="page">
                    <t t-call="custom_pos.report_recap_caisses_document">
                        <t t-set="data" t-value="doc.get_report_data()"/>
                    </t>
                </div>
            </t>
        </t>
    </t>
</template>

<!-- ================================================================ -->
<!-- Document (une section par POS)                                    -->
<!-- ================================================================ -->
<template id="report_recap_caisses_document">
    <style>
        .rc-report { font-family: Arial, Helvetica, sans-serif; font-size: 9pt; color: #1a1a1a; }
        .rc-report table { width: 100%; border-collapse: collapse; margin-bottom: 10px; }
        .rc-report td, .rc-report th { padding: 4px 6px; border: 1px solid #b0b0b0; }
        .rc-report .section-title {
            display: inline-block;
            white-space: nowrap;
            background: #2c3e50; color: #ffffff; font-weight: bold;
            font-size: 10pt; padding: 5px 10px; margin: 10px 0 4px 0;
            letter-spacing: 0.5px;
        }
        .rc-report .th-group {
            background: #34495e; color: #ffffff; font-weight: bold;
            text-align: center; font-size: 8.5pt; padding: 4px 4px;
        }
        .rc-report .th-sub {
            background: #ecf0f1; font-weight: bold; text-align: center;
            font-size: 7.5pt; padding: 3px 3px; border-top: 2px solid #2c3e50;
        }
        .rc-report .row-total   { background: #d5e8d4; font-weight: bold; border-top: 2px solid #2c3e50; }
        .rc-report .row-total2  { background: #dae8fc; font-weight: bold; border-top: 2px solid #2c3e50; }
        .rc-report .row-grand-total { background: #2c3e50; color: #ffffff; font-weight: bold; }
        .rc-report .row-alt     { background: #f5f8fa; }
        .rc-report .row-italic  { font-style: italic; color: #555; }
        .rc-report .row-bold    { font-weight: bold; }
        .rc-report .num         { text-align: right; white-space: nowrap; }
        .rc-report .highlight   { font-weight: bold; }
        .rc-main-title {
            text-align: center; font-size: 17pt; font-weight: bold;
            color: #2c3e50; letter-spacing: 1px; padding: 8px 0 6px 0;
            border-bottom: 3px solid #2c3e50; margin-bottom: 8px;
        }
        .rc-header-info { margin-bottom: 8px; font-size: 9pt; }
        .rc-header-info table { border: none; margin-bottom: 0; }
        .rc-header-info td { border: none; padding: 2px 4px; }
        .rc-mini-header { font-size: 8pt; border-bottom: 1px solid #999; margin-bottom: 6px; padding-bottom: 4px; }
        .rc-mini-header table { border: none; margin-bottom: 0; }
        .rc-mini-header td { border: none; padding: 1px 4px; }
        .rc-page2 { page-break-before: always; }
        .rc-footer { text-align: right; font-size: 7.5pt; margin-top: 8px; color: #888; border-top: 1px solid #ccc; padding-top: 4px; }
    </style>

    <t t-set="h"           t-value="data.get('header', {})"/>
    <t t-set="ca"          t-value="data.get('ca_detaille', {})"/>
    <t t-set="enc"         t-value="data.get('encaissements', {})"/>
