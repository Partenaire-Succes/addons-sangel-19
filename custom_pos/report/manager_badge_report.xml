<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="paperformat_manager_badge" model="report.paperformat">
            <field name="name">Badge Manager POS (85×54mm)</field>
            <field name="default" eval="False"/>
            <field name="format">custom</field>
            <field name="page_width">85</field>
            <field name="page_height">54</field>
            <field name="orientation">Landscape</field>
            <field name="margin_top">3</field>
            <field name="margin_bottom">3</field>
            <field name="margin_left">4</field>
            <field name="margin_right">4</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">0</field>
            <field name="dpi">150</field>
        </record>

        <record id="action_report_manager_badge" model="ir.actions.report">
            <field name="name">Badge Manager</field>
            <field name="model">pos.manager.code</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">custom_pos.report_manager_badge</field>
            <field name="report_file">custom_pos.report_manager_badge</field>
            <field name="print_report_name">'Badge_POS_%s' % object.name.replace(' ', '_')</field>
            <field name="paperformat_id" ref="custom_pos.paperformat_manager_badge"/>
        </record>

    </data>
</odoo>
