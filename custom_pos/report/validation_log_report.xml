<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="paperformat_validation_log" model="report.paperformat">
            <field name="name">Rapport Validations POS (A4)</field>
            <field name="default" eval="False"/>
            <field name="format">A4</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">15</field>
            <field name="margin_bottom">10</field>
            <field name="margin_left">10</field>
            <field name="margin_right">10</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">0</field>
            <field name="dpi">96</field>
        </record>

        <record id="action_report_validation_log" model="ir.actions.report">
            <field name="name">Rapport des validations</field>
            <field name="model">pos.session</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">custom_pos.report_validation_log_document</field>
            <field name="report_file">custom_pos.report_validation_log_document</field>
            <field name="print_report_name">'Validations_%s_%s' % (object.config_id.name, object.start_at.strftime('%Y%m%d') if object.start_at else '')</field>
            <field name="binding_model_id" ref="point_of_sale.model_pos_session"/>
            <field name="binding_type">report</field>
            <field name="paperformat_id" ref="custom_pos.paperformat_validation_log"/>
        </record>

    </data>
</odoo>
