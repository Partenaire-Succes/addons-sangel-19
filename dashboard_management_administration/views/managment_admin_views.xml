    <!-- Action -->
    <record id="action_managment_admin" model="ir.actions.act_window">
        <field name="name">Gestion Administration</field>
        <field name="res_model">managment.admin</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_my_periods': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Créer une nouvelle période de gestion
            </p>
        </field>
