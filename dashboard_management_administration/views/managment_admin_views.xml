<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View -->
    <record id="view_managment_admin_form" model="ir.ui.view">
        <field name="name">managment.admin.form</field>
        <field name="model">managment.admin</field>
        <field name="arch" type="xml">
            <form string="Gestion Administration">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nom de la période..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="responsible_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="date_from"/>
                            <field name="date_to"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Ventes" name="sales">
                            <group>
                                <button name="action_view_sale_orders" 
                                        type="object" 
                                        string="Voir toutes les ventes"
                                        class="btn-primary"
                                        icon="fa-eye"/>
                            </group>
                            <field name="sale_order_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="partner_id"/>
                                    <field name="date_order"/>
                                    <field name="amount_total" sum="Total"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>

                        <page string="Achats" name="purchases">
                            <group>
                                <button name="action_view_purchase_orders" 
                                        type="object" 
                                        string="Voir tous les achats"
                                        class="btn-primary"
                                        icon="fa-eye"/>
                            </group>
                            <field name="purchase_order_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="partner_id"/>
                                    <field name="date_order"/>
                                    <field name="amount_total" sum="Total"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>

                        <page string="Point de Vente" name="pos">
                            <group>
                                <button name="action_view_pos_orders" 
                                        type="object" 
                                        string="Voir toutes les commandes POS"
                                        class="btn-primary"
                                        icon="fa-eye"/>
                            </group>
                            <field name="pos_order_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="partner_id"/>
                                    <field name="session_id"/>
                                    <field name="config_id"/>
                                    <field name="date_order"/>
                                    <field name="amount_total" sum="Total"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- list View -->
    <record id="view_managment_admin_tree" model="ir.ui.view">
        <field name="name">managment.admin.list</field>
        <field name="model">managment.admin</field>
        <field name="arch" type="xml">
            <list string="Gestion Administration">
                <field name="name"/>
                <field name="responsible_id"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

