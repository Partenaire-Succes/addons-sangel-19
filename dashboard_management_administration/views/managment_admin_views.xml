<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View -->
    <record id="view_managment_admin_form" model="ir.ui.view">
        <field name="name">managment.admin.form</field>
        <field name="model">managment.admin</field>
        <field name="arch" type="xml">
            <form string="Gestion Administration">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nom de la période..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="responsible_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="date_from"/>
                            <field name="date_to"/>
                        </group>
                    </group>

                    <footer>
                        <button name="action_view_sale_orders"
                                type="object"
                                string="Voir les ventes"
                                class="btn-primary"/>

                        <button name="action_view_purchase_orders"
                                type="object"
                                string="Voir les achats"
                                class="btn-secondary"/>

                        <button name="action_view_pos_orders"
                                type="object"
                                string="Voir le POS"
                                class="btn-info"/>

                        <button string="Fermer"
                                special="cancel"
                                class="btn-light"/>
                    </footer>

                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- list View -->
    <record id="view_managment_admin_tree" model="ir.ui.view">
        <field name="name">managment.admin.list</field>
        <field name="model">managment.admin</field>
        <field name="arch" type="xml">
            <list string="Gestion Administration">
                <field name="name"/>
                <field name="responsible_id"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

