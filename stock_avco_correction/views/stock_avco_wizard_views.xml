<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_stock_avco_import_wizard_form" model="ir.ui.view">
        <field name="name">stock.avco.import.wizard.form</field>
        <field name="model">stock.avco.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Correction AVCO — Import Excel">

                <header>
                    <button name="action_load_file"
                            string="Analyser le fichier"
                            type="object" class="btn-primary"
                            invisible="state != 'import'"/>
                    <button name="action_apply"
                            string="Appliquer les corrections"
                            type="object" class="btn-primary"
                            confirm="Les mouvements, commandes et factures seront mis a jour. Continuer ?"
                            invisible="state != 'preview'"/>
                    <button name="action_reset"
                            string="Recommencer"
                            type="object" class="btn-secondary"
                            invisible="state == 'import'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="import,preview,done"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1>Correction AVCO — Import Excel</h1>
                    </div>

                    <!-- ======================== -->
                    <!-- ETAPE 1 : IMPORT        -->
                    <!-- ======================== -->
                    <group invisible="state != 'import'">
                        <group string="Fichier et Societe">
                            <field name="company_id" options="{'no_create': True}"
                                   string="Societe a corriger"/>
                            <field name="excel_file" filename="excel_filename"
                                   widget="binary" string="Fichier (.xlsx / .xls)"/>
                            <field name="excel_filename" invisible="1"/>
                        </group>
                        <group string="Parametres">
                            <field name="variation_threshold"
                                   string="Seuil de variation (%)"
                                   help="Si la variation entre le prix reception et le prix Excel est inferieure ou egale a ce seuil, le prix reception est conserve. Sinon le prix Excel est utilise."/>
                        </group>
                    </group>

                    <!-- Explication règle -->
                    <div invisible="state != 'import'"
                         style="background:#fff8e1;border:1px solid #ffc107;
                                border-radius:6px;padding:12px;margin-top:8px;font-size:13px;">
                        <b>Regle de correction appliquee :</b><br/><br/>
                        1. Reception = 0 &#8594; Prix Excel utilise<br/>
                        2. Variation entre reception et Excel &lt;= seuil &#8594; Prix reception conserve (correct)<br/>
                        3. Variation entre reception et Excel &gt; seuil &#8594; Prix Excel utilise (prix reception errone)
                    </div>

                    <!-- Format Excel -->
                    <div invisible="state != 'import'"
                         style="background:#f0f7ff;border:1px solid #b8d4f0;
                                border-radius:6px;padding:12px;margin-top:8px;">
                        <b>Format Excel attendu :</b>
                        <table style="margin-top:8px;border-collapse:collapse;width:260px;">
                            <tr style="background:#d0e8ff;">
                                <th style="padding:6px;border:1px solid #aac;">code article</th>
                                <th style="padding:6px;border:1px solid #aac;">pmp</th>
                            </tr>
                            <tr>
                                <td style="padding:6px;border:1px solid #ddd;text-align:center;">0404</td>
                                <td style="padding:6px;border:1px solid #ddd;text-align:right;">2582.67</td>
                            </tr>
                        </table>
                    </div>

                    <!-- ======================== -->
                    <!-- ETAPES 2 ET 3           -->
                    <!-- ======================== -->
                    <div invisible="state == 'import'">

                        <field name="summary_html" widget="html" readonly="1" nolabel="1"/>

                        <notebook>
                            <page string="Lignes a corriger" invisible="state == 'done'">
                                <field name="line_ids" nolabel="1" readonly="1">
                                    <list decoration-success="state == 'ready'"
                                          decoration-danger="state == 'not_found'"
                                          decoration-warning="state == 'no_move'"
                                          decoration-muted="state in ('ok','done')">
                                        <field name="code_article"            string="Code"/>
                                        <field name="product_id"              string="Produit"/>
                                        <field name="pmp_excel"               string="PMP Excel"/>
                                        <field name="nb_moves_total"          string="Total"/>
                                        <field name="nb_moves_no_change"      string="Sans chgt"/>
                                        <field name="nb_moves_reception_ok"   string="Var.&lt;=seuil"/>
                                        <field name="nb_moves_excel_override" string="Var.&gt;seuil"/>
                                        <field name="nb_moves_excel_zero"     string="Récep.=0"/>
                                        <field name="total_qty"               string="Qte"/>
                                        <field name="total_value"             string="Valeur (FCFA)"/>
                                        <field name="state" string="Statut" widget="badge"
                                               decoration-success="state == 'ready'"
                                               decoration-danger="state == 'not_found'"
                                               decoration-warning="state == 'no_move'"
                                               decoration-muted="state in ('ok','done')"/>
                                    </list>
                                </field>
                            </page>

                            <page string="Codes non trouves" invisible="nb_not_found == 0">
                                <field name="line_ids" nolabel="1" readonly="1"
                                       domain="[('state','=','not_found')]">
                                    <list>
                                        <field name="code_article" string="Code Article"/>
                                        <field name="pmp_excel"    string="PMP Excel"/>
                                    </list>
                                </field>
                            </page>

                            <page string="Resultat" invisible="state != 'done'">
                                <group>
                                    <group string="Statistiques">
                                        <field name="nb_products_updated"  string="Produits traites"/>
                                        <field name="nb_moves_corrected"   string="Mouvements corriges"/>
                                        <field name="nb_po_updated"        string="Commandes mises a jour"/>
                                        <field name="nb_invoice_updated"   string="Factures mises a jour"/>
                                        <field name="total_value_injected" string="Valeur totale (FCFA)"/>
                                        <field name="nb_not_found"         string="Codes non trouves"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </div>

                </sheet>
            </form>
        </field>
    </record>

    <record id="action_stock_avco_import_wizard" model="ir.actions.act_window">
        <field name="name">Correction AVCO</field>
        <field name="res_model">stock.avco.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
