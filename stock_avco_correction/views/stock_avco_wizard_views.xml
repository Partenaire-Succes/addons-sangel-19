<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_stock_avco_import_wizard_form" model="ir.ui.view">
        <field name="name">stock.avco.import.wizard.form</field>
        <field name="model">stock.avco.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Correction AVCO — Import Excel">

                <header>
                    <button name="action_load_file"
                            string="Analyser le fichier"
                            type="object" class="btn-primary"
                            invisible="state != 'import'"/>
                    <button name="action_apply"
                            string="Appliquer les corrections"
                            type="object" class="btn-primary"
                            confirm="Les mouvements, commandes et factures seront mis à jour avec le PMP Excel. Continuer ?"
                            invisible="state != 'preview'"/>
                    <button name="action_reset"
                            string="Recommencer"
                            type="object" class="btn-secondary"
                            invisible="state == 'import'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="import,preview,done"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1>Correction AVCO — Import Excel</h1>
                    </div>

                    <!-- ======================== -->
                    <!-- ETAPE 1 : IMPORT        -->
                    <!-- ======================== -->
                    <group invisible="state != 'import'">
                        <group string="Fichier et Société">
                            <field name="company_id" options="{'no_create': True}"
                                   string="Société à corriger"/>
                            <field name="move_type" widget="radio"
                                   options="{'horizontal': true}"/>
                            <field name="excel_file" filename="excel_filename"
                                   widget="binary" string="Fichier (.xlsx / .xls)"/>
                            <field name="excel_filename" invisible="1"/>
                        </group>
                    </group>

                    <div invisible="state != 'import'"
                         style="background:#f0f7ff;border:1px solid #b8d4f0;
                                border-radius:6px;padding:12px;margin-top:8px;">
                        <b>Format Excel attendu :</b>
                        <table style="margin-top:8px;border-collapse:collapse;width:260px;">
                            <tr style="background:#d0e8ff;">
                                <th style="padding:6px;border:1px solid #aac;">code article</th>
                                <th style="padding:6px;border:1px solid #aac;">pmp</th>
                            </tr>
                            <tr>
                                <td style="padding:6px;border:1px solid #ddd;text-align:center;">0404</td>
                                <td style="padding:6px;border:1px solid #ddd;text-align:right;">2582.67</td>
                            </tr>
                        </table>
                        <p style="margin-top:8px;font-size:12px;color:#6c757d;">
                            Le PMP Excel est appliqué directement sur tous les mouvements de réception du produit.
                        </p>
                    </div>

                    <!-- ======================== -->
                    <!-- ETAPES 2 ET 3           -->
                    <!-- ======================== -->
                    <div invisible="state == 'import'">

                        <field name="summary_html" widget="html" readonly="1" nolabel="1"/>

                        <notebook>
                            <page string="Articles à corriger" invisible="state == 'done'">
                                <field name="line_ids" nolabel="1" readonly="1">
                                    <list decoration-success="state == 'ready'"
                                          decoration-danger="state == 'not_found'"
                                          decoration-warning="state == 'no_move'"
                                          decoration-muted="state == 'done'">
                                        <field name="code_article" string="Code"/>
                                        <field name="product_id"   string="Produit"/>
                                        <field name="pmp_excel"    string="PMP Excel" digits="[16,4]"/>
                                        <field name="nb_moves"     string="Mouvements"/>
                                        <field name="total_qty"    string="Qté totale" digits="[16,3]"/>
                                        <field name="old_value"    string="Valeur actuelle" digits="[16,2]"/>
                                        <field name="new_value"    string="Nouvelle valeur" digits="[16,2]"/>
                                        <field name="state" string="Statut" widget="badge"
                                               decoration-success="state == 'ready'"
                                               decoration-danger="state == 'not_found'"
                                               decoration-warning="state == 'no_move'"
                                               decoration-muted="state == 'done'"/>
                                    </list>
                                </field>
                            </page>

                            <page string="Codes non trouvés" invisible="nb_not_found == 0">
                                <field name="line_ids" nolabel="1" readonly="1"
                                       domain="[('state','=','not_found')]">
                                    <list>
                                        <field name="code_article" string="Code Article"/>
                                        <field name="pmp_excel"    string="PMP Excel" digits="[16,4]"/>
                                    </list>
                                </field>
                            </page>

                            <page string="Résultat" invisible="state != 'done'">
                                <group>
                                    <group string="Statistiques">
                                        <field name="nb_products_updated"  string="Produits traités"/>
                                        <field name="nb_moves_corrected"   string="Mouvements corrigés"/>
                                        <field name="nb_po_updated"        string="Commandes mises à jour"/>
                                        <field name="nb_invoice_updated"   string="Factures mises à jour"/>
                                        <field name="total_value_injected" string="Valeur totale (FCFA)"/>
                                        <field name="nb_not_found"         string="Codes non trouvés"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </div>

                </sheet>
            </form>
        </field>
    </record>

    <record id="action_stock_avco_import_wizard" model="ir.actions.act_window">
        <field name="name">Correction AVCO</field>
        <field name="res_model">stock.avco.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
