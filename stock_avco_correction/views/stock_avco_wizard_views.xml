<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_stock_avco_import_wizard_form" model="ir.ui.view">
        <field name="name">stock.avco.import.wizard.form</field>
        <field name="model">stock.avco.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Correction AVCO — Import Excel">

                <header>
                    <button name="action_load_file"
                            string="📂 Analyser le fichier"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'import'"/>
                    <button name="action_apply"
                            string="⚡ Appliquer les corrections"
                            type="object"
                            class="btn-primary"
                            confirm="Les mouvements, commandes et factures seront mis à jour. Continuer ?"
                            invisible="state != 'preview'"/>
                    <button name="action_reset"
                            string="↩ Recommencer"
                            type="object"
                            class="btn-secondary"
                            invisible="state == 'import'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="import,preview,done"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1>🔧 Correction AVCO — Import Excel</h1>
                    </div>

                    <!-- ======================== -->
                    <!-- ÉTAPE 1 : IMPORT        -->
                    <!-- ======================== -->
                    <group invisible="state != 'import'">
                        <group string="📎 Fichier Excel">
                            <field name="excel_file"
                                   filename="excel_filename"
                                   widget="binary"
                                   string="Fichier (.xlsx / .xls)"/>
                            <field name="excel_filename" invisible="1"/>
                        </group>
                        <group string="⚙️ Options">
                            <field name="update_standard_price"/>
                        </group>
                    </group>

                    <div invisible="state != 'import'"
                         style="background:#f0f7ff;border:1px solid #b8d4f0;
                                border-radius:6px;padding:12px;margin-top:8px;">
                        <strong>📋 Format Excel attendu :</strong>
                        <table style="margin-top:8px;border-collapse:collapse;width:280px;">
                            <tr style="background:#d0e8ff;">
                                <th style="padding:6px;border:1px solid #aac;">code article</th>
                                <th style="padding:6px;border:1px solid #aac;">pmp</th>
                            </tr>
                            <tr>
                                <td style="padding:6px;border:1px solid #ddd;text-align:center;">0404</td>
                                <td style="padding:6px;border:1px solid #ddd;text-align:right;">2582.67</td>
                            </tr>
                            <tr style="background:#f8f9fa;">
                                <td style="padding:6px;border:1px solid #ddd;text-align:center;">0430</td>
                                <td style="padding:6px;border:1px solid #ddd;text-align:right;">3170.82</td>
                            </tr>
                        </table>
                        <p style="margin-top:8px;color:#555;font-size:12px;">
                            ℹ️ Codes avec ou sans zéro acceptés (404 = 0404)
                        </p>
                    </div>

                    <div invisible="state != 'import'"
                         style="background:#fff8e1;border:1px solid #ffc107;border-radius:6px;
                                padding:12px;margin-top:8px;font-size:13px;">
                        <strong>⚙️ Logique de correction (toutes les réceptions) :</strong><br/><br/>
                        🔵 <strong>Réception a un prix</strong> → prix réception = vérité<br/>
                           → PO ≠ réception ? → PO corrigé<br/>
                           → Facture ≠ réception ? → Facture corrigée<br/>
                           → Value incohérente ? → Value recalculée<br/><br/>
                        🟡 <strong>Réception = 0</strong> → prix Excel utilisé<br/>
                           → stock_move + PO + Facture corrigés
                    </div>

                    <!-- ======================== -->
                    <!-- ÉTAPES 2 et 3           -->
                    <!-- ======================== -->
                    <div invisible="state == 'import'">

                        <field name="summary_html" widget="html" readonly="1" nolabel="1"/>

                        <notebook>
                            <page string="📦 Lignes à corriger"
                                  invisible="state == 'done'">
                                <field name="line_ids" nolabel="1" readonly="1">
                                    <list decoration-success="state == 'ready'"
                                          decoration-danger="state == 'not_found'"
                                          decoration-warning="state == 'no_move'"
                                          decoration-muted="state in ('ok','done')">
                                        <field name="code_article"           string="Code"/>
                                        <field name="product_id"             string="Produit"/>
                                        <field name="pmp_excel"              string="PMP Excel"/>
                                        <field name="nb_moves_total"         string="Total moves"/>
                                        <field name="nb_moves_reception_ok"  string="✔ PO=Récep."/>
                                        <field name="nb_moves_po_mismatch"   string="🔄 PO≠Récep."/>
                                        <field name="nb_moves_zero"          string="📄 Récep.=0"/>
                                        <field name="total_qty"              string="Qté"/>
                                        <field name="total_value"            string="Valeur (FCFA)"/>
                                        <field name="state"                  string="Statut"
                                               widget="badge"
                                               decoration-success="state == 'ready'"
                                               decoration-danger="state == 'not_found'"
                                               decoration-warning="state == 'no_move'"
                                               decoration-muted="state in ('ok','done')"/>
                                    </list>
                                </field>
                            </page>

                            <page string="❌ Codes non trouvés"
                                  invisible="nb_not_found == 0">
                                <field name="line_ids" nolabel="1" readonly="1"
                                       domain="[('state','=','not_found')]">
                                    <list>
                                        <field name="code_article" string="Code Article"/>
                                        <field name="pmp_excel"    string="PMP Excel"/>
                                    </list>
                                </field>
                            </page>

                            <page string="✅ Résultat" invisible="state != 'done'">
                                <group>
                                    <group string="Statistiques">
                                        <field name="nb_products_updated"
                                               string="Produits traités"/>
                                        <field name="nb_moves_corrected"
                                               string="Mouvements de stock corrigés"/>
                                        <field name="nb_po_updated"
                                               string="Commandes d'achat mises à jour"/>
                                        <field name="nb_invoice_updated"
                                               string="Factures fournisseurs mises à jour"/>
                                        <field name="total_value_injected"
                                               string="Valeur totale recalculée (FCFA)"/>
                                        <field name="nb_not_found"
                                               string="Codes non trouvés"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </div>

                </sheet>
            </form>
        </field>
    </record>

    <record id="action_stock_avco_import_wizard" model="ir.actions.act_window">
        <field name="name">Correction AVCO</field>
        <field name="res_model">stock.avco.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
