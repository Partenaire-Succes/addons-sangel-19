<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Template d'impression avec QR Code FNE -->
    <template id="report_invoice_document_fne" inherit_id="account.report_invoice_document">
        
        <!-- Ajout du badge FNE en haut de la facture -->
        <xpath expr="//h2" position="before">
            <div class="row" t-if="o.fne_certified">
                <div class="col-12 text-center" style="margin-bottom: 20px;">
                    <div style="border: 3px solid #00a651; padding: 15px; background-color: #f0fdf4; border-radius: 8px;">
                        <h3 style="color: #00a651; margin: 0;">
                            <i class="fa fa-check-circle"/> FACTURE NORMALISÉE ÉLECTRONIQUE
                        </h3>
                        <p style="margin: 5px 0; font-size: 16px;">
                            <strong>Référence FNE:</strong> <span t-field="o.fne_reference"/>
                        </p>
                    </div>
                </div>
            </div>
        </xpath>
        
        <!-- Ajout du QR Code en bas de la facture -->
        <xpath expr="//p[@name='payment_term']" position="after">
            <div class="row" t-if="o.fne_certified" style="page-break-inside: avoid; margin-top: 30px;">
                <div class="col-12">
                    <hr style="border-top: 2px solid #00a651;"/>
                    <h4 style="color: #00a651; text-align: center;">
                        <i class="fa fa-qrcode"/> Code de vérification FNE
                    </h4>
                </div>
                
                <div class="col-6 text-center">
                    <t t-if="o.fne_qr_code">
                        <img t-att-src="'/report/barcode/?type=QR&amp;value=%s&amp;width=200&amp;height=200' % quote_plus(o.fne_qr_code)" 
                             style="max-width: 200px; max-height: 200px;" 
                             alt="QR Code FNE"/>
                        <p style="font-size: 10px; margin-top: 10px;">
                            Scanner ce code pour vérifier l'authenticité
                        </p>
                    </t>
                </div>
                
                <div class="col-6">
                    <table class="table table-sm" style="font-size: 11px;">
                        <tr>
                            <td><strong>Référence FNE:</strong></td>
                            <td><span t-field="o.fne_reference"/></td>
                        </tr>
                        <tr>
                            <td><strong>ID Certification:</strong></td>
                            <td style="font-size: 9px;"><span t-field="o.fne_id"/></td>
                        </tr>
                        <tr>
                            <td><strong>Type client:</strong></td>
                            <td><span t-field="o.fne_template"/></td>
                        </tr>
                        <tr>
                            <td><strong>Paiement:</strong></td>
                            <td><span t-field="o.fne_payment_method"/></td>
                        </tr>
                        <tr>
                            <td><strong>Lien vérification:</strong></td>
                            <td colspan="2" style="font-size: 8px; word-break: break-all;">
                                <span t-field="o.fne_token"/>
                            </td>
                        </tr>
                    </table>
                </div>
                
                <div class="col-12 text-center" style="margin-top: 15px; padding: 10px; background-color: #f9fafb; border-radius: 5px;">
                    <p style="margin: 0; font-size: 10px; color: #6b7280;">
                        <strong>Direction Générale des Impôts - Côte d'Ivoire</strong><br/>
                        Facture certifiée conforme aux dispositions de la loi de finances 2025<br/>
                        Support: support.fne@dgi.gouv.ci
                    </p>
                </div>
            </div>
        </xpath>
        
    </template>
    
    <!-- Rapport PDF avec QR Code -->
    <record id="account.account_invoices" model="ir.actions.report">
        <field name="paperformat_id" ref="account.paperformat_euro"/>
    </record>

</odoo>