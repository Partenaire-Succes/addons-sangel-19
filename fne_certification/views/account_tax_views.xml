<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Extension vue formulaire partenaire -->
        <record id="view_tax_form_fne" model="ir.ui.view">
            <field name="name">account.tax.form.fne</field>
            <field name="model">account.tax</field>
            <field name="inherit_id" ref="account.view_tax_form"/>
            <field name="arch" type="xml">
                <!-- Ajouter le type client FNE dans l'onglet Comptabilité -->
                <xpath expr="//field[@name='active']" position="inside">
                    <field name="tax_type" readonly="0" 
                        widget="badge" 
                        decoration-info="tax_type == 'TVA'"
                        decoration-success="tax_type == 'TVAB'"
                        decoration-warning="tax_type == 'TVAC'"
                        decoration-primary="tax_type == 'TVAD'"
                        decoration-dark="tax_type == 'OTHER'" />
                </xpath>
            </field>
        </record>
        
        <!-- Extension vue liste partenaire -->
        <record id="view_tax_tree_fne" model="ir.ui.view">
            <field name="name">account.tax.tree.fne</field>
            <field name="model">account.tax</field>
            <field name="inherit_id" ref="account.view_tax_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='description']" position="after">
                    <field name="tax_type" optional="show"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>