<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Template du document (appelé une fois par enregistrement) -->
    <template id="report_supplier_returns_document">
        <t t-call="web.external_layout">
            <t t-set="o" t-value="doc"/>
            <t t-set="data" t-value="o._get_report_data()"/>
            <div class="page">
                <style>
                    .page {
                        font-family: Arial, sans-serif;
                        font-size: 10pt;
                    }
                    .header-section {
                        margin-bottom: 20px;
                        border-bottom: 2px solid #000;
                        padding-bottom: 10px;
                    }
                    .company-name {
                        font-size: 14pt;
                        font-weight: bold;
                        text-transform: uppercase;
                    }
                    .report-title {
                        text-align: center;
                        font-size: 12pt;
                        font-weight: bold;
                        margin: 20px 0;
                        border: 2px solid #000;
                        padding: 8px;
                        background-color: #f5f5f5;
                    }
                    .date-range {
                        text-align: right;
                        font-weight: bold;
                        margin-bottom: 10px;
                    }
                    .table-retours {
                        width: 100%;
                        border-collapse: collapse;
                        margin-bottom: 15px;
                        font-size: 9pt;
                    }
                    .table-retours th {
                        background-color: #e0e0e0;
                        border: 1px solid #000;
                        padding: 5px;
                        font-weight: bold;
                        text-align: left;
                    }
                    .table-retours td {
                        border: 1px solid #000;
                        padding: 4px 5px;
                    }
                    .subtotal-row {
                        background-color: #f0f0f0;
                        font-weight: bold;
                    }
                    .total-row {
                        background-color: #d0d0d0;
                        font-weight: bold;
                        font-size: 11pt;
                    }
                    .text-right  { text-align: right; }
                    .text-center { text-align: center; }
                    .fournisseur-name {
                        font-weight: bold;
                        color: #000;
                    }
                </style>

                <!-- En-tête -->
                <div class="header-section">
                    <div class="row">
                        <div class="col-8">
                            <div class="company-name">
                                <span t-field="o.company_id.name"/>
                            </div>
                            <div t-if="o.company_id.street">
                                <span t-field="o.company_id.street"/>
                            </div>
                            <div t-if="o.company_id.city">
                                <span t-field="o.company_id.city"/>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="date-range">
                                Du <span t-esc="o.date_from.strftime('%d/%m/%Y')"/>
                                Au <span t-esc="o.date_to.strftime('%d/%m/%Y')"/>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Titre -->
                <div class="report-title">
                    Récapitulatif Retours Fournisseurs
                </div>

                <t t-set="grand_total" t-value="0"/>

                <!-- Boucle par fournisseur -->
                <t t-foreach="data['suppliers']" t-as="supplier">
                    <t t-set="grand_total" t-value="grand_total + supplier['total_amount']"/>

                    <table class="table-retours">
                        <thead>
                            <tr>
                                <th style="width: 8%;">Type Mvt</th>
                                <th style="width: 12%;">Date</th>
                                <th style="width: 15%;">N° Retour</th>
                                <th style="width: 25%;">Fournisseur</th>
                                <th style="width: 20%;">Référence</th>
                                <th style="width: 20%;" class="text-right">Montant Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="supplier['returns']" t-as="return_data">
                                <tr>
                                    <td class="text-center">BRF</td>
                                    <td class="text-center">
                                        <span t-esc="return_data['date'].strftime('%d-%m-%Y') if return_data['date'] else ''"/>
                                    </td>
                                    <td><span t-esc="return_data['reference']"/></td>
                                    <td>
                                        <span class="fournisseur-name" t-esc="supplier['supplier_name']"/>
                                    </td>
                                    <td><span t-esc="return_data['origin']"/></td>
                                    <td class="text-right">
                                        <span t-esc="'{:,.0f}'.format(return_data['amount']).replace(',', ' ')"/>
                                    </td>
                                </tr>
                            </t>
                            <!-- Sous-total -->
                            <tr class="subtotal-row">
                                <td class="text-right" style="font-size: 13pt;" colspan="5">
                                    <span t-esc="supplier['supplier_name']"/>
                                </td>
                                <td class="text-right" style="font-size: 13pt;">
                                    <span t-esc="'{:,.0f}'.format(supplier['total_amount']).replace(',', ' ')"/>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </t>

                <!-- Total général -->
                <t t-if="len(data['suppliers']) > 1">
                    <table class="table-retours" style="margin-top: 20px; width: 50%; margin-left: 50%;">
                        <tr class="total-row">
                            <td style="width: 60%; border: 2px solid #000; font-size: 15pt;" class="text-center">
                                TOTAL RETOURS
                            </td>
                            <td style="width: 40%; border: 2px solid #000; font-size: 15pt;" class="text-right">
                                <span t-esc="'{:,.0f}'.format(grand_total).replace(',', ' ')"/>
                            </td>
                        </tr>
                    </table>
                </t>

                <!-- Pied de page -->
                <div style="margin-top: 30px; font-size: 8pt;">
                    <div class="row">
                        <div class="col-6">
                            <strong>Nombre de fournisseurs:</strong>
                            <span t-esc="len(data['suppliers'])"/>
                        </div>
                        <div class="col-6 text-right">
                            <strong>Date d'impression:</strong>
                            <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y %H:%M')"/>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- Template conteneur (même pattern que réceptions) -->
    <template id="report_supplier_returns">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="custom_reports.report_supplier_returns_document"/>
            </t>
        </t>
    </template>

    <!-- Déclaration du rapport -->
    <record id="action_report_supplier_returns" model="ir.actions.report">
        <field name="name">Retours Fournisseurs</field>
        <field name="model">supplier.return.report.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_reports.report_supplier_returns</field>
        <field name="report_file">custom_reports.report_supplier_returns</field>
        <field name="binding_model_id" ref="model_supplier_return_report_wizard"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">'Retours_Fournisseurs_%s_%s' % (object.date_from.strftime('%Y%m%d'), object.date_to.strftime('%Y%m%d'))</field>
        <field name="paperformat_id" ref="base.paperformat_euro"/>
    </record>
</odoo>
