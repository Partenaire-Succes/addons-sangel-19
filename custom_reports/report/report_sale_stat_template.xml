<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_sale_statistics_document">
        <t t-call="web.external_layout">
            <t t-foreach="docs" t-as="doc">
                <div class="page">
                    <main>
                        <style>
                            .stat-table {
                            width: 100%;
                            font-size: 7pt;
                            margin-bottom: 20px;
                            border-collapse: collapse;
                            }
                            .stat-table th {
                            padding: 4px 3px;
                            text-align: center;
                            font-weight: bold;
                            border: 1px solid #333;
                            font-size: 7pt;
                            }
                            .stat-table td {
                            padding: 2px 3px;
                            border: 1px solid #999;
                            font-size: 7pt;
                            }
                            .stat-table .total-row {
                            border-top: 2px solid #333;
                            font-weight: bold;
                            }
                            .stat-table .grand-total-row {
                            border-top: 2px solid #333;
                            font-weight: bold;
                            }
                            .text-right { text-align: right; }
                            .text-center { text-align: center; }
                            .text-left { text-align: left; }
                            .group-title {
                            border-left: 3px solid #333;
                            padding: 5px 10px;
                            font-weight: bold;
                            margin-top: 15px;
                            margin-bottom: 5px;
                            font-size: 9pt;
                            }
                            .page-header h3 { font-size: 12pt; margin: 5px 0; }
                            .page-header h4 { font-size: 10pt; margin: 3px 0; }
                            .col-period1 {}
                            .col-period2 {}
                            .col-progress {}
                            .col-progress-pct {}
                        </style>

                        <!-- En-tête -->
                        <t t-set="group_by_labels" t-value="{
                            'customer_category': ('FAM_CLI', 'CLIENT'),
                            'customer':          ('CLIENT', 'RÉF.'),
                            'product_category':  ('CATÉG. PRODUIT', 'PRODUIT'),
                            'product':           ('PRODUIT', 'RÉF.'),
                        }"/>
                        <t t-set="lbl_group" t-value="group_by_labels.get(doc.group_by, ('GROUPE', 'DÉTAIL'))[0]"/>
                        <t t-set="lbl_item"  t-value="group_by_labels.get(doc.group_by, ('GROUPE', 'DÉTAIL'))[1]"/>

                        <div class="text-center page-header">
                            <h3>
                                <strong>Statistiques ventes — du
                                    <span t-esc="doc.date_start_period1.strftime('%d/%m/%Y')"/>
                                    au
                                    <span t-esc="doc.date_end_period1.strftime('%d/%m/%Y')"/>
                                </strong>
                            </h3>
                            <h4>
                                Groupé par <t t-esc="lbl_group"/>
                                <t t-if="doc.partner_ids">
                                    —
                                    <t t-foreach="doc.partner_ids[:3]" t-as="p">
                                        <span t-esc="p.name"/>
                                        <t t-if="not p_last">, </t>
                                    </t>
                                    <t t-if="len(doc.partner_ids) > 3">...</t>
                                </t>
                            </h4>
                            <h4>
                                <strong>Société(s):</strong>
                                <span t-esc="', '.join(doc.company_ids.mapped('name'))"/>
                            </h4>
                        </div>

                        <!-- Données -->
                        <t t-set="sale_data" t-value="doc.get_sale_data()"/>

                        <t t-set="grand_total_p1_qty" t-value="0"/>
                        <t t-set="grand_total_p1_ca" t-value="0.0"/>
                        <t t-set="grand_total_p1_ca_ttc" t-value="0.0"/>
                        <t t-set="grand_total_p1_margin" t-value="0.0"/>
                        <t t-set="grand_total_p2_qty" t-value="0"/>
                        <t t-set="grand_total_p2_ca" t-value="0.0"/>
                        <t t-set="grand_total_p2_ca_ttc" t-value="0.0"/>
                        <t t-set="grand_total_p2_margin" t-value="0.0"/>

                        <t t-foreach="sale_data.items()" t-as="grp_item">
                            <t t-set="grp_key"  t-value="grp_item[0]"/>
                            <t t-set="grp_data" t-value="grp_item[1]"/>

                            <div class="group-title">
                                <t t-esc="lbl_group"/>&#160;&#160;<t t-esc="grp_data['group_name']"/>
                            </div>

                            <table class="stat-table">
                                <thead>
                                    <tr>
                                        <th rowspan="2" style="width: 14%;"><t t-esc="lbl_item"/></th>
                                        <th colspan="5" class="col-period1">Période 1</th>
                                        <t t-if="doc.report_mode == 'comparison'">
                                            <th colspan="5" class="col-period2">Période 2</th>
                                            <th colspan="4" class="col-progress">Progression</th>
                                            <th colspan="3" class="col-progress-pct">% Progression</th>
                                        </t>
                                    </tr>
                                    <tr>
                                        <th class="col-period1">Qté</th>
                                        <th class="col-period1">CA HT</th>
                                        <th class="col-period1">CA TTC</th>
                                        <th class="col-period1">Marge</th>
                                        <th class="col-period1">Mge %</th>
                                        <t t-if="doc.report_mode == 'comparison'">
                                            <th class="col-period2">Qté</th>
                                            <th class="col-period2">CA HT</th>
                                            <th class="col-period2">CA TTC</th>
                                            <th class="col-period2">Marge</th>
                                            <th class="col-period2">Mge %</th>
                                            <th class="col-progress">Qté</th>
                                            <th class="col-progress">CA</th>
                                            <th class="col-progress">Marge</th>
                                            <th class="col-progress">Mge %</th>
                                            <th class="col-progress-pct">Qté</th>
                                            <th class="col-progress-pct">CA</th>
                                            <th class="col-progress-pct">Marge</th>
                                        </t>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="sorted(grp_data['items'].values(), key=lambda x: x['name'])"
                                       t-as="item">
                                        <tr>
                                            <td class="text-left">
                                                <t t-if="item['ref']">
                                                    <span t-esc="item['ref']"/> —
                                                </t>
                                                <span t-esc="item['name']"/>
                                            </td>
                                            <td class="text-right"><span t-esc="'%g' % round(item['qty_p1'], 3)"/></td>
                                            <td class="text-right"><span t-esc="'{:,.2f}'.format(item['ca_p1']).replace(',', ' ')"/></td>
                                            <td class="text-right"><span t-esc="'{:,.2f}'.format(item['ca_ttc_p1']).replace(',', ' ')"/></td>
                                            <td class="text-right"><span t-esc="'{:,.2f}'.format(item['margin_p1']).replace(',', ' ')"/></td>
                                            <td class="text-right"><span t-esc="'%.2f' % item['margin_pct_p1']"/></td>
                                            <t t-if="doc.report_mode == 'comparison'">
                                                <td class="text-right"><span t-esc="'%g' % round(item['qty_p2'], 3)"/></td>
                                                <td class="text-right"><span t-esc="'{:,.2f}'.format(item['ca_p2']).replace(',', ' ')"/></td>
                                                <td class="text-right"><span t-esc="'{:,.2f}'.format(item['ca_ttc_p2']).replace(',', ' ')"/></td>
                                                <td class="text-right"><span t-esc="'{:,.2f}'.format(item['margin_p2']).replace(',', ' ')"/></td>
                                                <td class="text-right"><span t-esc="'%.2f' % item['margin_pct_p2']"/></td>
                                                <td class="text-right"><span t-esc="'%g' % round(item['prog_qty'], 3)"/></td>
                                                <td class="text-right"><span t-esc="'{:,.2f}'.format(item['prog_ca']).replace(',', ' ')"/></td>
                                                <td class="text-right"><span t-esc="'{:,.2f}'.format(item['prog_margin']).replace(',', ' ')"/></td>
                                                <td class="text-right">0.00</td>
                                                <td class="text-right"><span t-esc="'%.2f' % ((item['prog_qty'] / item['qty_p1'] * 100) if item['qty_p1'] else 0)"/></td>
                                                <td class="text-right"><span t-esc="'%.2f' % item['prog_ca_pct']"/></td>
                                                <td class="text-right"><span t-esc="'%.2f' % item['prog_margin_pct']"/></td>
                                            </t>
                                        </tr>
                                    </t>

                                    <!-- Sous-total groupe -->
                                    <tr class="total-row">
                                        <td class="text-left"><strong>Sous-total</strong></td>
                                        <td class="text-right"><strong><span t-esc="'%g' % round(grp_data['total_p1_qty'], 3)"/></strong></td>
                                        <td class="text-right"><strong><span t-esc="'{:,.2f}'.format(grp_data['total_p1_ca']).replace(',', ' ')"/></strong></td>
                                        <td class="text-right"><strong><span t-esc="'{:,.2f}'.format(grp_data['total_p1_ca_ttc']).replace(',', ' ')"/></strong></td>
                                        <td class="text-right"><strong><span t-esc="'{:,.2f}'.format(grp_data['total_p1_margin']).replace(',', ' ')"/></strong></td>
                                        <td class="text-right"><strong><span t-esc="'%.2f' % grp_data['total_p1_margin_pct']"/></strong></td>
                                        <t t-if="doc.report_mode == 'comparison'">
                                            <td class="text-right"><strong><span t-esc="'%g' % round(grp_data['total_p2_qty'], 3)"/></strong></td>
                                            <td class="text-right"><strong><span t-esc="'{:,.2f}'.format(grp_data['total_p2_ca']).replace(',', ' ')"/></strong></td>
                                            <td class="text-right"><strong><span t-esc="'{:,.2f}'.format(grp_data['total_p2_ca_ttc']).replace(',', ' ')"/></strong></td>
                                            <td class="text-right"><strong><span t-esc="'{:,.2f}'.format(grp_data['total_p2_margin']).replace(',', ' ')"/></strong></td>
                                            <td class="text-right"><strong><span t-esc="'%.2f' % grp_data['total_p2_margin_pct']"/></strong></td>
                                            <td class="text-right"><strong><span t-esc="'%g' % round(grp_data['total_prog_qty'], 3)"/></strong></td>
                                            <td class="text-right"><strong><span t-esc="'{:,.2f}'.format(grp_data['total_prog_ca']).replace(',', ' ')"/></strong></td>
                                            <td class="text-right"><strong><span t-esc="'{:,.2f}'.format(grp_data['total_prog_margin']).replace(',', ' ')"/></strong></td>
                                            <td class="text-right"><strong>0.00</strong></td>
                                            <td class="text-right"><strong><span t-esc="'%.2f' % ((grp_data['total_prog_qty'] / grp_data['total_p1_qty'] * 100) if grp_data['total_p1_qty'] else 0)"/></strong></td>
                                            <td class="text-right"><strong><span t-esc="'%.2f' % grp_data['total_prog_ca_pct']"/></strong></td>
                                            <td class="text-right"><strong>0.00</strong></td>
                                        </t>
                                    </tr>
                                </tbody>
                            </table>

                            <t t-set="grand_total_p1_qty"    t-value="grand_total_p1_qty     + grp_data['total_p1_qty']"/>
                            <t t-set="grand_total_p1_ca"     t-value="grand_total_p1_ca      + grp_data['total_p1_ca']"/>
                            <t t-set="grand_total_p1_ca_ttc" t-value="grand_total_p1_ca_ttc  + grp_data['total_p1_ca_ttc']"/>
                            <t t-set="grand_total_p1_margin" t-value="grand_total_p1_margin  + grp_data['total_p1_margin']"/>
                            <t t-set="grand_total_p2_qty"    t-value="grand_total_p2_qty     + grp_data['total_p2_qty']"/>
                            <t t-set="grand_total_p2_ca"     t-value="grand_total_p2_ca      + grp_data['total_p2_ca']"/>
                            <t t-set="grand_total_p2_ca_ttc" t-value="grand_total_p2_ca_ttc  + grp_data['total_p2_ca_ttc']"/>
                            <t t-set="grand_total_p2_margin" t-value="grand_total_p2_margin  + grp_data['total_p2_margin']"/>
                        </t>

                        <!-- Total général -->
                        <table class="stat-table" style="margin-top: 20px;">
                            <tr class="grand-total-row">
                                <td style="width: 14%;" class="text-left"><strong>TOTAL GÉNÉRAL</strong></td>
                                <td class="text-right"><strong><span t-esc="'%g' % round(grand_total_p1_qty, 3)"/></strong></td>
                                <td class="text-right"><strong><span t-esc="'{:,.2f}'.format(grand_total_p1_ca).replace(',', ' ')"/></strong></td>
                                <td class="text-right"><strong><span t-esc="'{:,.2f}'.format(grand_total_p1_ca_ttc).replace(',', ' ')"/></strong></td>
                                <td class="text-right"><strong><span t-esc="'{:,.2f}'.format(grand_total_p1_margin).replace(',', ' ')"/></strong></td>
                                <td class="text-right"><strong><span t-esc="'%.2f' % ((grand_total_p1_margin / grand_total_p1_ca * 100) if grand_total_p1_ca else 0)"/></strong></td>
                                <t t-if="doc.report_mode == 'comparison'">
                                    <td class="text-right"><strong><span t-esc="'%g' % round(grand_total_p2_qty, 3)"/></strong></td>
                                    <td class="text-right"><strong><span t-esc="'{:,.2f}'.format(grand_total_p2_ca).replace(',', ' ')"/></strong></td>
                                    <td class="text-right"><strong><span t-esc="'{:,.2f}'.format(grand_total_p2_ca_ttc).replace(',', ' ')"/></strong></td>
                                    <td class="text-right"><strong><span t-esc="'{:,.2f}'.format(grand_total_p2_margin).replace(',', ' ')"/></strong></td>
                                    <td class="text-right"><strong><span t-esc="'%.2f' % ((grand_total_p2_margin / grand_total_p2_ca * 100) if grand_total_p2_ca else 0)"/></strong></td>
                                    <td class="text-right"><strong><span t-esc="'%g' % round(grand_total_p2_qty - grand_total_p1_qty, 3)"/></strong></td>
                                    <td class="text-right"><strong><span t-esc="'{:,.2f}'.format(grand_total_p2_ca - grand_total_p1_ca).replace(',', ' ')"/></strong></td>
                                    <td class="text-right"><strong><span t-esc="'{:,.2f}'.format(grand_total_p2_margin - grand_total_p1_margin).replace(',', ' ')"/></strong></td>
                                    <td class="text-right"><strong>0.00</strong></td>
                                    <td class="text-right"><strong><span t-esc="'%.2f' % (((grand_total_p2_qty - grand_total_p1_qty) / grand_total_p1_qty * 100) if grand_total_p1_qty else 0)"/></strong></td>
                                    <td class="text-right"><strong><span t-esc="'%.2f' % (((grand_total_p2_ca - grand_total_p1_ca) / grand_total_p1_ca * 100) if grand_total_p1_ca else 0)"/></strong></td>
                                    <td class="text-right"><strong><span t-esc="'%.2f' % (((grand_total_p2_margin - grand_total_p1_margin) / grand_total_p1_margin * 100) if grand_total_p1_margin else 0)"/></strong></td>
                                </t>
                            </tr>
                        </table>
                    </main>
                </div>
            </t>
        </t>
    </template>

    <!-- Action du rapport PDF -->
    <record id="action_report_sale_statistics" model="ir.actions.report">
        <field name="name">Statistiques de Ventes</field>
        <field name="model">sale.stat.report.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_reports.report_sale_statistics_document</field>
        <field name="report_file">custom_reports.report_sale_statistics_document</field>
        <field name="binding_model_id" ref="model_sale_stat_report_wizard"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">'Stats_Ventes_%s_%s' % (object.date_start_period1.strftime('%Y%m%d'), object.date_end_period2.strftime('%d%m%Y')) if object.report_mode == 'comparison' else 'Stats_Ventes_%s_%s' % (object.date_start_period1.strftime('%Y%m%d'), object.date_end_period1.strftime('%d%m%Y'))</field>
        <field name="paperformat_id" ref="base.paperformat_euro"/>
    </record>

</odoo>
