<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Paper format A4 landscape for the wide encaissements table -->
        <record id="paperformat_recap_caisses" model="report.paperformat">
            <field name="name">Récapitulatif Caisses Portrait A4</field>
            <field name="default" eval="False"/>
            <field name="format">A4</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">10</field>
            <field name="margin_bottom">10</field>
            <field name="margin_left">10</field>
            <field name="margin_right">10</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">10</field>
        </record>

        <!-- Report action -->
        <record id="action_report_recap_caisses" model="ir.actions.report">
            <field name="name">Récapitulatif des Caisses</field>
            <field name="model">recap.caisses.wizard</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">custom_reports.report_recap_caisses</field>
            <field name="report_file">custom_reports.report_recap_caisses</field>
            <field name="paperformat_id" ref="paperformat_recap_caisses"/>
            <field name="binding_model_id" eval="False"/>
        </record>
    </data>
</odoo>
