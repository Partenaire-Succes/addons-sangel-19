<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_achat_produit_document">
        <t t-call="web.external_layout">
            <t t-set="o" t-value="doc"/>
            <div class="page">
                <style>
                    .page { font-family: Arial, sans-serif; font-size: 8pt; }
                    .header-section { margin-bottom: 12px; border-bottom: 2px solid #000; padding-bottom: 6px; }
                    .company-name { font-size: 12pt; font-weight: bold; text-transform: uppercase; }
                    .date-range { text-align: right; font-weight: bold; font-size: 9pt; }
                    .report-title {
                        text-align: center; font-size: 11pt; font-weight: bold;
                        margin: 10px 0; padding: 6px;
                        background-color: #1A5276; color: #fff;
                    }
                    /* Table principale */
                    table.main { width: 100%; border-collapse: collapse; font-size: 7.5pt; }
                    table.main th {
                        background-color: #1A5276; color: #fff;
                        border: 1px solid #888; padding: 4px 3px;
                        font-weight: bold; text-align: center;
                    }
                    table.main td { border: 1px solid #ccc; padding: 2px 3px; vertical-align: middle; }
                    /* Ligne produit header */
                    tr.prod-hdr td {
                        background-color: #1A5276; color: #fff;
                        font-weight: bold; font-size: 8pt;
                        border: 1px solid #aaa;
                    }
                    /* Sous-lignes */
                    tr.sl-both   td { background-color: #EBF5FB; }
                    tr.sl-both-alt td { background-color: #FFFFFF; }
                    tr.sl-po     td { background-color: #D5D8DC; }
                    tr.sl-rec    td { background-color: #FAD7A0; }
                    /* Séparateur entre produits */
                    tr.spacer td { background-color: #fff; border: none; height: 4px; }
                    /* Total */
                    tr.total-row td {
                        background-color: #1A5276; color: #fff;
                        font-weight: bold; font-size: 9pt;
                        border: 1px solid #aaa;
                    }
                    .r { text-align: right; }
                    .c { text-align: center; }
                    .indent { padding-left: 8px; color: #555; }
                    .footer-info { margin-top: 12px; font-size: 7pt; }
                </style>

                <!-- En-tête -->
                <div class="header-section">
                    <div class="row">
                        <div class="col-8">
                            <div class="company-name"><span t-field="o.company_id.name"/></div>
                        </div>
                        <div class="col-4">
                            <div class="date-range">
                                Du <span t-esc="o.date_debut.strftime('%d/%m/%Y')"/>
                                au <span t-esc="o.date_fin.strftime('%d/%m/%Y')"/>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="report-title">COMMANDES &amp; RÉCEPTIONS PAR PRODUIT</div>

                <t t-set="data" t-value="o._get_report_data()"/>
                <t t-set="tot_qty_cmd"  t-value="0.0"/>
                <t t-set="tot_mnt_cmd"  t-value="0.0"/>
                <t t-set="tot_qty_rec"  t-value="0.0"/>
                <t t-set="tot_mnt_rec"  t-value="0.0"/>

                <table class="main">
                    <thead>
                        <tr>
                            <th style="width:6%;">Réf.</th>
                            <th style="width:16%;">Désignation / Réf. Commande</th>
                            <th style="width:8%;">Date Cmd</th>
                            <th style="width:7%;">Qté Cmdée</th>
                            <th style="width:8%;">Prix Unit Cmd</th>
                            <th style="width:9%;">Montant Cmdé</th>
                            <th style="width:10%;">Réf. Réception</th>
                            <th style="width:8%;">Date Réc.</th>
                            <th style="width:7%;">Qté Réc.</th>
                            <th style="width:8%;">Prix Unit Réc.</th>
                            <th style="width:9%;">Montant Réc.</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="data" t-as="prod">
                            <t t-set="tot_qty_cmd" t-value="tot_qty_cmd + prod['qty_commandee']"/>
                            <t t-set="tot_mnt_cmd" t-value="tot_mnt_cmd + prod['montant_commande']"/>
                            <t t-set="tot_qty_rec" t-value="tot_qty_rec + prod['qty_receptionnee']"/>
                            <t t-set="tot_mnt_rec" t-value="tot_mnt_rec + prod['montant_reception']"/>

                            <!-- Ligne produit -->
                            <tr class="prod-hdr">
                                <td><span t-esc="prod['ref']"/></td>
                                <td><span t-esc="prod['name']"/></td>
                                <td class="c">
                                    <span t-esc="str(prod['nb_commandes']) + ' cmde(s)'"/>
                                </td>
                                <td class="r">
                                    <span t-esc="'{:,.2f}'.format(prod['qty_commandee']).replace(',', ' ')"/>
                                </td>
                                <td></td>
                                <td class="r">
                                    <span t-esc="'{:,.0f}'.format(prod['montant_commande']).replace(',', ' ')"/>
                                </td>
                                <td class="c">
                                    <span t-esc="str(prod['nb_receptions']) + ' réc.'"/>
                                </td>
                                <td></td>
                                <td class="r">
                                    <span t-esc="'{:,.2f}'.format(prod['qty_receptionnee']).replace(',', ' ')"/>
                                </td>
                                <td></td>
                                <td class="r">
                                    <span t-esc="'{:,.0f}'.format(prod['montant_reception']).replace(',', ' ')"/>
                                </td>
                            </tr>

                            <!-- Sous-lignes -->
                            <t t-foreach="prod['sub_lines']" t-as="sl">
                                <t t-set="has_po"  t-value="bool(sl['po_ref'])"/>
                                <t t-set="has_rec" t-value="bool(sl['reception_ref'])"/>
                                <t t-set="sl_class"
                                   t-value="'sl-both' if (has_po and has_rec and sl_odd) else 'sl-both-alt' if (has_po and has_rec) else 'sl-po' if has_po else 'sl-rec'"/>
                                <tr t-att-class="sl_class">
                                    <td></td>
                                    <td class="indent">
                                        <span t-esc="sl['po_ref']"/>
                                    </td>
                                    <td class="c">
                                        <span t-esc="sl['date_commande'].strftime('%d/%m/%Y') if sl['date_commande'] else ''"/>
                                    </td>
                                    <td class="r">
                                        <span t-esc="'{:,.2f}'.format(sl['qty_commandee']).replace(',', ' ') if sl['qty_commandee'] else ''"/>
                                    </td>
                                    <td class="r">
                                        <span t-esc="'{:,.2f}'.format(sl['prix_commande']).replace(',', ' ') if sl['prix_commande'] else ''"/>
                                    </td>
                                    <td class="r">
                                        <span t-esc="'{:,.0f}'.format(sl['montant_commande']).replace(',', ' ') if sl['montant_commande'] else ''"/>
                                    </td>
                                    <td class="indent">
                                        <span t-esc="sl['reception_ref']"/>
                                    </td>
                                    <td class="c">
                                        <span t-esc="sl['date_reception'].strftime('%d/%m/%Y') if sl['date_reception'] else ''"/>
                                    </td>
                                    <td class="r">
                                        <span t-esc="'{:,.2f}'.format(sl['qty_receptionnee']).replace(',', ' ') if sl['qty_receptionnee'] else ''"/>
                                    </td>
                                    <td class="r">
                                        <span t-esc="'{:,.2f}'.format(sl['prix_reception']).replace(',', ' ') if sl['prix_reception'] else ''"/>
                                    </td>
                                    <td class="r">
                                        <span t-esc="'{:,.0f}'.format(sl['montant_reception']).replace(',', ' ') if sl['montant_reception'] else ''"/>
                                    </td>
                                </tr>
                            </t>

                            <!-- Ligne de séparation entre produits -->
                            <tr class="spacer"><td colspan="11"></td></tr>
                        </t>

                        <!-- Total général -->
                        <tr class="total-row">
                            <td colspan="2">TOTAL GÉNÉRAL</td>
                            <td></td>
                            <td class="r">
                                <span t-esc="'{:,.2f}'.format(tot_qty_cmd).replace(',', ' ')"/>
                            </td>
                            <td></td>
                            <td class="r">
                                <span t-esc="'{:,.0f}'.format(tot_mnt_cmd).replace(',', ' ')"/>
                            </td>
                            <td></td>
                            <td></td>
                            <td class="r">
                                <span t-esc="'{:,.2f}'.format(tot_qty_rec).replace(',', ' ')"/>
                            </td>
                            <td></td>
                            <td class="r">
                                <span t-esc="'{:,.0f}'.format(tot_mnt_rec).replace(',', ' ')"/>
                            </td>
                        </tr>
                    </tbody>
                </table>

                <!-- Légende -->
                <div style="margin-top: 8px; font-size: 7pt;">
                    <span style="background:#EBF5FB; border:1px solid #ccc; padding:1px 6px;">■</span> Commandé + Réceptionné&#160;&#160;
                    <span style="background:#D5D8DC; border:1px solid #ccc; padding:1px 6px;">■</span> Commandé sans réception&#160;&#160;
                    <span style="background:#FAD7A0; border:1px solid #ccc; padding:1px 6px;">■</span> Réception directe
                </div>

                <div class="footer-info">
                    <div class="row">
                        <div class="col-6">
                            <strong>Nb produits :</strong> <span t-esc="len(data)"/>
                        </div>
                        <div class="col-6 text-right">
                            <strong>Imprimé le :</strong>
                            <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y %H:%M')"/>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <template id="report_achat_produit">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="custom_reports.report_achat_produit_document"/>
            </t>
        </t>
    </template>

    <record id="action_report_achat_produit" model="ir.actions.report">
        <field name="name">Rapport Commandes &amp; Réceptions par Produit</field>
        <field name="model">achat.produit.report.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_reports.report_achat_produit</field>
        <field name="report_file">custom_reports.report_achat_produit</field>
        <field name="binding_model_id" ref="model_achat_produit_report_wizard"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="base.paperformat_euro"/>
        <field name="print_report_name">
            'Commandes_Receptions_Produits_%s_%s' % (
                object.date_debut.strftime('%d%m%Y'),
                object.date_fin.strftime('%d%m%Y')
            )
        </field>
    </record>
</odoo>
