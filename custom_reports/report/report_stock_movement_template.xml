<odoo>
    <data>
        <!-- Template du rapport PDF -->
        <template id="report_stock_movement_document">
            <t t-call="web.external_layout">
                <t t-foreach="docs" t-as="doc">
                    <t t-set="doc" t-value="doc.with_context(lang=doc.company_id.partner_id.lang)"/>
                    <div class="page">
                        <main>
                            <div class="row">
                                <div class="col-8">
                                    <h2>Stock et Mouvements</h2>
                                </div>
                                <div class="col-4 text-end">
                                    <p>
                                        <strong>Date:</strong>
                                        <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y %H:%M')"/>
                                    </p>
                                </div>
                            </div>

                            <p>
                                <em>
                                    <span t-field="doc.location_id.complete_name"/>
                                    — Stock au
                                    <span t-field="doc.date_from"/>
                                    comparé au
                                    <span t-field="doc.date_to"/>
                                </em>
                            </p>

                            <t t-set="lines" t-value="doc._get_report_lines()"/>

                            <table class="table table-sm table-bordered mt-3"
                                   style="table-layout:fixed; width:100%;">
                                <colgroup>
                                    <col style="width:9%;"/>
                                    <col style="width:18%;"/>
                                    <col style="width:12%;"/>
                                    <col style="width:9%;"/>
                                    <col style="width:9%;"/>
                                    <col style="width:9%;"/>
                                    <col style="width:9%;"/>
                                    <col style="width:9%;"/>
                                    <col style="width:8%;"/>
                                    <col style="width:8%;"/>
                                </colgroup>
                                <thead>
                                    <tr style="background-color:#f0f0f0;">
                                        <th>Code Article</th>
                                        <th>Nom produit</th>
                                        <th class="text-center">Date dernier inventaire</th>
                                        <th class="text-end">Coût</th>
                                        <th class="text-end">Stock <span t-field="doc.date_from"/></th>
                                        <th class="text-end">Stock <span t-field="doc.date_to"/></th>
                                        <th class="text-end">Entrée</th>
                                        <th class="text-end">Sortie</th>
                                        <th class="text-end">Mvts (Entrée-Sortie)</th>
                                        <th class="text-end">Ecart cumulé</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="lines" t-as="line">
                                        <tr>
                                            <td><span t-esc="line['code_article']"/></td>
                                            <td><span t-esc="line['name']"/></td>
                                            <td class="text-center">
                                                <span t-if="line['last_inventory_date']"
                                                      t-esc="line['last_inventory_date'].strftime('%d/%m/%Y %H:%M')"/>
                                                <span t-else="">—</span>
                                            </td>
                                            <td class="text-end">
                                                <span t-esc="'%.2f' % line['cost']"/>
                                            </td>
                                            <td class="text-end">
                                                <span t-esc="'%.2f' % line['stock_a']"/>
                                            </td>
                                            <td class="text-end">
                                                <span t-esc="'%.2f' % line['stock_b']"/>
                                            </td>
                                            <td class="text-end">
                                                <span t-esc="'%.2f' % line['entree']"/>
                                            </td>
                                            <td class="text-end">
                                                <span t-esc="'%.2f' % line['sortie']"/>
                                            </td>
                                            <td class="text-end">
                                                <span t-esc="'%.2f' % line['movement']"/>
                                            </td>
                                            <td class="text-end">
                                                <span t-esc="'%.2f' % line['ecart_cumule']"/>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </main>
                    </div>
                </t>
            </t>
        </template>

        <!-- Définition du rapport -->
        <record id="action_report_stock_movement" model="ir.actions.report">
            <field name="name">Stock et Mouvements</field>
            <field name="model">stock.movement.report.wizard</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">custom_reports.report_stock_movement_document</field>
            <field name="report_file">custom_reports.report_stock_movement_document</field>
            <field name="binding_model_id" ref="model_stock_movement_report_wizard"/>
            <field name="binding_type">report</field>
            <field name="print_report_name">'Stock_Mouvements_%s_%s' % (object.date_from.strftime('%Y%m%d_%Hh%M'), object.date_to.strftime('%Y%m%d_%Hh%M'))</field>
        </record>
    </data>
</odoo>
