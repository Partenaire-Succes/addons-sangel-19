<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Vue formulaire du wizard -->
    <record id="view_retours_consolides_report_wizard_form" model="ir.ui.view">
        <field name="name">retours.consolides.report.wizard.form</field>
        <field name="model">retours.consolides.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Rapport Consolidé Retours et Réceptions">
                <sheet>
                    <div class="oe_title">
                        <h1>Rapport Consolidé</h1>
                        <h3 class="text-muted">
                            Réceptions directes · Retours fournisseurs · Retours inventaires
                        </h3>
                    </div>
                    <group>
                        <group string="Contenu du rapport">
                            <field name="type_rapport" widget="radio"/>
                        </group>
                        <group string="Société">
                            <field name="company_id"
                                   options="{'no_create': True}"
                                   groups="base.group_multi_company"
                                   readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="Période">
                            <field name="date_from" required="1"/>
                            <field name="date_to" required="1"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_print_report"
                            string="Imprimer PDF"
                            type="object"
                            class="btn-primary"
                            icon="fa-print"/>
                    <button string="Annuler"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action du wizard -->
    <record id="action_retours_consolides_report_wizard" model="ir.actions.act_window">
        <field name="name">Rapport Consolidé Retours</field>
        <field name="res_model">retours.consolides.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="view_retours_consolides_report_wizard_form"/>
    </record>

    <!-- Menu : Analyse et Rapports > Stock et Inventaire -->
