<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_livraison_report_wizard_form" model="ir.ui.view">
        <field name="name">livraison.report.wizard.form</field>
        <field name="model">livraison.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Rapport Livraisons">
                <sheet>
                    <div class="oe_title">
                        <h1>Récapitulatif Livraisons</h1>
                    </div>
                    <group>
                        <group string="Période">
                            <field name="date_debut" widget="date" required="1"/>
                            <field name="date_fin" widget="date" required="1"/>
                        </group>
                        <group string="Filtres">
                            <field name="company_id"
                                   options="{'no_create': True, 'no_open': True}"
                                   readonly="1"/>
                            <field name="client_ids"
                                   widget="many2many_tags"
                                   options="{'no_create': True}"
                                   placeholder="Tous les clients"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_print_report"
                            string="Imprimer PDF"
                            type="object"
                            class="btn-primary"
                            icon="fa-print"/>
                    <button name="action_export_excel"
                            string="Télécharger Excel"
                            type="object"
                            class="btn-success"
                            icon="fa-file-excel-o"/>
                    <button string="Annuler"
                            class="btn-secondary"
                            special="cancel"
                            icon="fa-times"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_livraison_report_wizard" model="ir.actions.act_window">
        <field name="name">Rapport Livraisons</field>
        <field name="res_model">livraison.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="view_livraison_report_wizard_form"/>
    </record>

    <menuitem id="menu_livraison_report"
              name="Rapports Livraisons"
              parent="custom_reports.menu_reports_stock"
              action="action_livraison_report_wizard"
              sequence="10"/>
</odoo>
