<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_retour_produit_report_wizard_form" model="ir.ui.view">
        <field name="name">retour.produit.report.wizard.form</field>
        <field name="model">retour.produit.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Retours Fournisseurs par Produit">
                <sheet>
                    <div class="oe_title">
                        <h1>Retours Fournisseurs par Produit</h1>
                    </div>
                    <group>
                        <group string="Période">
                            <field name="date_debut" widget="date" required="1"/>
                            <field name="date_fin" widget="date" required="1"/>
                        </group>
                        <group string="Filtres">
                            <field name="company_ids"
                                   widget="many2many_tags"
                                   options="{'no_create': True}"/>
                            <field name="fournisseur_ids"
                                   widget="many2many_tags"
                                   options="{'no_create': True}"
                                   placeholder="Tous les fournisseurs"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_print_report"
                            string="Imprimer PDF"
                            type="object"
                            class="btn-primary"
                            icon="fa-print"/>
                    <button name="action_export_excel"
                            string="Télécharger Excel"
                            type="object"
                            class="btn-success"
                            icon="fa-file-excel-o"/>
                    <button string="Annuler"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_retour_produit_report_wizard" model="ir.actions.act_window">
        <field name="name">Retours Fournisseurs par Produit</field>
        <field name="res_model">retour.produit.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_retour_produit_report"
              name="Retours Fournisseurs Produits"
              parent="custom_reports.menu_reports_purchase"
              action="action_retour_produit_report_wizard"
              sequence="26"/>
</odoo>
