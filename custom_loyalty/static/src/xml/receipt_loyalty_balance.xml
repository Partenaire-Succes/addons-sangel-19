<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="custom_loyalty.OrderReceiptLoyaltyBalance"
       t-inherit="point_of_sale.OrderReceipt"
       t-inherit-mode="extension">

        <!--
            Section fidélité en français, avant before-footer.
            La section native Odoo en anglais (div.loyalty) est masquée via CSS.

            Valeurs utilisées (capturées dans export_as_JSON, fiables à l'impression) :
              order.initial_loyalty_balance → solde avant cette transaction
              order.initial_loyalty_won     → points gagnés (calculés à export)
              order.initial_loyalty_spent   → points utilisés pour une récompense
              order.get_rendu_monnaie()     → monnaie rendue créditée en points
        -->
        <xpath expr="//div[hasclass('before-footer')]" position="before">
            <t t-if="order.partner_id">

                <!--
                    Lire les valeurs capturées à l'export (état complet garanti).
                    Fallback : getLoyaltyPoints() si les valeurs ne sont pas encore capturées
                    (cas d'une réimpression immédiate avant tout export).
                -->
                <t t-set="_liveStats"
                   t-value="(order.getLoyaltyPoints and order.getLoyaltyPoints()) or []"/>
                <t t-set="_liveStat"
                   t-value="_liveStats.find(s => s.program and s.program.program_type === 'loyalty')"/>

                <!-- Points capturés à l'export (source principale) -->
                <t t-set="ancienSolde"
                   t-value="order.initial_loyalty_balance != null
                            ? order.initial_loyalty_balance
                            : (_liveStat ? _liveStat.points.balance : 0)"/>

                <t t-set="wonPts"
                   t-value="order.initial_loyalty_won != null
                            ? order.initial_loyalty_won
                            : (_liveStat ? _liveStat.points.won : 0)"/>

                <t t-set="spentPts"
                   t-value="order.initial_loyalty_spent != null
                            ? order.initial_loyalty_spent
                            : (_liveStat ? _liveStat.points.spent : 0)"/>

                <!-- Points sur monnaie rendue (1 FCFA = 1 pt) -->
                <t t-set="renduPts"
                   t-value="Math.floor(order.get_rendu_monnaie ? order.get_rendu_monnaie() : 0)"/>

                <!-- Solde cumulé = ancien + gagné - utilisé + rendu -->
                <t t-set="nouveauSolde"
                   t-value="ancienSolde + wonPts - spentPts + renduPts"/>

                <!--
                    Affiche la section si le client a des points ou a eu une activité
                    (gagné, utilisé, rendu) sur cette transaction.
                -->
                <t t-if="ancienSolde > 0 or wonPts > 0 or spentPts > 0 or renduPts > 0">

                    <div class="pos-receipt-loyalty-balance text-start pt-2"
                         style="font-size: 90%; border-top: 1px dashed #777; margin-top: 8px; padding-top: 8px;">

                        <div class="fw-bold mb-1" style="font-size: 102%; letter-spacing: 0.02em;">
                            Fidélité
                        </div>

                        <div class="d-flex justify-content-between">
                            <span>Ancien solde :</span>
                            <span class="font-monospace">
                                <t t-esc="ancienSolde"/> pts
                            </span>
                        </div>

                        <!-- Points gagnés : affiché seulement si > 0 -->
                        <t t-if="wonPts > 0">
                            <div class="d-flex justify-content-between" style="color: #1a7a1a;">
                                <span>Points gagnés :</span>
                                <span class="font-monospace fw-bold">
                                    +<t t-esc="wonPts"/> pts
                                </span>
                            </div>
                        </t>

                        <!-- Points utilisés : affiché si le client a utilisé une récompense -->
                        <t t-if="spentPts > 0">
                            <div class="d-flex justify-content-between text-danger">
                                <span>Points utilisés :</span>
                                <span class="font-monospace fw-bold">
                                    -<t t-esc="spentPts"/> pts
                                </span>
                            </div>
                        </t>

                        <!-- Monnaie rendue → points (1 FCFA = 1 pt) -->
                        <t t-if="renduPts > 0">
                            <div class="d-flex justify-content-between" style="color: #1a5276;">
                                <span>Monnaie rendue :</span>
                                <span class="font-monospace fw-bold">
                                    +<t t-esc="renduPts"/> pts
                                </span>
                            </div>
                        </t>

                        <div class="d-flex justify-content-between fw-bold"
                             style="border-top: 1px solid #ccc; margin-top: 4px; padding-top: 4px;">
                            <span>Solde cumulé :</span>
                            <span class="font-monospace">
                                <t t-esc="nouveauSolde"/> pts
                            </span>
                        </div>

                    </div>
                </t>

            </t>
        </xpath>
    </t>
</templates>
