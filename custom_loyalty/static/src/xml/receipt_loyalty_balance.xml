<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="custom_loyalty.OrderReceiptLoyaltyBalance"
       t-inherit="point_of_sale.OrderReceipt"
       t-inherit-mode="extension">

        <!--
            Section fidélité en français, avant before-footer.
            La section native Odoo en anglais (div.loyalty) est masquée via CSS
            dans receipt_custom.css — approche plus robuste qu'un xpath sur
            un élément injecté par un autre module.

            ATTENTION double comptage :
            loyaltyCard.points (= balance) est déjà mis à jour avec les points
            gagnés de cette vente au moment où le ticket s'affiche.
            Formule correcte :
              ancien_solde = balance - won + spent
              nouveau_solde = balance  (valeur actuelle, pas balance + won)
        -->
        <xpath expr="//div[hasclass('before-footer')]" position="before">
            <t t-if="order.partner_id">

                <t t-set="loyaltyStats"
                   t-value="(order.getLoyaltyPoints and order.getLoyaltyPoints()) or []"/>
                <t t-set="loyaltyStat"
                   t-value="loyaltyStats.find(s => s.program and s.program.program_type === 'loyalty')"/>

                <!--
                    Affiche la section uniquement si le client a des points
                    ou a gagné/utilisé des points dans cette vente.
                -->
                <t t-if="loyaltyStat and (loyaltyStat.points.balance > 0 or loyaltyStat.points.won > 0 or loyaltyStat.points.spent > 0)">

                    <!-- Recalcul de l'ancien solde : balance est déjà mis à jour -->
                    <t t-set="ancienSolde"
                       t-value="loyaltyStat.points.balance - loyaltyStat.points.won + loyaltyStat.points.spent"/>

                    <!-- Points sur monnaie rendue (1 FCFA = 1 pt) — crédités côté serveur après paiement -->
                    <t t-set="renduPts"
                       t-value="Math.floor(order.get_rendu_monnaie ? order.get_rendu_monnaie() : 0)"/>

                    <!-- Solde cumulé = balance Odoo + points sur rendu monnaie -->
                    <t t-set="nouveauSolde"
                       t-value="loyaltyStat.points.balance + renduPts"/>

                    <div class="pos-receipt-loyalty-balance text-start pt-2"
                         style="font-size: 90%; border-top: 1px dashed #777; margin-top: 8px; padding-top: 8px;">

                        <div class="fw-bold mb-1" style="font-size: 102%; letter-spacing: 0.02em;">
                            Fidélité
                        </div>

                        <div class="d-flex justify-content-between">
                            <span>Ancien solde :</span>
                            <span class="font-monospace">
                                <t t-esc="ancienSolde"/> pts
                            </span>
                        </div>

                        <!-- Points gagnés : affiché seulement si > 0 -->
                        <t t-if="loyaltyStat.points.won > 0">
                            <div class="d-flex justify-content-between" style="color: #1a7a1a;">
                                <span>Points gagnés :</span>
                                <span class="font-monospace fw-bold">
                                    +<t t-esc="loyaltyStat.points.won"/> pts
                                </span>
                            </div>
                        </t>

                        <!-- Points utilisés : affiché seulement si le client a utilisé des points -->
                        <t t-if="loyaltyStat.points.spent > 0">
                            <div class="d-flex justify-content-between text-danger">
                                <span>Points utilisés :</span>
                                <span class="font-monospace">
                                    -<t t-esc="loyaltyStat.points.spent"/> pts
                                </span>
                            </div>
                        </t>

                        <!-- Monnaie rendue → points (1 FCFA = 1 pt) : affiché seulement si > 0 -->
                        <t t-if="renduPts > 0">
                            <div class="d-flex justify-content-between" style="color: #1a5276;">
                                <span>Monnaie rendue :</span>
                                <span class="font-monospace fw-bold">
                                    +<t t-esc="renduPts"/> pts
                                </span>
                            </div>
                        </t>

                        <div class="d-flex justify-content-between fw-bold">
                            <span>Solde cumulé :</span>
                            <span class="font-monospace">
                                <t t-esc="nouveauSolde"/> pts
                            </span>
                        </div>

                    </div>
                </t>

                <t t-else="">
                    <!--
                        Fallback : getLoyaltyPoints n'a pas de données pour ce programme.
                        Utilise la carte directement. N'affiche rien si le client n'a pas de points.
                    -->
                    <t t-set="loyaltyCards"
                       t-value="order.models and order.models['loyalty.card']"/>
                    <t t-set="partnerLoyaltyCard"
                       t-value="loyaltyCards and loyaltyCards.find(
                           card => card.partner_id and (
                               card.partner_id.id === order.partner_id.id or
                               card.partner_id === order.partner_id.id
                           )
                       )"/>
                    <t t-if="partnerLoyaltyCard and partnerLoyaltyCard.points > 0">
                        <div class="pos-receipt-loyalty-balance text-start pt-2"
                             style="font-size: 90%; border-top: 1px dashed #777; margin-top: 8px; padding-top: 8px;">
                            <div class="fw-bold mb-1" style="font-size: 102%;">
                                Fidélité
                            </div>
                            <div class="d-flex justify-content-between fw-bold">
                                <span>Solde :</span>
                                <span class="font-monospace">
                                    <t t-esc="partnerLoyaltyCard.points"/> pts
                                </span>
                            </div>
                        </div>
                    </t>
                </t>

            </t>
        </xpath>
    </t>
</templates>
