<odoo>
    <data>
        <record id="product_credit_food" model="product.product">
            <field name="name">Crédit Alimentaire</field>
            <field name="sale_ok">True</field>
            <field name="purchase_ok">False</field>
            <field name="invoice_policy">order</field>
            <field name="type">service</field>
            <field name="categ_id" ref="product.product_category_services"/>
            <field name="list_price">0.0</field>
            <field name="standard_price">0.0</field>
            <field name="description">Produit pour facturation des crédits alimentaires</field>
        </record>

        <record id="generation_credit_food" model="food.credit">
            <field name="partner_company_id" ref="base.main_partner"/>
            <field name="amount">0.0</field>
            <field name="state">draft</field>
            <field name="company_id" ref="base.main_company"/>
            <field name="responsible_id" ref="base.user_admin"/>
        </record>
    </data>
</odoo>
