<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_supplier_price_import_wizard_form" model="ir.ui.view">
        <field name="name">supplier.price.import.wizard.form</field>
        <field name="model">supplier.price.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Liste de Prix Fournisseurs">

                <header>
                    <button string="Confirmer l'import"
                            name="action_confirm"
                            type="object"
                            class="btn-success"
                            invisible="state != 'loaded'"/>
                </header>

                <group>
                    <group>
                        <field name="file" widget="binary" filename="file_name"/>
                        <field name="file_name" invisible="1"/>
                        <field name="company_id"/>
                        <field name="state" invisible="1"/>
                    </group>
                    <group>
                        <button string="Charger le fichier"
                                name="action_load_file"
                                type="object"
                                class="btn-primary"
                                invisible="state == 'done'"/>
                    </group>
                </group>

                <!-- Résumé colonnes attendues -->
                <div class="alert alert-info" invisible="state != 'draft'" role="alert">
                    <strong>Colonnes requises dans le fichier Excel :</strong>
                    <code>partner_id</code> (nom fournisseur) ·
                    <code>product_tmpl_id</code> (code interne produit) ·
                    <code>company_id</code> (nom société) ·
                    <code>price</code> (prix unitaire)
                </div>

                <notebook invisible="state == 'draft'">
                    <page string="Lignes importées">
                        <field name="line_ids" readonly="1">
                            <list decoration-success="action == 'create'"
                                  decoration-warning="action == 'update'"
                                  decoration-danger="action == 'not_found'">
                                <field name="partner_val" string="Fournisseur (Excel)"/>
                                <field name="partner_id" string="Fournisseur trouvé"/>
                                <field name="product_val" string="Code Produit (Excel)"/>
                                <field name="product_tmpl_id" string="Produit trouvé"/>
                                <field name="company_val" string="Société (Excel)"/>
                                <field name="company_res_id" string="Société trouvée"/>
                                <field name="price" string="Prix unitaire"/>
                                <field name="supplierinfo_id" string="Prix existant" optional="show"/>
                                <field name="action" string="Action"/>
                            </list>
                        </field>
                    </page>
                </notebook>

                <footer>
                    <button name="action_confirm"
                            type="object"
                            string="Confirmer"
                            class="btn-success"
                            invisible="state != 'loaded'"/>
                    <button string="Fermer" special="cancel"/>
                </footer>

            </form>
        </field>
    </record>

    <record id="action_supplier_price_import_wizard" model="ir.actions.act_window">
        <field name="name">Import Prix Fournisseurs</field>
        <field name="res_model">supplier.price.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>


</odoo>
