<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_physical_inventory_line_cleanup_wizard_form" model="ir.ui.view">
        <field name="name">physical.inventory.line.cleanup.wizard.form</field>
        <field name="model">physical.inventory.line.cleanup.wizard</field>
        <field name="arch" type="xml">
            <form string="Nettoyage des lignes d'inventaire orphelines">

                <header>
                    <button name="action_preview"
                            string="Analyser"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_delete"
                            string="Supprimer les lignes"
                            type="object" class="btn-danger"
                            confirm="Ces lignes d'inventaire orphelines (sans inventaire parent, quantité comptée à 0) vont être définitivement supprimées. Continuer ?"
                            invisible="state != 'preview' or count_found == 0"/>
                    <button name="action_reset"
                            string="Recommencer"
                            type="object" class="btn-secondary"
                            invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,preview,done"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1>Nettoyage des lignes d'inventaire orphelines</h1>
                        <p class="text-muted" invisible="state != 'draft'">
                            Recherche les lignes d'inventaire physique (<code>physical.inventory.line</code>)
                            sans inventaire parent et dont la quantité comptée est égale à 0.
                        </p>
                    </div>

                    <div invisible="state == 'draft'">
                        <group>
                            <field name="count_found" string="Lignes trouvées"/>
                        </group>

                        <field name="line_ids" nolabel="1" readonly="1">
                            <list decoration-muted="state == 'done'">
                                <field name="product_id"/>
                                <field name="product_tmpl_id"/>
                                <field name="physical_qty"/>
                                <field name="active"/>
                                <field name="create_date"/>
                                <field name="state" widget="badge"
                                       decoration-info="state == 'preview'"
                                       decoration-success="state == 'done'"/>
                            </list>
                        </field>

                        <field name="summary_html" widget="html" readonly="1" nolabel="1"
                               invisible="state != 'done'"/>
                    </div>

                </sheet>
            </form>
        </field>
    </record>

    <record id="action_physical_inventory_line_cleanup_wizard" model="ir.actions.act_window">
        <field name="name">Nettoyage lignes d'inventaire orphelines</field>
        <field name="res_model">physical.inventory.line.cleanup.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
