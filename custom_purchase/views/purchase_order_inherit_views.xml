<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Vue liste pour le catalogue achat — lecture seule, produits en D déjà exclus par domaine -->
    <record id="product_view_list_catalog_purchase" model="ir.ui.view">
        <field name="name">product.view.list.catalog.purchase</field>
        <field name="model">product.product</field>
        <field name="arch" type="xml">
            <list string="Produits" create="false" default_order="default_code, name">
                <field name="default_code" string="Référence" optional="show"/>
                <field name="name" string="Produit"/>
                <field name="categ_id" string="Catégorie" optional="show"/>
                <field name="uom_id" string="Unité" groups="uom.group_uom" optional="show"/>
                <field name="current_company_status_id" string="Statut magasin" optional="show"/>
            </list>
        </field>
    </record>

    <!--
        Filtre produits dans purchase.order.line :
          - actif_x3 = '1' (Actif X3 uniquement)
          - Aucun statut magasin avec code 'D' pour la société courante
            (opérateur "not any" sur company_status_ids — Odoo 17+)
        Les produits sans statut défini pour ce magasin sont inclus.
    -->

    <record id="view_purchase_order_filter_products" model="ir.ui.view">
        <field name="name">purchase.order.line.product.filter</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']//field[@name='product_id']"
                   position="attributes">
                <attribute name="domain">[
                    ('actif_x3', '=', '1'),
                    ('company_status_ids', 'not any', [
                        ('company_id', '=', parent.company_id),
                        ('status_id.code', '=', 'D')
                    ])
                ]</attribute>
                <attribute name="options">{"no_create": True, "no_create_edit": True}</attribute>
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute name="options">{'no_create': True, 'no_create_edit': True}</attribute>
            </xpath>
        </field>
    </record>

</odoo>
