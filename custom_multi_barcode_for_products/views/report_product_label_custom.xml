<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <!--
        ====================================================================
        Étiquette 2×7  (97 mm × 37.1 mm)  —  Sangel
        ====================================================================
        -->
        <template id="report_simple_label2x7_ttc"
                  inherit_id="product.report_simple_label2x7"
                  name="Étiquette 2×7 – Prix TTC Sangel">

            <xpath expr="//div[hasclass('o_label_full')]" position="replace">

                <t t-set="price_ht"
                   t-value="pricelist._get_product_price(
                                product, 1,
                                currency=pricelist.currency_id or product.currency_id)"/>
                <t t-set="applicable_taxes"
                   t-value="product.taxes_id.filtered(
                                lambda t: t.company_id == product.env.user.company_id)"/>
                <t t-set="tax_result"
                   t-value="applicable_taxes.compute_all(
                                price_ht,
                                pricelist.currency_id or product.currency_id,
                                1, product=product)"/>
                <t t-set="price_ttc" t-value="tax_result['total_included']"/>
                <t t-set="company"     t-value="env.user.company_id"/>
                <t t-set="logo_binary" t-value="company.label_logo"/>

                <div class="o_label_full" t-att-style="table_style"
                     style="font-family:Arial,Helvetica,sans-serif;
                            box-sizing:border-box; overflow:hidden;
                            padding:0; margin:0;">

                    <table style="width:100%; border-collapse:collapse;">

                        <!-- ① NOM -->
                        <tr>
                            <td colspan="2"
                                style="padding:1.2mm 2.5mm 1mm 2.5mm;
                                       border-bottom:0.5pt solid #bbb;
                                       vertical-align:middle;">
                                <strong t-field="product.display_name"
                                        style="font-size:9.5pt; font-weight:900; line-height:1.1;"/>
                            </td>
                        </tr>

                        <!-- ② CORPS -->
                        <tr style="height:18mm;">
                            <!-- PRIX -->
                            <td style="padding:1.5mm 2mm 1mm 2.5mm; vertical-align:middle;">
                                <div class="o_label_extra_data"><t t-out="extra_html"/></div>
                                <span style="font-size:7.5pt; font-weight:700;
                                             line-height:1; display:block; margin-bottom:1mm;">
                                    FCFA&#160;/&#160;<span t-field="product.uom_id.name"/>
                                </span>
                                <strong style="font-size:30pt; font-weight:900;
                                               line-height:0.9; letter-spacing:-0.5px; display:block;">
                                    <t t-out="'{:,.0f}'.format(price_ttc).replace(',', '\u00a0')"/>
                                </strong>
                            </td>
                            <!-- LOGO : div wrapper hauteur fixe + overflow:hidden
                                 → img height:100% garantit le rendu quelle que
                                   soit la version de wkhtmltopdf -->
                            <td style="width:28mm; vertical-align:middle;
                                       text-align:center; padding:1mm 2mm 1mm 1mm;">
                                <div style="height:15mm; overflow:hidden;">
                                    <img t-if="logo_binary"
                                         t-att-src="image_data_uri(logo_binary)"
                                         style="height:100%; width:auto;"/>
                                    <img t-else=""
                                         src="/custom_multi_barcode_for_products/static/img/etiquette.png"
                                         style="height:100%; width:auto;"/>
                                </div>
                            </td>
                        </tr>

                        <!-- ③ BARCODE + RÉF + DATE -->
                        <tr>
                            <td colspan="2"
                                style="border-top:0.5pt solid #bbb;
                                       padding:0.8mm 2.5mm; vertical-align:middle;">
                                <table style="width:100%; border-collapse:collapse;">
                                    <tr>
                                        <td style="vertical-align:middle; width:38mm;">
                                            <t t-if="barcode">
                                                <div t-out="barcode"
                                                     t-options="{'widget': 'barcode',
                                                                 'symbology': 'auto',
                                                                 'img_style': 'width:36mm;height:7mm'}"/>
                                            </t>
                                        </td>
                                        <td style="vertical-align:middle; padding-left:2mm;
                                                   font-size:5pt; line-height:1.5;">
                                            <span style="display:block; font-weight:700; color:#222;">
                                                <t t-out="barcode"/>
                                            </span>
                                            <span style="display:block; color:#555;">
                                                <t t-if="product.default_code">
                                                    <span t-field="product.default_code"/>&#160;&#160;
                                                </t>
                                                <t t-out="datetime.date.today().strftime('%d/%m/%Y')"/>
                                            </span>
                                        </td>
                                    </tr>
                                </table>
                            </td>
                        </tr>

                    </table>
                </div>
            </xpath>
        </template>


        <!--
        ====================================================================
        Étiquette 4×7  (47 mm × 37.1 mm)  —  Sangel
        ====================================================================
        -->
