<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <!-- ======================= ETIQUETTE 2x7 ======================= -->
        <template id="report_simple_label2x7_ttc"
                  inherit_id="product.report_simple_label2x7"
                  name="Etiquette 2x7 - Prix TTC Sangel">

            <xpath expr="//div[hasclass('o_label_full')]" position="replace">

                <t t-set="price_ht"
                   t-value="pricelist._get_product_price(
                                product, 1,
                                currency=pricelist.currency_id or product.currency_id)
                             if pricelist else (product.lst_price if product._name == 'product.product' else product.list_price)"/>
                <t t-set="applicable_taxes"
                   t-value="product.taxes_id.filtered(
                                lambda t: t.company_id == product.env.company)"/>
                <t t-set="tax_result"
                   t-value="applicable_taxes.compute_all(
                                price_ht,
                                (pricelist.currency_id if pricelist else False) or product.currency_id,
                                1, product=product)"/>
                <t t-set="price_ttc" t-value="tax_result['total_included']"/>
                <t t-set="company"   t-value="product.env.company"/>
                <t t-set="logo_bin"  t-value="company.label_logo"/>
                <t t-set="hcol"      t-value="company.primary_color or '#1a3a5c'"/>
                <t t-set="today"         t-value="datetime.date.today()"/>
                <t t-set="curr_co_id"    t-value="product.env.company.id"/>
                <t t-set="variant_ids"   t-value="[product.id] if product._name == 'product.product' else product.product_variant_ids.ids"/>
                <t t-set="active_promos" t-value="product.env['sale.promotion'].sudo().search([('date_start', '&lt;=', today), ('date_end', '&gt;=', today), ('active', '=', True), '|', ('company_ids', '=', False), ('company_ids', 'in', [curr_co_id])])"/>
                <t t-set="promo_line"    t-value="product.env['sale.promotion.line'].sudo().search([('product_id', 'in', variant_ids), ('promotion_id', 'in', active_promos.ids)], limit=1)"/>
                <t t-set="price_display" t-value="promo_line.promo_ttc if promo_line else price_ttc"/>

                <!-- GRAMMAGE -->
                <t t-set="is_grame"   t-value="is_grame   if is_grame   else False"/>
                <t t-set="unit_grame" t-value="unit_grame if unit_grame else 100.0"/>
                <t t-set="price_display" t-value="(price_display / 1000.0 * unit_grame) if is_grame else price_display"/>
                <t t-set="price_ttc"     t-value="(price_ttc / 1000.0 * unit_grame) if is_grame else price_ttc"/>
                <t t-set="unit_label"    t-value="('%dG' % int(unit_grame)) if is_grame else product.uom_id.name"/>

                <div class="o_label_full"
                     t-att-style="table_style + ';font-family:Arial,Helvetica,sans-serif;box-sizing:border-box;overflow:hidden;padding:0;margin:0;'">

                    <table style="width:100%;
                                  height:100%;
                                  border-collapse:collapse;
                                  table-layout:fixed;">

                        <!-- NOM -->
                        <tr>
                            <td colspan="2"
                                style="padding:1mm 3mm 0.5mm 3mm;text-align:left;">
                                <div style="font-size:14pt;font-weight:900;line-height:1.15;height:12mm;overflow:hidden;color:#111;">
                                    <t t-out="product.name"/>
                                </div>
                            </td>
                        </tr>

                        <!-- CORPS -->
                        <tr style="height:23mm;">

                            <!-- GAUCHE : prix + unite + ref -->
                            <td style="vertical-align:top;
                                       padding:0.5mm 1mm 1mm 3mm;
                                       text-align:center;">

                                <div class="o_label_extra_data"
                                     style="font-size:4pt; line-height:1;">
                                    <t t-out="extra_html"/>
                                </div>

                                <!-- PRIX + UNITE sur la même ligne -->
                                <t t-if="promo_line">
                                    <div style="white-space:nowrap;line-height:1;">
                                        <span style="font-size:10pt;font-weight:700;color:#666;text-decoration:line-through;vertical-align:top;"><t t-out="'{:,.0f}'.format(price_ttc).replace(',', '&#160;')"/></span>
                                        <span style="font-size:45pt;font-weight:900;color:#111;letter-spacing:-1px;vertical-align:top;">&#160;<t t-out="'{:,.0f}'.format(price_display).replace(',', '&#160;')"/></span>
                                        <span style="font-size:7pt;font-weight:700;color:#111;vertical-align:top;margin-left:1mm;">FCFA&#160;/&#160;<t t-out="unit_label"/></span>
                                    </div>
                                </t>
                                <t t-else="">
                                    <div style="white-space:nowrap;line-height:1;">
                                        <span style="font-size:45pt;font-weight:900;color:#111;letter-spacing:-1px;vertical-align:top;"><t t-out="'{:,.0f}'.format(price_display).replace(',', '&#160;')"/></span>
                                        <span style="font-size:7pt;font-weight:700;color:#111;vertical-align:top;margin-left:1mm;">FCFA&#160;/&#160;<t t-out="unit_label"/></span>
                                    </div>
                                </t>

                                <!-- REF + DATE -->
                                <div style="font-size:7pt;font-weight:700;color:#111;margin-top:1mm;text-align:left;letter-spacing:0.5px;line-height:1.2;">
                                    <t t-out="product.default_code"/>&#160;&#160;<t t-out="datetime.date.today().strftime('%d/%m/%Y')"/>
                                </div>

                            </td>

                            <!-- DROITE : logo collé à droite, pleine hauteur -->
                            <td style="width:30mm;
                                       padding:0;
                                       vertical-align:top;">
                                <img t-if="logo_bin"
                                     t-att-src="image_data_uri(logo_bin)"
                                     style="display:block;
                                            width:30mm;
                                            height:23mm;
                                            object-fit:cover;
                                            object-position:right center;
                                            margin-left:auto;"/>
                                <img t-else=""
                                     src="/custom_multi_barcode_for_products/static/img/etiquette.png"
                                     style="display:block;
                                            width:30mm;
                                            height:23mm;
                                            object-fit:cover;
                                            object-position:right center;
                                            margin-left:auto;"/>
                            </td>

                        </tr>

                    </table>
                </div>
            </xpath>
        </template>


        <!-- ======================= ETIQUETTE 4x7 ======================= -->
        <template id="report_simple_label4x7_ttc"
                  inherit_id="product.report_simple_label4x7"
                  name="Etiquette 4x7 - Prix TTC Sangel">

            <xpath expr="//div[hasclass('o_label_full')]" position="replace">

                <t t-set="price_ht"
                   t-value="pricelist._get_product_price(
                                product, 1,
                                currency=pricelist.currency_id or product.currency_id)
                             if pricelist else (product.lst_price if product._name == 'product.product' else product.list_price)"/>
                <t t-set="applicable_taxes"
                   t-value="product.taxes_id.filtered(
                                lambda t: t.company_id == product.env.company)"/>
                <t t-set="tax_result"
                   t-value="applicable_taxes.compute_all(
                                price_ht,
                                (pricelist.currency_id if pricelist else False) or product.currency_id,
                                1, product=product)"/>
                <t t-set="price_ttc" t-value="tax_result['total_included']"/>
                <t t-set="company"   t-value="product.env.company"/>
                <t t-set="logo_bin"  t-value="company.label_logo"/>
                <t t-set="hcol"      t-value="company.primary_color or '#1a3a5c'"/>
                <t t-set="today"         t-value="datetime.date.today()"/>
                <t t-set="curr_co_id"    t-value="product.env.company.id"/>
                <t t-set="variant_ids"   t-value="[product.id] if product._name == 'product.product' else product.product_variant_ids.ids"/>
                <t t-set="active_promos" t-value="product.env['sale.promotion'].sudo().search([('date_start', '&lt;=', today), ('date_end', '&gt;=', today), ('active', '=', True), '|', ('company_ids', '=', False), ('company_ids', 'in', [curr_co_id])])"/>
                <t t-set="promo_line"    t-value="product.env['sale.promotion.line'].sudo().search([('product_id', 'in', variant_ids), ('promotion_id', 'in', active_promos.ids)], limit=1)"/>
                <t t-set="price_display" t-value="promo_line.promo_ttc if promo_line else price_ttc"/>

                <div class="o_label_full"
                     t-att-style="table_style + ';font-family:Arial,Helvetica,sans-serif;box-sizing:border-box;overflow:hidden;padding:0;margin:0;'">

                    <table style="width:100%;
                                  height:100%;
                                  border-collapse:collapse;
                                  table-layout:fixed;">

                        <!-- NOM -->
                        <tr>
                            <td colspan="2"
                                t-att-style="'padding:1.5mm 2mm 1mm 2mm;text-align:center;border-bottom:1.5pt solid ' + hcol + ';'">
                                <div style="font-size:7.5pt;font-weight:900;line-height:1.2;text-align:center;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:#111;">
                                    <t t-out="product.name"/>
                                </div>
                            </td>
                        </tr>

                        <!-- PRIX + LOGO -->
                        <tr style="height:28mm;">

                            <!-- GAUCHE : prix + unite + ref -->
                            <td style="vertical-align:top;
                                       padding:0.5mm 0.5mm 1.5mm 2mm;
                                       text-align:center;">

                                <div class="o_label_extra_data"
                                     style="font-size:4pt; line-height:1;">
                                    <t t-out="extra_html"/>
                                </div>

                                <!-- PRIX -->
                                <t t-if="promo_line">
                                    <div style="font-size:26pt;
                                                font-weight:900;
                                                line-height:1;
                                                white-space:nowrap;
                                                text-align:center;
                                                letter-spacing:-1px;">
                                        <span style="font-size:8pt;font-weight:700;color:#666;text-decoration:line-through;vertical-align:middle;"><t t-out="'{:,.0f}'.format(price_ttc).replace(',', '&#160;')"/></span>
                                        <span style="color:#111;vertical-align:middle;">&#160;<t t-out="'{:,.0f}'.format(price_display).replace(',', '&#160;')"/></span>
                                    </div>
                                </t>
                                <t t-else="">
                                    <div style="font-size:26pt;
                                                font-weight:900;
                                                line-height:1;
                                                color:#111;
                                                letter-spacing:-1px;
                                                white-space:nowrap;
                                                text-align:center;">
                                        <t t-out="'{:,.0f}'.format(price_display).replace(',', '&#160;')"/>
                                    </div>
                                </t>

                                <!-- UNITE -->
                                <div style="font-size:7pt;
                                            font-weight:700;
                                            color:#111;
                                            margin-top:1mm;
                                            text-align:center;
                                            line-height:1;">
                                    FCFA&#160;/&#160;<t t-out="product.uom_id.name"/>
                                </div>

                                <!-- REF VISIBLE -->
                                <t t-if="product.default_code">
                                    <div style="font-size:6.5pt;
                                                color:#111;
                                                margin-top:1mm;
                                                font-weight:900;
                                                text-align:center;
                                                letter-spacing:0.5px;
                                                line-height:1.2;">
                                        Ref&#160;:&#160;<t t-out="product.default_code"/><br/>Imprimé le&#160;:&#160;<t t-out="datetime.date.today().strftime('%d/%m/%Y')"/>
                                    </div>
                                </t>

                            </td>

                            <!-- DROITE : logo collé à droite, pleine hauteur -->
                            <td style="width:16mm;
                                       padding:0;
                                       vertical-align:top;">
                                <img t-if="logo_bin"
                                     t-att-src="image_data_uri(logo_bin)"
                                     style="display:block;
                                            width:16mm;
                                            height:28mm;
                                            object-fit:cover;
                                            object-position:right center;
                                            margin-left:auto;"/>
                                <img t-else=""
                                     src="/custom_multi_barcode_for_products/static/img/etiquette.png"
                                     style="display:block;
                                            width:16mm;
                                            height:28mm;
                                            object-fit:cover;
                                            object-position:right center;
                                            margin-left:auto;"/>
                            </td>

                        </tr>

                    </table>
                </div>
            </xpath>
        </template>

    </data>
</odoo>
