<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_company_form_label_logo" model="ir.ui.view">
            <field name="name">res.company.form.label.logo</field>
            <field name="model">res.company</field>
            <field name="inherit_id" ref="base.view_company_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='logo']" position="after">
                    <field name="label_logo"
                           widget="image"
                           string="Logo étiquette produit"
                           options="{'size': [128, 128]}"
                           help="Logo affiché sur les étiquettes produits. Remplacez cette image sans modifier le code."/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
