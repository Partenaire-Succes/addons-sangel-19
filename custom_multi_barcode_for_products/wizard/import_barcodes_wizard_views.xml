<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_import_barcodes_wizard_form" model="ir.ui.view">
            <field name="name">import.barcodes.wizard.form</field>
            <field name="model">import.barcodes.wizard</field>
            <field name="arch" type="xml">
                <form string="Import Excel - Codes-Barres Produits">

                    <!-- Zone upload (état brouillon) -->
                    <group invisible="state != 'draft'">
                        <group string="Fichier à importer">
                            <field name="file" filename="file_name" widget="binary"
                                   help="Fichier Excel avec colonnes : code_article | barcode"/>
                            <field name="file_name" invisible="1"/>
                        </group>
                    </group>

                    <!-- Bouton télécharger template -->
                    <div invisible="state != 'draft'" class="mb-3">
                        <button name="action_download_template"
                                type="object"
                                string="Télécharger le template Excel"
                                class="btn-secondary"
                                icon="fa-download"/>
                    </div>

                    <!-- Bouton charger -->
                    <button name="action_load_file"
                            type="object"
                            string="Charger le fichier"
                            class="btn-primary"
                            invisible="state != 'draft'"/>

                    <!-- Résumé après chargement -->
                    <group invisible="state == 'draft'">
                        <group string="Résumé">
                            <field name="count_ok" string="Lignes valides" readonly="1"/>
                            <field name="count_errors" string="Lignes en erreur" readonly="1"/>
                        </group>
                    </group>

                    <!-- Tableau des lignes -->
                    <field name="line_ids" invisible="state == 'draft'" readonly="1">
                        <list decoration-success="status == 'ok'"
                              decoration-danger="status == 'product_not_found'"
                              decoration-warning="status == 'barcode_exists'">
                            <field name="product_code" string="Code Article (Excel)"/>
                            <field name="barcode" string="Code-Barres (Excel)"/>
                            <field name="product_id" string="Produit trouvé"/>
                            <field name="status" string="Statut"/>
                        </list>
                    </field>

                    <footer>
                        <button name="action_confirm"
                                type="object"
                                string="Confirmer l'import"
                                class="btn-success"
                                invisible="state != 'loaded'"/>
                        <button string="Annuler" special="cancel"/>
                    </footer>

                </form>
            </field>
        </record>

        <record id="action_import_barcodes_wizard" model="ir.actions.act_window">
            <field name="name">Import Excel Codes-Barres</field>
            <field name="res_model">import.barcodes.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <menuitem id="menu_import_product_barcodes"
                  name="Import Excel Codes-Barres"
                  parent="stock.menu_stock_root"
                  action="action_import_barcodes_wizard"
                  groups="stock.group_stock_manager"
                  sequence="99"/>

    </data>
</odoo>
